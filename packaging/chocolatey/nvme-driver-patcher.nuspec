<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>nvme-driver-patcher</id>
    <version>5.1.0</version>
    <title>NVMe Driver Patcher</title>
    <authors>SysAdminDoc</authors>
    <owners>SysAdminDoc</owners>
    <projectUrl>https://github.com/SysAdminDoc/win11-nvme-driver-patcher</projectUrl>
    <licenseUrl>https://github.com/SysAdminDoc/win11-nvme-driver-patcher/blob/main/LICENSE</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>Enable the Server 2025 Native NVMe driver (nvmedisk.sys) on Windows 11, replacing the legacy SCSI translation layer for improved NVMe performance. Includes Safe/Full mode profiles, BitLocker auto-suspend, VeraCrypt hard block, recovery kit, post-reboot verification, native FeatureStore fallback with ViVeTool as the secondary path, and a stability watchdog with auto-revert.</description>
    <summary>GUI + CLI tool to enable native NVMe on Windows 11 with full safety net.</summary>
    <tags>nvme storage performance driver windows11 sysadmin</tags>
    <releaseNotes>https://github.com/SysAdminDoc/win11-nvme-driver-patcher/releases/latest</releaseNotes>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
  </files>
</package>
