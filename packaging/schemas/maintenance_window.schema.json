{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/SysAdminDoc/win11-nvme-driver-patcher/packaging/schemas/maintenance_window.schema.json",
  "title": "NVMe Driver Patcher Maintenance Window",
  "description": "Schema for maintenance_window.json. Gates auto-revert and scheduled actions so they don't fire mid-workday.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "Enabled":    { "type": "boolean", "default": false },
    "StartHour":  { "type": "integer", "minimum": 0, "maximum": 23, "default": 22 },
    "EndHour":    { "type": "integer", "minimum": 0, "maximum": 23, "default": 6 },
    "ActiveDays": {
      "type": "array",
      "items": { "type": "string", "enum": ["Sunday","Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"] },
      "uniqueItems": true,
      "default": ["Monday","Tuesday","Wednesday","Thursday","Friday"]
    }
  }
}
