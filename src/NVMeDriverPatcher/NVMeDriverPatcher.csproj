<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <AssemblyName>NVMeDriverPatcher</AssemblyName>
    <RootNamespace>NVMeDriverPatcher</RootNamespace>
    <ApplicationIcon>..\..\icon.ico</ApplicationIcon>
    <Version>4.3.6</Version>
    <AssemblyVersion>4.3.6.0</AssemblyVersion>
    <FileVersion>4.3.6.0</FileVersion>
    <Company>SysAdminDoc</Company>
    <Product>NVMe Driver Patcher</Product>
    <Description>Enable the Server 2025 Native NVMe driver on Windows 11</Description>
    <PublishSingleFile>true</PublishSingleFile>
    <SelfContained>true</SelfContained>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <ItemGroup>
    <Resource Include="nvme.ico"/>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.0" />
    <PackageReference Include="LiveChartsCore.SkiaSharpView.WPF" Version="2.0.0-rc3.3" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Sqlite" Version="9.0.3" />
    <PackageReference Include="System.Management" Version="9.0.2" />
  </ItemGroup>

</Project>
