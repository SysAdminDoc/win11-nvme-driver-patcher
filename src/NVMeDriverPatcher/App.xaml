<Application x:Class="NVMeDriverPatcher.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:NVMeDriverPatcher.Converters"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/DarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
            <conv:SettingsToggleConverter x:Key="SettingsToggle"/>
            <conv:StringToColorConverter x:Key="StrToColor"/>
            <conv:StringToBrushConverter x:Key="StrToBrush"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
