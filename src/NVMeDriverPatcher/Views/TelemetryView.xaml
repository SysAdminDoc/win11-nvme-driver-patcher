<UserControl x:Class="NVMeDriverPatcher.Views.TelemetryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,4,0">
            <StackPanel>
                <TextBlock Text="Drive Telemetry" Style="{StaticResource SectionEyebrow}"/>
                <TextBlock Text="Inspect one NVMe drive at a time and compare a fresh snapshot against recent local history."
                           Margin="0,8,0,0"
                           Style="{StaticResource BodyCopy}"/>
            </StackPanel>

            <Border Margin="0,18,0,0" Style="{StaticResource InsetCard}">
                <StackPanel>
                    <TextBlock Text="Source" Style="{StaticResource SectionEyebrow}"/>
                    <StackPanel Margin="0,14,0,0">
                        <TextBlock Text="Drive"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontWeight="SemiBold"/>
                        <ComboBox x:Name="DriveSelector"
                                  MinWidth="220"
                                  MaxWidth="420"
                                  Margin="0,10,0,0"
                                  HorizontalAlignment="Left"
                                  Style="{StaticResource DarkComboBox}"
                                  AutomationProperties.Name="Select NVMe drive for telemetry"
                                  SelectionChanged="DriveSelector_Changed"/>
                    </StackPanel>

                    <Border x:Name="TelemetryStatusCard"
                            Margin="0,14,0,0"
                            Padding="14,12"
                            Background="{StaticResource SurfaceInset}"
                            BorderBrush="{StaticResource Border}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <TextBlock x:Name="TelemetryStatusText"
                                   Foreground="{StaticResource TextDim}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Text="Choose an NVMe drive to capture a fresh health snapshot and review recent history."/>
                    </Border>
                </StackPanel>
            </Border>

            <Border Margin="0,18,0,0" Style="{StaticResource InsetCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="148"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Snapshot"
                               Style="{StaticResource SectionEyebrow}"/>
                    <StackPanel Grid.Column="1">
                        <TextBlock x:Name="TelemetrySourceValue"
                                   Foreground="{StaticResource Accent}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"/>
                        <TextBlock x:Name="TelemetrySourceDetail"
                                   Margin="0,4,0,0"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <Border Grid.Row="1"
                            Grid.ColumnSpan="2"
                            Margin="0,12"
                            Height="1"
                            Background="{StaticResource Border}"/>
                    <TextBlock Grid.Row="2"
                               Text="History"
                               Style="{StaticResource SectionEyebrow}"/>
                    <StackPanel Grid.Row="2"
                                Grid.Column="1">
                        <TextBlock x:Name="TelemetryHistoryValue"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"/>
                        <TextBlock x:Name="TelemetryHistoryDetail"
                                   Margin="0,4,0,0"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <Border Grid.Row="3"
                            Grid.ColumnSpan="2"
                            Margin="0,12"
                            Height="1"
                            Background="{StaticResource Border}"/>
                    <TextBlock Grid.Row="4"
                               Text="Trend"
                               Style="{StaticResource SectionEyebrow}"/>
                    <StackPanel Grid.Row="4"
                                Grid.Column="1"
                                Margin="0,0,0,0">
                        <TextBlock x:Name="TelemetryTrendValue"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"/>
                        <TextBlock x:Name="TelemetryTrendDetail"
                                   Margin="0,4,0,0"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Margin="0,18,0,0" Style="{StaticResource InsetCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0"
                                Grid.Column="0">
                        <TextBlock Text="Temperature" Style="{StaticResource SectionEyebrow}"/>
                        <TextBlock x:Name="TempValue"
                                   Text="-"
                                   Margin="0,8,0,0"
                                   Foreground="{StaticResource Green}"
                                   FontSize="24"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Current thermal reading"
                                   Margin="0,4,0,0"
                                   Foreground="{StaticResource TextDim}"
                                   FontSize="11"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0"
                                Grid.Column="2">
                        <TextBlock Text="Life Remaining" Style="{StaticResource SectionEyebrow}"/>
                        <TextBlock x:Name="WearValue"
                                   Text="-"
                                   Margin="0,8,0,0"
                                   Foreground="{StaticResource Green}"
                                   FontSize="24"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Estimated endurance left"
                                   Margin="0,4,0,0"
                                   Foreground="{StaticResource TextDim}"
                                   FontSize="11"/>
                    </StackPanel>

                    <Border Grid.Row="1"
                            Grid.ColumnSpan="3"
                            Margin="0,16,0,16"
                            Height="1"
                            Background="{StaticResource Border}"/>

                    <StackPanel Grid.Row="2"
                                Grid.Column="0"
                                Margin="0,0,0,0">
                        <TextBlock Text="Power-On Hours" Style="{StaticResource SectionEyebrow}"/>
                        <TextBlock x:Name="PohValue"
                                   Text="-"
                                   Margin="0,8,0,0"
                                   Foreground="{StaticResource Accent}"
                                   FontSize="24"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Controller lifetime usage"
                                   Margin="0,4,0,0"
                                   Foreground="{StaticResource TextDim}"
                                   FontSize="11"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2"
                                Grid.Column="2"
                                Margin="0,0,0,0">
                        <TextBlock Text="Media Errors" Style="{StaticResource SectionEyebrow}"/>
                        <TextBlock x:Name="ErrorsValue"
                                   Text="-"
                                   Margin="0,8,0,0"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="24"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Reported controller errors"
                                   Margin="0,4,0,0"
                                   Foreground="{StaticResource TextDim}"
                                   FontSize="11"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Expander Margin="0,18,0,0"
                      IsExpanded="False"
                      Style="{StaticResource DarkExpander}">
                <Expander.Header>
                    <TextBlock Text="Temperature trend"
                               FontWeight="SemiBold"/>
                </Expander.Header>
                <StackPanel>
                    <TextBlock Text="Local samples from the last seven days make thermal drift easier to spot than one peak reading."
                               Style="{StaticResource BodyCopy}"/>
                    <Grid Height="220" Margin="0,16,0,0">
                        <lvc:CartesianChart x:Name="TempChart"
                                            AutomationProperties.Name="Temperature trend chart"
                                            TooltipPosition="Hidden"
                                            LegendPosition="Hidden"/>
                        <Border x:Name="TempHistoryPlaceholder"
                                Style="{StaticResource EmptyStateCard}"
                                Visibility="Collapsed">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="No temperature history yet"
                                           Style="{StaticResource EmptyStateTitle}"/>
                                <TextBlock Text="Poll this drive again later to build a usable local trend instead of relying on a single thermal snapshot."
                                           Margin="0,8,0,0"
                                           Style="{StaticResource EmptyStateBody}"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Expander>

            <Expander Margin="0,18,0,0"
                      IsExpanded="False"
                      Style="{StaticResource DarkExpander}">
                <Expander.Header>
                    <TextBlock Text="Wear trend"
                               FontWeight="SemiBold"/>
                </Expander.Header>
                <StackPanel>
                    <TextBlock Text="Endurance changes slowly, so this view becomes more useful as more local samples accumulate."
                               Style="{StaticResource BodyCopy}"/>
                    <Grid Height="220" Margin="0,16,0,0">
                        <lvc:CartesianChart x:Name="WearChart"
                                            AutomationProperties.Name="Wear trend chart"
                                            TooltipPosition="Hidden"
                                            LegendPosition="Hidden"/>
                        <Border x:Name="WearHistoryPlaceholder"
                                Style="{StaticResource EmptyStateCard}"
                                Visibility="Collapsed">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="No endurance history yet"
                                           Style="{StaticResource EmptyStateTitle}"/>
                                <TextBlock Text="Wear usually changes gradually, so this chart fills out over time as more local samples are stored."
                                           Margin="0,8,0,0"
                                           Style="{StaticResource EmptyStateBody}"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Expander>
        </StackPanel>
    </ScrollViewer>
</UserControl>
