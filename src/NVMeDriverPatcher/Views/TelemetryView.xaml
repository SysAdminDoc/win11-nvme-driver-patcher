<UserControl x:Class="NVMeDriverPatcher.Views.TelemetryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">

    <Border Background="#FF111113" CornerRadius="10" Padding="20,16" BorderBrush="#FF1a1a1e" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="180"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="180"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                <TextBlock Text="NVMe TELEMETRY" Foreground="#FF52525b" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                <ComboBox x:Name="DriveSelector" Margin="12,0,0,0" Width="200" Height="26" FontSize="11"
                          Background="#FF18181b" Foreground="#FFfafafa" BorderBrush="#FF3f3f46"
                          SelectionChanged="DriveSelector_Changed"/>
            </StackPanel>

            <!-- Health gauges -->
            <Grid Grid.Row="1" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/><ColumnDefinition Width="10"/>
                    <ColumnDefinition/><ColumnDefinition Width="10"/>
                    <ColumnDefinition/><ColumnDefinition Width="10"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#FF0d0d10" CornerRadius="8" Padding="12,10">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Temperature" Foreground="#FF71717a" FontSize="9" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TempValue" Text="-" Foreground="#FF22c55e" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="#FF0d0d10" CornerRadius="8" Padding="12,10">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Life Remaining" Foreground="#FF71717a" FontSize="9" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="WearValue" Text="-" Foreground="#FF22c55e" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="4" Background="#FF0d0d10" CornerRadius="8" Padding="12,10">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Power-On Hours" Foreground="#FF71717a" FontSize="9" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="PohValue" Text="-" Foreground="#FF3b82f6" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="6" Background="#FF0d0d10" CornerRadius="8" Padding="12,10">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Media Errors" Foreground="#FF71717a" FontSize="9" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="ErrorsValue" Text="-" Foreground="#FFd4d4d8" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Temperature chart -->
            <TextBlock Grid.Row="2" Text="TEMPERATURE HISTORY" Foreground="#FF3f3f46" FontSize="9" FontWeight="Bold" Margin="0,8,0,4"/>
            <lvc:CartesianChart x:Name="TempChart" Grid.Row="3"
                                TooltipPosition="Hidden" LegendPosition="Hidden"/>

            <!-- Wear chart -->
            <TextBlock Grid.Row="4" Text="WEAR LEVEL HISTORY" Foreground="#FF3f3f46" FontSize="9" FontWeight="Bold" Margin="0,12,0,4"/>
            <lvc:CartesianChart x:Name="WearChart" Grid.Row="5"
                                TooltipPosition="Hidden" LegendPosition="Hidden"/>
        </Grid>
    </Border>
</UserControl>
