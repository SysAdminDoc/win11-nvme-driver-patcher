<UserControl x:Class="NVMeDriverPatcher.Views.TelemetryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">

    <ScrollViewer VerticalScrollBarVisibility="Auto" PanningMode="VerticalFirst">
        <StackPanel Margin="0,0,4,0">
            <StackPanel>
                <TextBlock Text="Telemetry" Style="{StaticResource SectionEyebrow}"/>
                <TextBlock Text="Inspect the selected NVMe drive and compare a fresh snapshot against recent local history."
                           Margin="0,4,0,0"
                           Style="{StaticResource BodyCopy}"/>
            </StackPanel>

            <Border Margin="0,10,0,0" Style="{StaticResource InsetCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Source" Style="{StaticResource SectionEyebrow}"/>
                        <TextBlock Text="Drive"
                                   Margin="0,8,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontWeight="SemiBold"/>
                        <ComboBox x:Name="DriveSelector"
                                  MinWidth="220"
                                  MaxWidth="280"
                                  Margin="0,6,0,0"
                                  HorizontalAlignment="Left"
                                  Style="{StaticResource DarkComboBox}"
                                  AutomationProperties.Name="Select NVMe drive for telemetry"
                                  SelectionChanged="DriveSelector_Changed"/>
                    </StackPanel>

                    <Border x:Name="TelemetryStatusCard"
                            Grid.Column="2"
                            Padding="12,10"
                            Background="{DynamicResource SurfaceInset}"
                            BorderBrush="{DynamicResource Border}"
                            BorderThickness="1"
                            CornerRadius="7"
                            VerticalAlignment="Stretch"
                            AutomationProperties.LiveSetting="Polite">
                        <TextBlock x:Name="TelemetryStatusText"
                                   Foreground="{DynamicResource TextDim}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"
                                   Text="Choose an NVMe drive to capture a fresh health snapshot and review recent history."/>
                    </Border>
                </Grid>
            </Border>

            <Border Margin="0,10,0,0" Style="{StaticResource InsetCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.25*"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="0.95*"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="104"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Snapshot" Style="{StaticResource SectionEyebrow}"/>
                        <StackPanel Grid.Column="1">
                            <TextBlock x:Name="TelemetrySourceValue"
                                       Foreground="{DynamicResource Accent}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="TelemetrySourceDetail"
                                       Margin="0,2,0,0"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="11.5"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <Border Grid.Row="1"
                                Grid.ColumnSpan="2"
                                Margin="0,8"
                                Height="1"
                                Background="{DynamicResource Border}"/>
                        <TextBlock Grid.Row="2"
                                   Text="History"
                                   Style="{StaticResource SectionEyebrow}"/>
                        <StackPanel Grid.Row="2"
                                    Grid.Column="1">
                            <TextBlock x:Name="TelemetryHistoryValue"
                                       Foreground="{DynamicResource TextPrimary}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="TelemetryHistoryDetail"
                                       Margin="0,2,0,0"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="11.5"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <Border Grid.Row="3"
                                Grid.ColumnSpan="2"
                                Margin="0,8"
                                Height="1"
                                Background="{DynamicResource Border}"/>
                        <TextBlock Grid.Row="4"
                                   Text="Trend"
                                   Style="{StaticResource SectionEyebrow}"/>
                        <StackPanel Grid.Row="4"
                                    Grid.Column="1">
                            <TextBlock x:Name="TelemetryTrendValue"
                                       Foreground="{DynamicResource TextPrimary}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="TelemetryTrendDetail"
                                       Margin="0,2,0,0"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="11.5"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Column="1"
                            Width="1"
                            Background="{DynamicResource Border}"/>

                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0">
                            <TextBlock Text="Temperature" Style="{StaticResource SectionEyebrow}"/>
                            <TextBlock x:Name="TempValue"
                                       Text="-"
                                       Margin="0,4,0,0"
                                       Foreground="{DynamicResource Green}"
                                       FontSize="20"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="Thermal"
                                       Margin="0,1,0,0"
                                       Foreground="{DynamicResource TextDim}"
                                       FontSize="10.5"/>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="2">
                            <TextBlock Text="Life" Style="{StaticResource SectionEyebrow}"/>
                            <TextBlock x:Name="WearValue"
                                       Text="-"
                                       Margin="0,4,0,0"
                                       Foreground="{DynamicResource Green}"
                                       FontSize="20"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="Remaining"
                                       Margin="0,1,0,0"
                                       Foreground="{DynamicResource TextDim}"
                                       FontSize="10.5"/>
                        </StackPanel>

                        <Border Grid.Row="1"
                                Grid.ColumnSpan="3"
                                Margin="0,9"
                                Height="1"
                                Background="{DynamicResource Border}"/>

                        <StackPanel Grid.Row="2" Grid.Column="0">
                            <TextBlock Text="Power-On" Style="{StaticResource SectionEyebrow}"/>
                            <TextBlock x:Name="PohValue"
                                       Text="-"
                                       Margin="0,4,0,0"
                                       Foreground="{DynamicResource Accent}"
                                       FontSize="20"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="Hours"
                                       Margin="0,1,0,0"
                                       Foreground="{DynamicResource TextDim}"
                                       FontSize="10.5"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="2">
                            <TextBlock Text="Errors" Style="{StaticResource SectionEyebrow}"/>
                            <TextBlock x:Name="ErrorsValue"
                                       Text="-"
                                       Margin="0,4,0,0"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="20"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="Media"
                                       Margin="0,1,0,0"
                                       Foreground="{DynamicResource TextDim}"
                                       FontSize="10.5"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <Expander Margin="0,10,0,0"
                      IsExpanded="True"
                      Style="{StaticResource DarkExpander}">
                <Expander.Header>
                    <TextBlock Text="Temperature trend" FontWeight="SemiBold"/>
                </Expander.Header>
                <StackPanel>
                    <TextBlock Text="Local samples from the last seven days make thermal drift easier to spot than one peak reading."
                               Style="{StaticResource BodyCopy}"/>
                    <Grid Height="210" Margin="0,10,0,0">
                        <lvc:CartesianChart x:Name="TempChart"
                                            AutomationProperties.Name="Temperature trend chart"
                                            TooltipPosition="Hidden"
                                            LegendPosition="Hidden"/>
                        <Border x:Name="TempHistoryPlaceholder"
                                Style="{StaticResource EmptyStateCard}"
                                Visibility="Collapsed">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="No temperature history yet"
                                           Style="{StaticResource EmptyStateTitle}"/>
                                <TextBlock Text="Poll this drive again later to build a usable local trend instead of relying on a single thermal snapshot."
                                           Margin="0,6,0,0"
                                           Style="{StaticResource EmptyStateBody}"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Expander>

            <Expander Margin="0,10,0,0"
                      IsExpanded="False"
                      Style="{StaticResource DarkExpander}">
                <Expander.Header>
                    <TextBlock Text="Wear trend" FontWeight="SemiBold"/>
                </Expander.Header>
                <StackPanel>
                    <TextBlock Text="Endurance changes slowly, so this view becomes more useful as more local samples accumulate."
                               Style="{StaticResource BodyCopy}"/>
                    <Grid Height="160" Margin="0,10,0,0">
                        <lvc:CartesianChart x:Name="WearChart"
                                            AutomationProperties.Name="Wear trend chart"
                                            TooltipPosition="Hidden"
                                            LegendPosition="Hidden"/>
                        <Border x:Name="WearHistoryPlaceholder"
                                Style="{StaticResource EmptyStateCard}"
                                Visibility="Collapsed">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="No endurance history yet"
                                           Style="{StaticResource EmptyStateTitle}"/>
                                <TextBlock Text="Wear usually changes gradually, so this chart fills out over time as more local samples are stored."
                                           Margin="0,6,0,0"
                                           Style="{StaticResource EmptyStateBody}"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Expander>
        </StackPanel>
    </ScrollViewer>
</UserControl>
