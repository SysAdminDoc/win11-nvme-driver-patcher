<UserControl x:Class="NVMeDriverPatcher.Views.BenchmarkComparisonView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <WrapPanel>
            <StackPanel MaxWidth="420" Margin="0,0,18,8">
                <TextBlock Text="Benchmark" Style="{StaticResource SectionEyebrow}"/>
                <TextBlock Text="Compare the latest run against the previous one so the patch decision stays grounded in this machine’s behavior."
                           Margin="0,4,0,0"
                           Style="{StaticResource BodyCopy}"/>
                <TextBlock x:Name="BenchmarkContextText"
                           Margin="0,6,0,0"
                           Foreground="{DynamicResource TextDim}"
                           FontSize="11"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <WrapPanel VerticalAlignment="Bottom">
                <Border x:Name="BenchmarkStateBadge"
                        Margin="0,0,10,8"
                        Style="{StaticResource StatusChipBorder}">
                    <TextBlock x:Name="BenchmarkStateText"
                               Text="Waiting"
                               Style="{StaticResource StatusChipText}"/>
                </Border>

                <StackPanel Margin="0,0,0,8"
                            VerticalAlignment="Bottom">
                    <TextBlock Text="Runs"
                               Style="{StaticResource SectionEyebrow}"/>
                    <TextBlock x:Name="RunCountValue"
                               Margin="0,4,0,0"
                               Foreground="{DynamicResource TextPrimary}"
                               FontSize="18"
                               FontWeight="SemiBold"/>
                </StackPanel>
            </WrapPanel>
        </WrapPanel>

        <Grid Grid.Row="1" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource MetricCard}">
                <StackPanel>
                    <TextBlock Text="Random Read" Style="{StaticResource SectionEyebrow}"/>
                    <WrapPanel Margin="0,5,0,0">
                        <TextBlock x:Name="ReadIopsValue"
                                   Text="-"
                                   Foreground="{DynamicResource Accent}"
                                   FontSize="21"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text=" IOPS"
                                   Margin="6,0,0,4"
                                   VerticalAlignment="Bottom"
                                   Foreground="{DynamicResource TextDim}"
                                   FontSize="12"/>
                    </WrapPanel>
                    <TextBlock x:Name="ReadDelta"
                               Margin="0,4,0,0"
                               Foreground="{DynamicResource TextMuted}"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource MetricCard}">
                <StackPanel>
                    <TextBlock Text="Random Write" Style="{StaticResource SectionEyebrow}"/>
                    <WrapPanel Margin="0,5,0,0">
                        <TextBlock x:Name="WriteIopsValue"
                                   Text="-"
                                   Foreground="{DynamicResource Yellow}"
                                   FontSize="21"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text=" IOPS"
                                   Margin="6,0,0,4"
                                   VerticalAlignment="Bottom"
                                   Foreground="{DynamicResource TextDim}"
                                   FontSize="12"/>
                    </WrapPanel>
                    <TextBlock x:Name="WriteDelta"
                               Margin="0,4,0,0"
                               Foreground="{DynamicResource TextMuted}"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border x:Name="InterpretationCard" Grid.Row="2" Margin="0,10,0,0" Style="{StaticResource InsetCard}">
            <StackPanel>
                <TextBlock Text="Summary" Style="{StaticResource SectionEyebrow}"/>
                <TextBlock x:Name="BenchmarkSummaryText"
                           Margin="0,5,0,0"
                           Foreground="{DynamicResource TextSecondary}"
                           FontSize="12"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Expander Grid.Row="3"
                  Margin="0,10,0,0"
                  IsExpanded="True"
                  Style="{StaticResource DarkExpander}">
            <Expander.Header>
                <TextBlock Text="Trend chart"
                           FontWeight="SemiBold"/>
            </Expander.Header>
            <StackPanel>
                <TextBlock x:Name="TrendHintText"
                           Text="Use the chart to confirm the latest run moved in the direction you expected."
                           Style="{StaticResource BodyCopy}"/>
                <lvc:CartesianChart x:Name="BenchChart"
                                    Height="300"
                                    Margin="0,8,0,0"
                                    AutomationProperties.Name="Benchmark trend chart"
                                    TooltipPosition="Hidden"
                                    LegendPosition="Hidden"/>
            </StackPanel>
        </Expander>
    </Grid>
</UserControl>
