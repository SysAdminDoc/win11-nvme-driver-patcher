<UserControl x:Class="NVMeDriverPatcher.Views.BenchmarkComparisonView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Benchmark Comparison"
                           Style="{StaticResource SectionEyebrow}"/>
                <TextBlock Text="Compare current results against the previous run to see whether this machine benefited from the driver change."
                           Margin="0,8,0,0"
                           Style="{StaticResource BodyCopy}"/>
                <TextBlock x:Name="BenchmarkContextText"
                           Margin="0,10,0,0"
                           Foreground="{StaticResource TextDim}"
                           FontSize="11"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <Border Grid.Column="1"
                    Padding="12,10"
                    Background="{StaticResource BgMedium}"
                    BorderBrush="{StaticResource Border}"
                    BorderThickness="1"
                    CornerRadius="12">
                <StackPanel>
                    <TextBlock Text="Runs" Style="{StaticResource SectionEyebrow}" HorizontalAlignment="Right"/>
                    <TextBlock x:Name="RunCountValue"
                               Margin="0,6,0,0"
                               HorizontalAlignment="Right"
                               Foreground="{StaticResource Accent}"
                               FontSize="22"
                               FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="1" Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource InsetCard}">
                <StackPanel>
                    <TextBlock Text="4K Random Read" Style="{StaticResource SectionEyebrow}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <TextBlock x:Name="ReadIopsValue"
                                   Text="-"
                                   Foreground="{StaticResource Accent}"
                                   FontSize="28"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text=" IOPS"
                                   Margin="4,0,0,4"
                                   VerticalAlignment="Bottom"
                                   Foreground="{StaticResource TextDim}"
                                   FontSize="12"/>
                    </StackPanel>
                    <TextBlock x:Name="ReadDelta"
                               Margin="0,8,0,0"
                               Foreground="{StaticResource TextMuted}"
                               FontSize="12"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource InsetCard}">
                <StackPanel>
                    <TextBlock Text="4K Random Write" Style="{StaticResource SectionEyebrow}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <TextBlock x:Name="WriteIopsValue"
                                   Text="-"
                                   Foreground="{StaticResource Yellow}"
                                   FontSize="28"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text=" IOPS"
                                   Margin="4,0,0,4"
                                   VerticalAlignment="Bottom"
                                   Foreground="{StaticResource TextDim}"
                                   FontSize="12"/>
                    </StackPanel>
                    <TextBlock x:Name="WriteDelta"
                               Margin="0,8,0,0"
                               Foreground="{StaticResource TextMuted}"
                               FontSize="12"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="0,18,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Style="{StaticResource InsetCard}">
                <TextBlock x:Name="BenchmarkSummaryText"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="12"
                           TextWrapping="Wrap"/>
            </Border>

            <Border Grid.Row="1" Margin="0,14,0,0" Style="{StaticResource InsetCard}">
                <lvc:CartesianChart x:Name="BenchChart"
                                    TooltipPosition="Hidden"
                                    LegendPosition="Hidden"/>
            </Border>
        </Grid>
    </Grid>
</UserControl>
