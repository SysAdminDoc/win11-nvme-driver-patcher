<UserControl x:Class="NVMeDriverPatcher.Views.BenchmarkComparisonView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Benchmark Comparison" Style="{StaticResource SectionEyebrow}"/>
                <TextBlock Text="Compare the current result against the previous run so the patch decision stays grounded in this machine’s actual behavior."
                           Margin="0,8,0,0"
                           Style="{StaticResource BodyCopy}"/>
                <TextBlock x:Name="BenchmarkContextText"
                           Margin="0,10,0,0"
                           Foreground="{StaticResource TextDim}"
                           FontSize="11"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <Border Grid.Column="1"
                    Padding="14,12"
                    Background="{StaticResource BgMedium}"
                    BorderBrush="{StaticResource BorderLight}"
                    BorderThickness="1"
                    CornerRadius="14">
                <StackPanel>
                    <TextBlock Text="Saved Runs" Style="{StaticResource SectionEyebrow}" HorizontalAlignment="Right"/>
                    <TextBlock x:Name="RunCountValue"
                               Margin="0,8,0,0"
                               HorizontalAlignment="Right"
                               Foreground="{StaticResource Accent}"
                               FontSize="24"
                               FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
        </Grid>

        <UniformGrid Grid.Row="1" Columns="2" Margin="0,18,0,0">
            <Border Style="{StaticResource MetricCard}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="4K Random Read" Style="{StaticResource SectionEyebrow}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <TextBlock x:Name="ReadIopsValue"
                                   Text="-"
                                   Foreground="{StaticResource Accent}"
                                   FontSize="30"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text=" IOPS"
                                   Margin="6,0,0,4"
                                   VerticalAlignment="Bottom"
                                   Foreground="{StaticResource TextDim}"
                                   FontSize="12"/>
                    </StackPanel>
                    <TextBlock x:Name="ReadDelta"
                               Margin="0,10,0,0"
                               Foreground="{StaticResource TextMuted}"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource MetricCard}">
                <StackPanel>
                    <TextBlock Text="4K Random Write" Style="{StaticResource SectionEyebrow}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <TextBlock x:Name="WriteIopsValue"
                                   Text="-"
                                   Foreground="{StaticResource Yellow}"
                                   FontSize="30"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text=" IOPS"
                                   Margin="6,0,0,4"
                                   VerticalAlignment="Bottom"
                                   Foreground="{StaticResource TextDim}"
                                   FontSize="12"/>
                    </StackPanel>
                    <TextBlock x:Name="WriteDelta"
                               Margin="0,10,0,0"
                               Foreground="{StaticResource TextMuted}"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="2" Margin="0,18,0,0" Style="{StaticResource InsetCard}">
            <StackPanel>
                <TextBlock Text="Interpretation" Style="{StaticResource SectionEyebrow}"/>
                <TextBlock x:Name="BenchmarkSummaryText"
                           Margin="0,8,0,0"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="12"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Margin="0,18,0,0" Style="{StaticResource InsetCard}">
            <StackPanel>
                <TextBlock Text="Trend View" Style="{StaticResource SectionEyebrow}"/>
                <TextBlock Text="Use the chart to sanity-check whether the latest run moved in the direction you expected instead of reacting to one headline number."
                           Margin="0,8,0,0"
                           Style="{StaticResource BodyCopy}"/>
                <lvc:CartesianChart x:Name="BenchChart"
                                    Height="260"
                                    Margin="0,16,0,0"
                                    TooltipPosition="Hidden"
                                    LegendPosition="Hidden"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
