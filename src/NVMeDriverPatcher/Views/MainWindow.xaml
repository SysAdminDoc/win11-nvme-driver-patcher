<Window x:Class="NVMeDriverPatcher.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:NVMeDriverPatcher.Views"
        Title="NVMe Driver Patcher"
        Height="968"
        Width="1440"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        AllowsTransparency="True"
        Background="#00000000"
        WindowStartupLocation="CenterScreen"
        MinHeight="820"
        MinWidth="1240">

    <Grid Margin="20">
        <Border Background="{StaticResource WindowCanvasBrush}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="1"
                CornerRadius="28"
                ClipToBounds="False">
            <Border.Effect>
                <StaticResource ResourceKey="WindowShadow"/>
            </Border.Effect>

            <Grid ClipToBounds="True">
                <Border Height="4"
                        VerticalAlignment="Top"
                        Background="{StaticResource AccentLineBrush}"
                        CornerRadius="28,28,0,0"
                        Panel.ZIndex="2"/>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Padding="32,24,32,0"
                            Background="Transparent"
                            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal">
                                <Border Width="54"
                                        Height="54"
                                        Margin="0,0,20,0"
                                        Background="{StaticResource AccentBg}"
                                        BorderBrush="{StaticResource BorderLight}"
                                        BorderThickness="1"
                                        CornerRadius="18">
                                    <Grid>
                                        <TextBlock Text="NVMe"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource Accent}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <StackPanel>
                                    <TextBlock Text="NVMe Driver Patcher"
                                               FontSize="30"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimary}"/>
                                    <TextBlock Text="Controlled activation, diagnostics, and rollback support for Windows 11 native NVMe."
                                               FontSize="14"
                                               Foreground="{StaticResource TextMuted}"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Top">
                                <Button Style="{StaticResource BadgeButton}"
                                        Margin="0,0,10,0"
                                        Background="{StaticResource YellowBg}"
                                        Foreground="{StaticResource Yellow}"
                                        Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolVis}}"
                                        Command="{Binding OpenUpdateUrlCommand}"
                                        ToolTip="{Binding UpdateTooltip}">
                                    <TextBlock Text="{Binding UpdateVersionText}" FontSize="11" FontWeight="SemiBold"/>
                                </Button>

                                <Border Margin="0,0,14,0"
                                        Padding="12,7"
                                        Background="{StaticResource BgMedium}"
                                        BorderBrush="{StaticResource Border}"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <TextBlock Text="{Binding VersionText}"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource Accent}"/>
                                </Border>

                                <Button Content="&#x2013;"
                                        Style="{StaticResource WindowChromeButton}"
                                        AutomationProperties.Name="Minimize window"
                                        Click="Minimize_Click"/>
                                <Button Content="&#x2715;"
                                        Margin="6,0,0,0"
                                        Style="{StaticResource CloseWindowChromeButton}"
                                        AutomationProperties.Name="Close window"
                                        Click="Close_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" Margin="32,24,32,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.15*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="0.85*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Style="{StaticResource SurfaceCard}"
                                Background="{StaticResource HeroSurfaceBrush}">
                              <Grid>
                                  <Grid.RowDefinitions>
                                      <RowDefinition Height="Auto"/>
                                      <RowDefinition Height="Auto"/>
                                      <RowDefinition Height="Auto"/>
                                      <RowDefinition Height="Auto"/>
                                      <RowDefinition Height="Auto"/>
                                  </Grid.RowDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Patch Readiness" Style="{StaticResource SectionEyebrow}"/>
                                    <TextBlock Text="{Binding StatusText}"
                                               Margin="0,10,0,0"
                                               FontSize="32"
                                               FontWeight="SemiBold"
                                               Foreground="{Binding StatusColor, Converter={StaticResource StrToBrush}}"/>
                                    <TextBlock Text="{Binding StatusSummaryText}"
                                               Margin="0,10,0,0"
                                               Style="{StaticResource BodyCopy}"/>

                                    <Border Margin="0,14,0,0"
                                            Padding="14,12"
                                            Background="{StaticResource YellowBg}"
                                            BorderBrush="{StaticResource Border}"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Visibility="{Binding ShowViVeToolFallbackBadge, Converter={StaticResource BoolVis}}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Registry override blocked by Windows"
                                                           Foreground="{StaticResource Yellow}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"/>
                                                <TextBlock Text="Your last patch applied the feature flags, but Windows is still using the legacy driver. This is the Feb/Mar 2026 Microsoft block. The ViVeTool fallback writes to a different feature store that still works."
                                                           Margin="0,6,0,0"
                                                           Foreground="{StaticResource TextSecondary}"
                                                           FontSize="12"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                    Content="Try ViVeTool Fallback"
                                                    Margin="14,0,0,0"
                                                    VerticalAlignment="Center"
                                                    Style="{StaticResource SecondaryButton}"
                                                    ToolTip="Downloads ViVeTool from its official GitHub release, caches it in this app's tools folder, then applies feature IDs 60786016 and 48433719. Requires a restart."
                                                    IsEnabled="{Binding ButtonsEnabled}"
                                                    Command="{Binding ApplyViVeToolFallbackCommand}"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>

                                <WrapPanel Grid.Row="2" Margin="0,24,0,0">
                                    <Border Style="{StaticResource MetricCard}" Width="180" Margin="0,0,12,12">
                                        <StackPanel>
                                            <TextBlock Text="Build" Style="{StaticResource SectionEyebrow}"/>
                                            <TextBlock Text="{Binding BuildSummaryText}"
                                                       Margin="0,8,0,0"
                                                       Foreground="{StaticResource TextPrimary}"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource MetricCard}" Width="180" Margin="0,0,12,12">
                                        <StackPanel>
                                            <TextBlock Text="Drive Inventory" Style="{StaticResource SectionEyebrow}"/>
                                            <TextBlock Text="{Binding DriveInventorySummaryText}"
                                                       Margin="0,8,0,0"
                                                       Foreground="{StaticResource TextPrimary}"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource MetricCard}" Width="180" Margin="0,0,12,12">
                                        <StackPanel>
                                            <TextBlock Text="Risk Summary" Style="{StaticResource SectionEyebrow}"/>
                                            <TextBlock Text="{Binding RiskSummaryText}"
                                                       Margin="0,8,0,0"
                                                       Foreground="{StaticResource TextPrimary}"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </WrapPanel>

                                <Border Grid.Row="3"
                                        Margin="0,12,0,0"
                                        Style="{StaticResource InsetCard}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock Text="Driver State" Style="{StaticResource SectionEyebrow}"/>
                                            <TextBlock Text="{Binding DriverLabelText}"
                                                       Margin="0,6,0,0"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       FontSize="13"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1"
                                                    Margin="24,0,0,0"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="Warnings" Style="{StaticResource SectionEyebrow}" HorizontalAlignment="Right"/>
                                            <TextBlock Text="{Binding WarningCount}"
                                                       Foreground="{StaticResource Yellow}"
                                                       FontSize="22"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Right"/>
                                        </StackPanel>

                                        <TextBlock Grid.ColumnSpan="2"
                                                   Margin="0,46,0,0"
                                                   Foreground="{StaticResource TextDim}"
                                                   FontSize="11"
                                                   Text="{Binding BenchLabelText}"
                                                   Visibility="{Binding BenchLabelVisible, Converter={StaticResource BoolVis}}"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource SurfaceCard}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Change Controls" Style="{StaticResource SectionEyebrow}"/>
                                    <TextBlock Text="Apply, validate, and recover without jumping across the app."
                                                Margin="0,8,0,0"
                                                Style="{StaticResource BodyCopy}"/>
                                </StackPanel>

                                <Border Grid.Row="1"
                                        Margin="0,18,0,0"
                                        Style="{StaticResource InsetCard}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Width="34"
                                                Height="34"
                                                Background="{Binding NextStepColor, Converter={StaticResource StrToBrush}}"
                                                CornerRadius="17"
                                                VerticalAlignment="Top"
                                                Opacity="0.16"/>

                                        <Ellipse Width="10"
                                                 Height="10"
                                                 Margin="12,12,0,0"
                                                 HorizontalAlignment="Left"
                                                 VerticalAlignment="Top"
                                                 Fill="{Binding NextStepColor, Converter={StaticResource StrToBrush}}"/>

                                        <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                            <TextBlock Text="Recommended Next Step" Style="{StaticResource SectionEyebrow}"/>
                                            <TextBlock Text="{Binding NextStepTitle}"
                                                       Margin="0,8,0,0"
                                                       Foreground="{Binding NextStepColor, Converter={StaticResource StrToBrush}}"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding NextStepDescription}"
                                                       Margin="0,8,0,0"
                                                       Style="{StaticResource BodyCopy}"/>

                                            <WrapPanel Margin="0,14,0,0">
                                                <Button Content="{Binding NextStepPrimaryActionText}"
                                                        Margin="0,0,10,10"
                                                        Padding="14,8"
                                                        Style="{StaticResource SecondaryButton}"
                                                        AutomationProperties.Name="Recommended primary action"
                                                        Visibility="{Binding HasNextStepPrimaryAction, Converter={StaticResource BoolVis}}"
                                                        IsEnabled="{Binding NextStepPrimaryActionEnabled}"
                                                        Click="RecommendedPrimaryAction_Click"/>
                                                <Button Content="{Binding NextStepSecondaryActionText}"
                                                        Margin="0,0,0,10"
                                                        Padding="14,8"
                                                        Style="{StaticResource OutlinedActionButton}"
                                                        AutomationProperties.Name="Recommended secondary action"
                                                        Visibility="{Binding HasNextStepSecondaryAction, Converter={StaticResource BoolVis}}"
                                                        IsEnabled="{Binding NextStepSecondaryActionEnabled}"
                                                        Click="RecommendedSecondaryAction_Click"/>
                                            </WrapPanel>

                                            <WrapPanel Margin="0,6,0,0">
                                                <Border Margin="0,0,8,8"
                                                        Padding="10,5"
                                                        CornerRadius="999">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{StaticResource BgMedium}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasBackupFiles}" Value="True">
                                                                    <Setter Property="Background" Value="{StaticResource GreenBg}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="Backup Ready"
                                                               FontSize="11"
                                                               FontWeight="SemiBold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{StaticResource TextDim}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasBackupFiles}" Value="True">
                                                                        <Setter Property="Foreground" Value="{StaticResource Green}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>

                                                <Border Margin="0,0,8,8"
                                                        Padding="10,5"
                                                        CornerRadius="999">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{StaticResource BgMedium}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasBenchmarkHistory}" Value="True">
                                                                    <Setter Property="Background" Value="{StaticResource AccentBg}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="Baseline Logged"
                                                               FontSize="11"
                                                               FontWeight="SemiBold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{StaticResource TextDim}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasBenchmarkHistory}" Value="True">
                                                                        <Setter Property="Foreground" Value="{StaticResource Accent}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>

                                                <Border Margin="0,0,8,8"
                                                        Padding="10,5"
                                                        CornerRadius="999">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{StaticResource BgMedium}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasRecoveryKit}" Value="True">
                                                                    <Setter Property="Background" Value="{StaticResource YellowBg}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="Recovery Kit"
                                                               FontSize="11"
                                                               FontWeight="SemiBold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{StaticResource TextDim}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasRecoveryKit}" Value="True">
                                                                        <Setter Property="Foreground" Value="{StaticResource Yellow}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>

                                                <Border Margin="0,0,0,8"
                                                        Padding="10,5"
                                                        CornerRadius="999">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{StaticResource BgMedium}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasDiagnosticsReport}" Value="True">
                                                                    <Setter Property="Background" Value="{StaticResource AccentBg}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="Diagnostics"
                                                               FontSize="11"
                                                               FontWeight="SemiBold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{StaticResource TextDim}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasDiagnosticsReport}" Value="True">
                                                                        <Setter Property="Foreground" Value="{StaticResource Accent}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </WrapPanel>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="2"
                                        Margin="0,18,0,0"
                                        Style="{StaticResource InsetCard}">
                                    <StackPanel>
                                        <TextBlock Text="Planned Machine Impact" Style="{StaticResource SectionEyebrow}"/>
                                        <TextBlock Text="{Binding ChangePlanSummaryText}"
                                                   Margin="0,8,0,0"
                                                   Style="{StaticResource BodyCopy}"/>

                                        <Border Margin="0,14,0,0"
                                                Padding="14,12"
                                                Background="{StaticResource BgMedium}"
                                                BorderBrush="{StaticResource Border}"
                                                BorderThickness="1"
                                                CornerRadius="12">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasChangePlanSteps}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="Waiting for the readiness scan to finish before building a machine-specific plan."
                                                       Foreground="{StaticResource TextSecondary}"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"/>
                                        </Border>

                                        <ItemsControl ItemsSource="{Binding ChangePlanSteps}" Margin="0,14,0,0">
                                            <ItemsControl.Style>
                                                <Style TargetType="ItemsControl">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasChangePlanSteps}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ItemsControl.Style>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,10"
                                                            Padding="14,12"
                                                            Background="{StaticResource BgMedium}"
                                                            BorderBrush="{StaticResource Border}"
                                                            BorderThickness="1"
                                                            CornerRadius="12">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>

                                                            <Border Width="28"
                                                                    Height="28"
                                                                    Background="{Binding ToneColor, Converter={StaticResource StrToBrush}}"
                                                                    CornerRadius="14"
                                                                    Opacity="0.16"
                                                                    VerticalAlignment="Top"/>
                                                            <Ellipse Width="8"
                                                                     Height="8"
                                                                     Margin="10,10,0,0"
                                                                     HorizontalAlignment="Left"
                                                                     VerticalAlignment="Top"
                                                                     Fill="{Binding ToneColor, Converter={StaticResource StrToBrush}}"/>

                                                            <StackPanel Grid.Column="1" Margin="14,0,0,0">
                                                                <TextBlock Text="{Binding Title}"
                                                                           Foreground="{Binding ToneColor, Converter={StaticResource StrToBrush}}"
                                                                           FontSize="13"
                                                                           FontWeight="SemiBold"
                                                                           TextWrapping="Wrap"/>
                                                                <TextBlock Text="{Binding Detail}"
                                                                           Margin="0,8,0,0"
                                                                           Foreground="{StaticResource TextSecondary}"
                                                                           FontSize="12"
                                                                           TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <Grid Grid.Row="3" Margin="0,22,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0"
                                            Content="{Binding ApplyButtonText}"
                                            Background="{StaticResource GreenBg}"
                                            BorderBrush="{StaticResource Green}"
                                            Foreground="{StaticResource TextPrimary}"
                                            Style="{StaticResource ActionButton}"
                                            AutomationProperties.Name="Apply patch"
                                            IsEnabled="{Binding ApplyEnabled}"
                                            ToolTip="{Binding ApplyButtonTooltipText}"
                                            Command="{Binding ApplyPatchCommand}"/>

                                    <Button Grid.Column="2"
                                            Content="Remove Patch"
                                            Style="{StaticResource OutlinedActionButton}"
                                            AutomationProperties.Name="Remove patch"
                                            IsEnabled="{Binding RemoveEnabled}"
                                            ToolTip="{Binding RemoveButtonTooltipText}"
                                            Command="{Binding RemovePatchCommand}"/>
                                </Grid>

                                  <Border Grid.Row="4"
                                          Margin="0,16,0,0"
                                          Padding="14,12"
                                          Background="{StaticResource BgMedium}"
                                          BorderBrush="{StaticResource Border}"
                                          BorderThickness="1"
                                          CornerRadius="12">
                                      <TextBlock Text="{Binding ActionReadinessText}"
                                                 Foreground="{Binding ActionReadinessColor, Converter={StaticResource StrToBrush}}"
                                                 FontSize="12"
                                                 FontWeight="SemiBold"
                                                 TextWrapping="Wrap"/>
                                  </Border>

                                  <UniformGrid Grid.Row="5"
                                               Columns="2"
                                               Margin="0,18,0,0">
                                    <Button Content="Create Backup"
                                            Margin="0,0,10,10"
                                            Style="{StaticResource SecondaryButton}"
                                            AutomationProperties.Name="Create backup"
                                            IsEnabled="{Binding ButtonsEnabled}"
                                            Command="{Binding RunBackupCommand}"/>
                                    <Button Content="Run Benchmark"
                                            Margin="0,0,0,10"
                                            Style="{StaticResource SecondaryButton}"
                                            AutomationProperties.Name="Run benchmark"
                                            IsEnabled="{Binding ButtonsEnabled}"
                                            Command="{Binding RunBenchmarkCommand}"/>
                                    <Button Content="Export Diagnostics"
                                            Margin="0,0,10,0"
                                            Style="{StaticResource SecondaryButton}"
                                            AutomationProperties.Name="Export diagnostics"
                                            IsEnabled="{Binding ButtonsEnabled}"
                                            Command="{Binding ExportDiagnosticsCommand}"/>
                                    <Button Content="Create Recovery Kit"
                                            Style="{StaticResource SecondaryButton}"
                                              AutomationProperties.Name="Create recovery kit"
                                              IsEnabled="{Binding ButtonsEnabled}"
                                              Command="{Binding ExportRecoveryKitCommand}"/>
                                  </UniformGrid>

                                  <Border Grid.Row="6"
                                          Margin="0,18,0,0"
                                          Style="{StaticResource InsetCard}">
                                      <StackPanel>
                                          <TextBlock Text="Operational History" Style="{StaticResource SectionEyebrow}"/>
                                          <TextBlock Text="Backups, snapshots, and benchmarks stay local so you can confirm what changed and when."
                                                     Margin="0,8,0,0"
                                                     Style="{StaticResource BodyCopy}"/>

                                          <Border Margin="0,14,0,0"
                                                  Padding="12,10"
                                                  Background="{StaticResource BgMedium}"
                                                  BorderBrush="{StaticResource Border}"
                                                  BorderThickness="1"
                                                  CornerRadius="12">
                                              <StackPanel>
                                                  <TextBlock Text="Registry Backups" Style="{StaticResource SectionEyebrow}"/>
                                                  <TextBlock Text="{Binding BackupHistoryText}"
                                                             Margin="0,6,0,0"
                                                             Foreground="{StaticResource TextSecondary}"
                                                             FontSize="12"
                                                             TextWrapping="Wrap"/>
                                              </StackPanel>
                                          </Border>

                                          <Border Margin="0,10,0,0"
                                                  Padding="12,10"
                                                  Background="{StaticResource BgMedium}"
                                                  BorderBrush="{StaticResource Border}"
                                                  BorderThickness="1"
                                                  CornerRadius="12">
                                              <StackPanel>
                                                  <TextBlock Text="Change Snapshots" Style="{StaticResource SectionEyebrow}"/>
                                                  <TextBlock Text="{Binding SnapshotHistoryText}"
                                                             Margin="0,6,0,0"
                                                             Foreground="{StaticResource TextSecondary}"
                                                             FontSize="12"
                                                             TextWrapping="Wrap"/>
                                              </StackPanel>
                                          </Border>

                                          <Border Margin="0,10,0,0"
                                                  Padding="12,10"
                                                  Background="{StaticResource BgMedium}"
                                                  BorderBrush="{StaticResource Border}"
                                                  BorderThickness="1"
                                                  CornerRadius="12">
                                              <StackPanel>
                                                  <TextBlock Text="Benchmark Runs" Style="{StaticResource SectionEyebrow}"/>
                                                  <TextBlock Text="{Binding BenchmarkHistoryText}"
                                                             Margin="0,6,0,0"
                                                             Foreground="{StaticResource TextSecondary}"
                                                             FontSize="12"
                                                             TextWrapping="Wrap"/>
                                              </StackPanel>
                                          </Border>
                                      </StackPanel>
                                  </Border>
                              </Grid>
                          </Border>
                    </Grid>

                    <Grid Grid.Row="2" Margin="32,22,32,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.02*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="0.98*"/>
                        </Grid.ColumnDefinitions>

                        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Border Style="{StaticResource SurfaceCard}" Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock Text="Readiness Checklist" Style="{StaticResource SectionEyebrow}"/>
                                        <TextBlock Text="Every prerequisite is grouped here before driver changes unlock."
                                                   Margin="0,8,0,0"
                                                   Style="{StaticResource BodyCopy}"/>

                                        <Grid Margin="0,18,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition Width="14"/>
                                                <ColumnDefinition/>
