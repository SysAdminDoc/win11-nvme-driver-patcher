                                                                <StackPanel Orientation="Horizontal">
                                                                    <Ellipse Width="9"
                                                                             Height="9"
                                                                             Margin="0,0,10,0"
                                                                             VerticalAlignment="Center"
                                                                             Fill="{Binding Color, Converter={StaticResource StrToBrush}}"/>
                                                                    <TextBlock Text="{Binding Label}"
                                                                               Foreground="{StaticResource TextSecondary}"
                                                                               FontWeight="SemiBold"/>
                                                                </StackPanel>
                                                                <TextBlock Text="{Binding Message}"
                                                                           Margin="19,8,0,0"
                                                                           Foreground="{Binding Color, Converter={StaticResource StrToBrush}}"
                                                                           FontSize="12"
                                                                           TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <ItemsControl Grid.Column="2" ItemsSource="{Binding RightChecks}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,0,0,10"
                                                                Padding="14,12"
                                                                Background="{StaticResource BgMedium}"
                                                                BorderBrush="{StaticResource Border}"
                                                                BorderThickness="1"
                                                                CornerRadius="12"
                                                                ToolTip="{Binding Tooltip}">
                                                            <StackPanel>
                                                                <StackPanel Orientation="Horizontal">
                                                                    <Ellipse Width="9"
                                                                             Height="9"
                                                                             Margin="0,0,10,0"
                                                                             VerticalAlignment="Center"
                                                                             Fill="{Binding Color, Converter={StaticResource StrToBrush}}"/>
                                                                    <TextBlock Text="{Binding Label}"
                                                                               Foreground="{StaticResource TextSecondary}"
                                                                               FontWeight="SemiBold"/>
                                                                </StackPanel>
                                                                <TextBlock Text="{Binding Message}"
                                                                           Margin="19,8,0,0"
                                                                           Foreground="{Binding Color, Converter={StaticResource StrToBrush}}"
                                                                           FontSize="12"
                                                                           TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SurfaceCard}" Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock Text="Compatibility Notes" Style="{StaticResource SectionEyebrow}"/>
                                        <TextBlock Text="{Binding AttentionSummaryText}"
                                                   Margin="0,8,0,0"
                                                   Style="{StaticResource BodyCopy}"/>

                                        <Border Margin="0,18,0,0"
                                                Padding="16,14"
                                                Background="{StaticResource GreenBg}"
                                                BorderBrush="{StaticResource Border}"
                                                BorderThickness="1"
                                                CornerRadius="14">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasAttentionNotes}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <TextBlock Text="No extra compatibility caveats"
                                                           Foreground="{StaticResource Green}"
                                                           FontSize="16"
                                                           FontWeight="SemiBold"/>
                                                <TextBlock Text="The scan did not surface any special vendor or platform notes beyond the standard readiness checks."
                                                           Margin="0,8,0,0"
                                                           Foreground="{StaticResource TextSecondary}"
                                                           FontSize="12"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>

                                        <ItemsControl ItemsSource="{Binding AttentionNotes}" Margin="0,18,0,0">
                                            <ItemsControl.Style>
                                                <Style TargetType="ItemsControl">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasAttentionNotes}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ItemsControl.Style>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,10"
                                                            Padding="16,14"
                                                            Background="{StaticResource BgMedium}"
                                                            BorderBrush="{StaticResource Border}"
                                                            BorderThickness="1"
                                                            CornerRadius="14">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>

                                                            <Border Width="30"
                                                                    Height="30"
                                                                    Background="{Binding ToneColor, Converter={StaticResource StrToBrush}}"
