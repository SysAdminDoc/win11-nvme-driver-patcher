<Window x:Class="NVMeDriverPatcher.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:NVMeDriverPatcher.Views"
        Title="NVMe Driver Patcher"
        Height="980"
        Width="1360"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        AllowsTransparency="False"
        Background="{DynamicResource WindowCanvasBrush}"
        WindowStartupLocation="CenterScreen"
        MinHeight="720"
        MinWidth="1024"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Grid x:Name="RootFrame" Margin="0">
        <Border x:Name="ShellBorder"
                Background="{DynamicResource WindowCanvasBrush}"
                BorderBrush="{DynamicResource Border}"
                BorderThickness="0"
                CornerRadius="0"
                ClipToBounds="False">

            <Grid ClipToBounds="True">
                <Border x:Name="ShellAccentBar"
                        Height="1"
                        VerticalAlignment="Top"
                        Background="{DynamicResource AccentLineBrush}"
                        CornerRadius="0"
                        Panel.ZIndex="2"/>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border x:Name="TitleBarRegion"
                            Grid.Row="0"
                            Padding="20,8,20,0"
                            Background="Transparent"
                            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal"
                                        Margin="0,2,0,0"
                                        VerticalAlignment="Top">
                                <TextBlock Text="NVMe Driver Patcher"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimary}"/>
                                <Border Width="1"
                                        Height="18"
                                        Margin="14,2,14,0"
                                        Background="{DynamicResource Border}"/>
                                <TextBlock Text="Windows 11 native driver control"
                                           Margin="0,2,0,0"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextDim}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Top">
                                <Border Margin="0,0,10,0"
                                        Padding="9,5"
                                        VerticalAlignment="Top"
                                        Visibility="Collapsed"
                                        Style="{StaticResource StatusChipBorder}"
                                        AutomationProperties.Name="Current patch state">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="3"
                                                Height="14"
                                                Margin="0,0,7,0"
                                                VerticalAlignment="Center"
                                                Background="{Binding StatusColor, Converter={StaticResource StrToBrush}}"
                                                CornerRadius="1"/>
                                        <TextBlock Text="{Binding StatusText}"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxWidth="180"/>
                                    </StackPanel>
                                </Border>

                                <Button Style="{StaticResource BadgeButton}"
                                        Margin="0,0,10,0"
                                        Background="{DynamicResource YellowBg}"
                                        Foreground="{DynamicResource Yellow}"
                                        AutomationProperties.Name="Open available update"
                                        Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolVis}}"
                                        Command="{Binding OpenUpdateUrlCommand}"
                                        ToolTip="{Binding UpdateTooltip}">
                                    <TextBlock Text="{Binding UpdateVersionText}" FontSize="11" FontWeight="SemiBold"/>
                                </Button>

                                <Button x:Name="ThemeToggleButton"
                                        Content="&#x2600;"
                                        Margin="0,0,8,0"
                                        Style="{StaticResource WindowChromeButton}"
                                        FontFamily="Segoe UI Symbol"
                                        FontSize="14"
                                        AutomationProperties.Name="Toggle theme"
                                        Click="ThemeToggle_Click"/>

                                <Border Margin="0,0,10,0"
                                        Padding="9,5"
                                        Background="{DynamicResource SurfaceInset}"
                                        BorderBrush="{DynamicResource Border}"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                    <TextBlock Text="{Binding VersionText}"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextMuted}"/>
                                </Border>

                                <Button Content="&#x2013;"
                                        Style="{StaticResource WindowChromeButton}"
                                        AutomationProperties.Name="Minimize window"
                                        Visibility="Collapsed"
                                        Click="Minimize_Click"/>
                                <Button x:Name="MaximizeRestoreButton"
                                        Content="&#x25A1;"
                                        Margin="6,0,0,0"
                                        Style="{StaticResource WindowChromeButton}"
                                        AutomationProperties.Name="Maximize window"
                                        Visibility="Collapsed"
                                        Click="MaximizeRestore_Click"/>
                                <Button Content="&#x2715;"
                                        Margin="6,0,0,0"
                                        Style="{StaticResource CloseWindowChromeButton}"
                                        AutomationProperties.Name="Close window"
                                        Visibility="Collapsed"
                                        Click="Close_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid x:Name="OverviewGrid" Grid.Row="1" Margin="20,12,20,0" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.15*"/>
                            <ColumnDefinition x:Name="OverviewSpacerColumn" Width="16"/>
                            <ColumnDefinition Width="0.85*"/>
                        </Grid.ColumnDefinitions>

                        <Border x:Name="ReadinessCard"
                                Grid.Row="0"
                                Grid.Column="0"
                                VerticalAlignment="Top"
                                Style="{StaticResource SurfaceCard}">
                              <Grid>
                                  <Grid.RowDefinitions>
                                      <RowDefinition Height="Auto"/>
                                      <RowDefinition Height="Auto"/>
                                      <RowDefinition Height="Auto"/>
                                      <RowDefinition Height="Auto"/>
                                      <RowDefinition Height="Auto"/>
                                  </Grid.RowDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Readiness" Style="{StaticResource SectionEyebrow}"/>
                                    <TextBlock Text="{Binding StatusText}"
                                               Margin="0,6,0,0"
                                               FontSize="24"
                                               FontWeight="SemiBold"
                                               Foreground="{Binding StatusColor, Converter={StaticResource StrToBrush}}"/>
                                    <TextBlock Text="{Binding StatusSummaryText}"
                                               Margin="0,6,0,0"
                                               Style="{StaticResource BodyCopy}"/>

                                    <Border Margin="0,14,0,0"
                                            Padding="14,12"
                                            Background="{DynamicResource YellowBg}"
                                            BorderBrush="{DynamicResource Border}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Visibility="{Binding ShowViVeToolFallbackBadge, Converter={StaticResource BoolVis}}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Registry override blocked by Windows"
                                                           Foreground="{DynamicResource Yellow}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"/>
                                                <TextBlock Text="Your last patch applied the feature flags, but Windows is still using the legacy driver. This is the Feb/Mar 2026 Microsoft block. The ViVeTool fallback writes to a different feature store that still works."
                                                           Margin="0,6,0,0"
                                                           Foreground="{DynamicResource TextSecondary}"
                                                           FontSize="12"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                    Content="Try ViVeTool Fallback"
                                                    Margin="14,0,0,0"
                                                    VerticalAlignment="Center"
                                                    Style="{StaticResource SecondaryButton}"
                                                    ToolTip="Downloads ViVeTool from its official GitHub release, caches it in this app's tools folder, then applies feature IDs 60786016 and 48433719. Requires a restart."
                                                    IsEnabled="{Binding ButtonsEnabled}"
                                                    Command="{Binding ApplyViVeToolFallbackCommand}"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>

                                <Border Grid.Row="2"
                                        Margin="0,12,0,0"
                                        Style="{StaticResource InsetCard}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="Build"
                                                   Style="{StaticResource SectionEyebrow}"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding BuildSummaryText}"
                                                   Foreground="{DynamicResource TextPrimary}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"/>

                                        <Border Grid.Row="1"
                                                Grid.ColumnSpan="2"
                                                Margin="0,8"
                                                Height="1"
                                                Background="{DynamicResource Border}"/>
                                        <TextBlock Grid.Row="1"
                                                   Text="Drives"
                                                   Style="{StaticResource SectionEyebrow}"/>
                                        <TextBlock Grid.Row="1"
                                                   Grid.Column="1"
                                                   Text="{Binding DriveInventorySummaryText}"
                                                   Foreground="{DynamicResource TextPrimary}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"/>

                                        <Border Grid.Row="2"
                                                Grid.ColumnSpan="2"
                                                Margin="0,-1,0,8"
                                                Height="1"
                                                Background="{DynamicResource Border}"/>
                                        <TextBlock Grid.Row="2"
                                                   Text="Risk"
                                                   Margin="0,8,0,0"
                                                   Style="{StaticResource SectionEyebrow}"/>
                                        <TextBlock Grid.Row="2"
                                                   Grid.Column="1"
                                                   Margin="0,8,0,0"
                                                   Text="{Binding RiskSummaryText}"
                                                   Foreground="{DynamicResource TextPrimary}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"/>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="3"
                                        Margin="0,10,0,0"
                                        Style="{StaticResource InsetCard}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock Text="Driver State" Style="{StaticResource SectionEyebrow}"/>
                                            <TextBlock Text="{Binding DriverLabelText}"
                                                       Margin="0,5,0,0"
                                                       Foreground="{DynamicResource TextSecondary}"
                                                       FontSize="13"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1"
                                                    Margin="24,0,0,0"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="Warnings" Style="{StaticResource SectionEyebrow}" HorizontalAlignment="Right"/>
                                            <TextBlock Text="{Binding WarningCount}"
                                                       Foreground="{DynamicResource Yellow}"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Right"/>
                                        </StackPanel>

                                        <TextBlock Grid.ColumnSpan="2"
                                                   Margin="0,46,0,0"
                                                   Foreground="{DynamicResource TextDim}"
                                                   FontSize="11"
                                                   Text="{Binding BenchLabelText}"
                                                   Visibility="{Binding BenchLabelVisible, Converter={StaticResource BoolVis}}"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <Border x:Name="ControlsCard"
                                Grid.Row="0"
                                Grid.Column="2"
                                MaxHeight="330"
                                VerticalAlignment="Top"
                                Style="{StaticResource SurfaceCard}">
                            <Grid Margin="0,0,6,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Visibility="Collapsed">
                                    <TextBlock Text="Actions" Style="{StaticResource SectionEyebrow}"/>
                                    <TextBlock Text="Act only after readiness, rollback, and validation signals are clear."
                                                Margin="0,8,0,0"
                                                Style="{StaticResource BodyCopy}"/>
                                </StackPanel>

                                <Border Grid.Row="1"
                                        Margin="0,12,0,0"
                                        Style="{StaticResource InsetCard}">
                                    <StackPanel>
                                            <TextBlock Text="Next step" Style="{StaticResource SectionEyebrow}"/>
                                            <TextBlock Text="{Binding NextStepTitle}"
                                                       Margin="0,6,0,0"
                                                       Foreground="{Binding NextStepColor, Converter={StaticResource StrToBrush}}"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding NextStepDescription}"
                                                       Margin="0,6,0,0"
                                                       Style="{StaticResource BodyCopy}"/>

                                            <WrapPanel Margin="0,10,0,0">
                                                <Button Content="{Binding NextStepPrimaryActionText}"
                                                        Margin="0,0,10,10"
                                                        Padding="14,8"
                                                        Style="{StaticResource ActionButton}"
                                                        AutomationProperties.Name="Recommended primary action"
                                                        Visibility="{Binding HasNextStepPrimaryAction, Converter={StaticResource BoolVis}}"
                                                        IsEnabled="{Binding NextStepPrimaryActionEnabled}"
                                                        Click="RecommendedPrimaryAction_Click"/>
                                                <Button Content="{Binding NextStepSecondaryActionText}"
                                                        Margin="0,0,0,10"
                                                        Padding="14,8"
                                                        Style="{StaticResource SecondaryButton}"
                                                        AutomationProperties.Name="Recommended secondary action"
                                                        Visibility="{Binding HasNextStepSecondaryAction, Converter={StaticResource BoolVis}}"
                                                        IsEnabled="{Binding NextStepSecondaryActionEnabled}"
                                                        Click="RecommendedSecondaryAction_Click"/>
                                            </WrapPanel>
                                            <TextBlock Text="Backup, benchmark, recovery, and diagnostics tools stay available below for a stronger paper trail."
                                                       Margin="0,0,0,0"
                                                       Foreground="{DynamicResource TextDim}"
                                                       FontSize="11.5"
                                                       TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="2"
                                        Visibility="Collapsed"
                                        Margin="0,18,0,0"
                                        Style="{StaticResource InsetCard}">
                                    <StackPanel>
                                        <TextBlock Text="Migration plan" Style="{StaticResource SectionEyebrow}"/>
                                        <TextBlock Text="{Binding ChangePlanSummaryText}"
                                                   Margin="0,8,0,0"
                                                   Style="{StaticResource BodyCopy}"/>
                                        <Expander Margin="0,14,0,0"
                                                  IsExpanded="False"
                                                  Style="{StaticResource DarkExpander}">
                                            <Expander.Header>
                                                <TextBlock Text="Plan details"
                                                           FontWeight="SemiBold"/>
                                            </Expander.Header>
                                            <StackPanel>
                                                <Border Padding="12,10"
                                                        Background="{DynamicResource BgMedium}"
                                                        BorderBrush="{DynamicResource Border}"
                                                        BorderThickness="1"
                                                        CornerRadius="6">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasChangePlanSteps}" Value="False">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="Waiting for the readiness scan to finish before building a machine-specific plan."
                                                               Foreground="{DynamicResource TextSecondary}"
                                                               FontSize="12"
                                                               TextWrapping="Wrap"/>
                                                </Border>

                                                <ItemsControl ItemsSource="{Binding ChangePlanSteps}" Margin="0,10,0,0">
                                                    <ItemsControl.Style>
                                                        <Style TargetType="ItemsControl">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasChangePlanSteps}" Value="False">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ItemsControl.Style>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Margin="0,0,0,10"
                                                                    Padding="12,10"
                                                                    Background="{DynamicResource BgMedium}"
                                                                    BorderBrush="{DynamicResource Border}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="6">
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding Title}"
                                                                               Foreground="{Binding ToneColor, Converter={StaticResource StrToBrush}}"
                                                                               FontSize="12.5"
                                                                               FontWeight="SemiBold"
                                                                               TextWrapping="Wrap"/>
                                                                    <TextBlock Text="{Binding Detail}"
                                                                               Margin="0,6,0,0"
                                                                               Foreground="{DynamicResource TextSecondary}"
                                                                               FontSize="12"
                                                                               TextWrapping="Wrap"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Expander>
                                    </StackPanel>
                                </Border>

                                <WrapPanel Grid.Row="3"
                                           Margin="0,12,0,0"
                                           ItemHeight="40">
                                    <Button Content="{Binding ApplyButtonText}"
                                            MinWidth="220"
                                            MaxWidth="320"
                                            Margin="0,0,12,12"
                                            Background="{DynamicResource GreenBg}"
                                            BorderBrush="{DynamicResource Green}"
                                            Foreground="{DynamicResource TextPrimary}"
                                            Style="{StaticResource ActionButton}"
                                            AutomationProperties.Name="Apply patch"
                                            IsEnabled="{Binding ApplyEnabled}"
                                            ToolTip="{Binding ApplyButtonTooltipText}"
                                            Command="{Binding ApplyPatchCommand}"/>

                                    <Button Content="Remove Patch"
                                            MinWidth="220"
                                            MaxWidth="320"
                                            Margin="0,0,0,12"
                                            Style="{StaticResource DangerButton}"
                                            AutomationProperties.Name="Remove patch"
                                            IsEnabled="{Binding RemoveEnabled}"
                                            ToolTip="{Binding RemoveButtonTooltipText}"
                                            Command="{Binding RemovePatchCommand}"/>
                                </WrapPanel>

                                  <Border Grid.Row="4"
                                          Visibility="Collapsed"
                                          Margin="0,16,0,0"
                                          Padding="16,14"
                                          Background="{DynamicResource SurfaceInset}"
                                          BorderBrush="{DynamicResource BorderLight}"
                                          BorderThickness="1"
                                          CornerRadius="6"
                                          AutomationProperties.LiveSetting="Polite">
                                      <TextBlock Text="{Binding ActionReadinessText}"
                                                 Foreground="{Binding ActionReadinessColor, Converter={StaticResource StrToBrush}}"
                                                 FontSize="12"
                                                 FontWeight="SemiBold"
                                                 TextWrapping="Wrap"/>
                                  </Border>

                                  <Border Grid.Row="5"
                                          Visibility="Collapsed"
                                          Margin="0,18,0,0"
                                          Style="{StaticResource InsetCard}">
                                      <StackPanel>
                                          <TextBlock Text="Prepare" Style="{StaticResource SectionEyebrow}"/>
                                          <TextBlock Text="Create rollback assets and machine-specific evidence before touching the live driver path."
                                                     Margin="0,8,0,0"
                                                     Style="{StaticResource BodyCopy}"/>

                                          <WrapPanel Margin="0,16,0,0"
                                                     ItemHeight="40">
                                              <Button Content="Create Backup"
                                                      MinWidth="168"
                                                      MaxWidth="220"
                                                      Margin="0,0,12,12"
                                                      Style="{StaticResource SecondaryButton}"
                                                      ToolTip="Export a manual registry backup so the current state can be restored quickly if needed."
                                                      AutomationProperties.Name="Create backup"
                                                      IsEnabled="{Binding ButtonsEnabled}"
                                                      Command="{Binding RunBackupCommand}"/>
                                              <Button Content="Run Benchmark"
                                                      MinWidth="168"
                                                      MaxWidth="220"
                                                      Margin="0,0,12,12"
                                                      Style="{StaticResource SecondaryButton}"
                                                      ToolTip="Capture a machine-specific performance run for before-and-after comparison."
                                                      AutomationProperties.Name="Run benchmark"
                                                      IsEnabled="{Binding ButtonsEnabled}"
                                                      Command="{Binding RunBenchmarkCommand}"/>
                                              <Button Content="Cancel Benchmark"
                                                      MinWidth="168"
                                                      MaxWidth="220"
                                                      Margin="0,0,12,12"
                                                      Style="{StaticResource WarningSecondaryButton}"
                                                      ToolTip="Stop the current DiskSpd run. Partial data is discarded."
                                                      AutomationProperties.Name="Cancel running benchmark"
                                                      Visibility="{Binding BenchmarkRunning, Converter={StaticResource BoolVis}}"
                                                      Command="{Binding CancelBenchmarkCommand}"/>
                                              <Button Content="Export Diagnostics"
                                                      MinWidth="168"
                                                      MaxWidth="220"
                                                      Margin="0,0,12,12"
                                                      Style="{StaticResource SecondaryButton}"
                                                      ToolTip="Save a support-ready snapshot with readiness, health, and recent activity details."
                                                      AutomationProperties.Name="Export diagnostics"
                                                      IsEnabled="{Binding ButtonsEnabled}"
                                                      Command="{Binding ExportDiagnosticsCommand}"/>
                                              <Button Content="Create Recovery Kit"
                                                      MinWidth="168"
                                                      MaxWidth="220"
                                                      Margin="0,0,0,12"
                                                      Style="{StaticResource SecondaryButton}"
                                                      ToolTip="Generate offline rollback files for Windows and WinRE before a risky restart or handoff."
                                                      AutomationProperties.Name="Create recovery kit"
                                                      IsEnabled="{Binding ButtonsEnabled}"
                                                      Command="{Binding ExportRecoveryKitCommand}"/>
                                          </WrapPanel>
                                      </StackPanel>
                                  </Border>

                                  <Border Grid.Row="6"
                                          Visibility="Collapsed"
                                          Margin="0,18,0,0"
                                          Style="{StaticResource InsetCard}">
                                      <StackPanel>
                                          <TextBlock Text="Recent local data" Style="{StaticResource SectionEyebrow}"/>
                                          <TextBlock Text="Backups, snapshots, and benchmarks stay close so every change has context."
                                                     Margin="0,8,0,0"
                                                     Style="{StaticResource BodyCopy}"/>
                                          <Expander Margin="0,14,0,0"
                                                    IsExpanded="False"
                                                    Style="{StaticResource DarkExpander}">
                                              <Expander.Header>
                                                  <TextBlock Text="History details"
                                                             FontWeight="SemiBold"/>
                                              </Expander.Header>
                                              <StackPanel>
                                                  <Border Padding="12,10"
                                                          Background="{DynamicResource BgMedium}"
                                                          BorderBrush="{DynamicResource Border}"
                                                          BorderThickness="1"
                                                          CornerRadius="6">
                                                      <StackPanel>
                                                          <TextBlock Text="Registry Backups" Style="{StaticResource SectionEyebrow}"/>
                                                          <TextBlock Text="{Binding BackupHistoryText}"
                                                                     Margin="0,6,0,0"
                                                                     Foreground="{DynamicResource TextSecondary}"
                                                                     FontSize="12"
                                                                     TextWrapping="Wrap"/>
                                                      </StackPanel>
                                                  </Border>

                                                  <Border Margin="0,10,0,0"
                                                          Padding="12,10"
                                                          Background="{DynamicResource BgMedium}"
                                                          BorderBrush="{DynamicResource Border}"
                                                          BorderThickness="1"
                                                          CornerRadius="6">
                                                      <StackPanel>
                                                          <TextBlock Text="Change Snapshots" Style="{StaticResource SectionEyebrow}"/>
                                                          <TextBlock Text="{Binding SnapshotHistoryText}"
                                                                     Margin="0,6,0,0"
                                                                     Foreground="{DynamicResource TextSecondary}"
                                                                     FontSize="12"
                                                                     TextWrapping="Wrap"/>
                                                      </StackPanel>
                                                  </Border>

                                                  <Border Margin="0,10,0,0"
                                                          Padding="12,10"
                                                          Background="{DynamicResource BgMedium}"
                                                          BorderBrush="{DynamicResource Border}"
                                                          BorderThickness="1"
                                                          CornerRadius="6">
                                                      <StackPanel>
                                                          <TextBlock Text="Benchmark Runs" Style="{StaticResource SectionEyebrow}"/>
                                                          <TextBlock Text="{Binding BenchmarkHistoryText}"
                                                                     Margin="0,6,0,0"
                                                                     Foreground="{DynamicResource TextSecondary}"
                                                                     FontSize="12"
                                                                     TextWrapping="Wrap"/>
                                                      </StackPanel>
                                                  </Border>
                                              </StackPanel>
                                          </Expander>
                                      </StackPanel>
                                  </Border>
                              </Grid>
                        </Border>
                    </Grid>

                    <Border x:Name="CommandDeck"
                            Grid.Row="1"
                            Margin="18,6,18,0"
                            Padding="12,8"
                            Background="{DynamicResource SurfaceCardBrush}"
                            BorderBrush="{DynamicResource Border}"
                            BorderThickness="1"
                            CornerRadius="7">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="0.95*"/>
                                <ColumnDefinition Width="22"/>
                                <ColumnDefinition Width="1.35*"/>
                                <ColumnDefinition Width="22"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Status" Style="{StaticResource SectionEyebrow}"/>
                                <TextBlock Text="{Binding StatusText}"
                                           Margin="0,4,0,0"
                                           Foreground="{Binding StatusColor, Converter={StaticResource StrToBrush}}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding StatusSummaryText}"
                                           Margin="0,3,0,0"
                                           Foreground="{DynamicResource TextMuted}"
                                           FontSize="12"
                                           LineHeight="16"
                                           MaxHeight="30"
                                           TextTrimming="CharacterEllipsis"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Width="1"
                                    HorizontalAlignment="Center"
                                    Background="{DynamicResource Border}"/>

                            <StackPanel Grid.Column="2"
                                        VerticalAlignment="Center">
                                <TextBlock Text="Next step" Style="{StaticResource SectionEyebrow}"/>
                                <TextBlock Text="{Binding NextStepTitle}"
                                           Margin="0,4,0,0"
                                           Foreground="{Binding NextStepColor, Converter={StaticResource StrToBrush}}"
                                           FontSize="13.5"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding NextStepDescription}"
                                           Margin="0,3,0,0"
                                           Foreground="{DynamicResource TextMuted}"
                                           FontSize="12"
                                           LineHeight="16"
                                           MaxHeight="30"
                                           TextTrimming="CharacterEllipsis"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <Border Grid.Column="3"
                                    Width="1"
                                    HorizontalAlignment="Center"
                                    Background="{DynamicResource Border}"/>

                            <Grid Grid.Column="4">
                                <StackPanel MinWidth="326"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Actions" Style="{StaticResource SectionEyebrow}"/>
                                    <StackPanel Margin="0,6,0,0"
                                                Orientation="Horizontal">
                                        <Button Content="{Binding ApplyButtonText}"
                                                MinWidth="126"
                                                Margin="0,0,8,0"
                                                Style="{StaticResource ActionButton}"
                                                AutomationProperties.Name="Apply patch"
                                                IsEnabled="{Binding ApplyEnabled}"
                                                ToolTip="{Binding ApplyButtonTooltipText}"
                                                Command="{Binding ApplyPatchCommand}"/>

                                        <Button Content="Remove"
                                                MinWidth="84"
                                                Margin="0,0,8,0"
                                                Style="{StaticResource DangerButton}"
                                                AutomationProperties.Name="Remove patch"
                                                IsEnabled="{Binding RemoveEnabled}"
                                                ToolTip="{Binding RemoveButtonTooltipText}"
                                                Command="{Binding RemovePatchCommand}"/>

                                        <Button Content="Refresh"
                                                MinWidth="84"
                                                Style="{StaticResource SecondaryButton}"
                                                AutomationProperties.Name="Refresh readiness checks"
                                                ToolTip="Run readiness checks again and rescan hardware inventory (F5)."
                                                Command="{Binding RefreshCommand}"
                                                IsEnabled="{Binding ButtonsEnabled}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <Grid x:Name="MainContentGrid" Grid.Row="2" Margin="18,10,18,0">
                        <Grid.RowDefinitions>
                            <RowDefinition x:Name="MainContentPrimaryRow" Height="*"/>
                            <RowDefinition x:Name="MainContentSecondaryRow" Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.02*"/>
                            <ColumnDefinition x:Name="MainContentSpacerColumn" Width="14"/>
                            <ColumnDefinition Width="0.98*"/>
                        </Grid.ColumnDefinitions>

                        <TabControl x:Name="OverviewTabs"
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Visibility="Collapsed"
                                    Style="{StaticResource WorkspaceTabControl}"
                                    KeyboardNavigation.TabNavigation="Cycle"
                                    AutomationProperties.Name="Details tabs">
                            <TabControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="1" Columns="4"/>
                                </ItemsPanelTemplate>
                            </TabControl.ItemsPanel>
                            <TabItem Header="Readiness" Style="{StaticResource WorkspaceTabItem}">
                                <Border Style="{StaticResource SurfaceCard}" Margin="0">
                                    <StackPanel>
                                        <TextBlock Text="Checklist" Style="{StaticResource SectionEyebrow}"/>
                                        <TextBlock Text="Blockers before changing the driver."
                                                   Margin="0,4,0,0"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   FontSize="12.5"
                                                   TextWrapping="Wrap"/>

                                        <ItemsControl ItemsSource="{Binding ReadinessChecks}" Margin="0,12,0,0">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Columns="5"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,6,6"
                                                            Padding="8,7"
                                                            Background="{DynamicResource BgMedium}"
                                                            BorderBrush="{DynamicResource Border}"
                                                            BorderThickness="1"
                                                            CornerRadius="6"
                                                            ToolTip="{Binding DetailTooltip}">
                                                        <StackPanel>
                                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                <Border Width="3"
                                                                        Height="14"
                                                                        Margin="0,0,8,0"
                                                                        VerticalAlignment="Center"
                                                                        Background="{Binding Color, Converter={StaticResource StrToBrush}}"
                                                                        CornerRadius="1"/>
                                                                <TextBlock Text="{Binding Label}"
                                                                           Foreground="{DynamicResource TextSecondary}"
                                                                           FontSize="12"
                                                                           FontWeight="SemiBold"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                            </StackPanel>

                                                            <TextBlock Text="{Binding StatusLabel}"
                                                                       Margin="16,4,0,0"
                                                                       Foreground="{Binding Color, Converter={StaticResource StrToBrush}}"
                                                                       FontSize="11"
                                                                       FontWeight="SemiBold"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </TabItem>

                            <TabItem Header="Notes" Style="{StaticResource WorkspaceTabItem}">
                                <Border Style="{StaticResource SurfaceCard}" Margin="0">
                                    <StackPanel>
                                        <TextBlock Text="Compatibility Notes" Style="{StaticResource SectionEyebrow}"/>
                                        <TextBlock Text="{Binding AttentionSummaryText}"
                                                   Margin="0,8,0,0"
                                                   Style="{StaticResource BodyCopy}"/>

                                        <Border Margin="0,10,0,0"
                                                Padding="12,10"
                                                Background="{DynamicResource SurfaceInset}"
                                                BorderBrush="{DynamicResource Border}"
                                                BorderThickness="1"
                                                CornerRadius="6">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasAttentionNotes}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <TextBlock Text="No extra compatibility notes"
                                                           Foreground="{DynamicResource TextPrimary}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"/>
                                                <TextBlock Text="The latest scan did not surface any vendor or platform notes beyond the standard readiness checks."
                                                           Margin="0,5,0,0"
                                                           Foreground="{DynamicResource TextSecondary}"
                                                           FontSize="12"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>

                                        <ItemsControl ItemsSource="{Binding AttentionNotes}" Margin="0,10,0,0">
                                            <ItemsControl.Style>
                                                <Style TargetType="ItemsControl">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasAttentionNotes}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ItemsControl.Style>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,8"
                                                            Padding="12,10"
                                                            Background="{DynamicResource BgMedium}"
                                                            BorderBrush="{DynamicResource Border}"
                                                            BorderThickness="1"
                                                            CornerRadius="6">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>

                                                            <Border Width="4"
                                                                    Height="30"
                                                                    Background="{Binding ToneColor, Converter={StaticResource StrToBrush}}"
                                                                    CornerRadius="1"
                                                                    Opacity="0.72"
                                                                    VerticalAlignment="Top"/>

                                                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                                                <TextBlock Text="{Binding Title}"
                                                                           Foreground="{Binding ToneColor, Converter={StaticResource StrToBrush}}"
                                                                           FontSize="13"
                                                                           FontWeight="SemiBold"
                                                                           TextWrapping="Wrap"/>
                                                                <TextBlock Text="{Binding Detail}"
                                                                           Margin="0,5,0,0"
                                                                           Foreground="{DynamicResource TextSecondary}"
                                                                           FontSize="12"
                                                                           TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </TabItem>

                            <TabItem Header="Settings" Style="{StaticResource WorkspaceTabItem}">
                                <Border Style="{StaticResource SurfaceCard}" Margin="0">
                                    <Grid x:Name="SettingsColumnsGrid">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition/>
                                            <ColumnDefinition x:Name="SettingsSpacerColumn" Width="16"/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>

                                        <Border x:Name="PatchDefaultsCard" Grid.Row="0" Grid.Column="0" Style="{StaticResource InsetCard}">
                                            <StackPanel>
                                                <TextBlock Text="Patch profile" Style="{StaticResource SectionEyebrow}"/>
                                                <TextBlock Text="{Binding OptionsSummaryText}"
                                                           Margin="0,5,0,0"
                                                           Style="{StaticResource BodyCopy}"/>

                                                <TextBlock Text="Install mode"
                                                           Margin="0,10,0,4"
                                                           Foreground="{DynamicResource TextPrimary}"
                                                           FontSize="12.5"
                                                           FontWeight="SemiBold"/>
                                                <RadioButton Content="Safe profile (recommended): primary flag only"
                                                             Style="{StaticResource DarkRadioButton}"
                                                             GroupName="PatchProfile"
                                                             ToolTip="Writes just 735209102 plus Safe Boot entries. Swaps the driver with the lowest crash risk."
                                                             IsChecked="{Binding IsSafeModeSelected}"/>
                                                <RadioButton Content="Full profile: all three feature flags"
                                                             Style="{StaticResource DarkRadioButton}"
                                                             GroupName="PatchProfile"
                                                             ToolTip="Adds 1853569164 (UxAccOptimization) and 156965516 (Standalone_Future). Higher peak performance on some drives, higher boot-crash risk on others."
                                                             IsChecked="{Binding IsFullModeSelected}"/>
                                                <TextBlock Text="{Binding PatchProfileHelpText}"
                                                           Margin="0,8,0,0"
                                                           Foreground="{DynamicResource TextMuted}"
                                                           FontSize="11.5"
                                                           TextWrapping="Wrap"/>

                                                <CheckBox Content="Include Microsoft Server 2025 compatibility key"
                                                          Style="{StaticResource DarkCheckBox}"
                                                          IsChecked="{Binding IncludeServerKey}"/>
                                                <CheckBox Content="Reduce confirmation warnings (expert mode)"
                                                          Style="{StaticResource DarkCheckBox}"
                                                          IsChecked="{Binding SkipWarnings}"/>

                                                <Border Margin="0,10,0,0"
                                                        Padding="12,10"
                                                        Background="{DynamicResource SurfaceInset}"
                                                        BorderBrush="{DynamicResource Border}"
                                                        BorderThickness="1"
                                                        CornerRadius="6">
                                                    <TextBlock Text="Safe Mode is still the safest default for most systems. Add the Server 2025 key only when you need the broader compatibility path."
                                                               Foreground="{DynamicResource TextSecondary}"
                                                               FontSize="12"
                                                               TextWrapping="Wrap"/>
                                                </Border>

                                                <Border Margin="0,8,0,0"
                                                        Padding="12,10"
                                                        Background="{DynamicResource YellowBg}"
                                                        BorderBrush="{DynamicResource Border}"
                                                        BorderThickness="1"
                                                        CornerRadius="6">
                                                    <TextBlock Text="Heads-up for gamers: nvmedisk.sys does not honor BypassIO, so DirectStorage titles fall back to the slower path. Skip the patch on your gaming rig, or keep a one-click removal ready."
                                                               Foreground="{DynamicResource Yellow}"
                                                               FontSize="12"
                                                               TextWrapping="Wrap"/>
                                                </Border>
                                            </StackPanel>
                                        </Border>

                                        <Border x:Name="AuditAlertsCard" Grid.Row="0" Grid.Column="2" Style="{StaticResource InsetCard}">
                                            <StackPanel>
                                                <TextBlock Text="Audit and alerts" Style="{StaticResource SectionEyebrow}"/>
                                                <TextBlock Text="{Binding PreferenceSummaryText}"
                                                           Margin="0,5,0,0"
                                                           Style="{StaticResource BodyCopy}"/>

                                                <CheckBox Content="Auto-save activity log on exit"
                                                          Style="{StaticResource DarkCheckBox}"
                                                          IsChecked="{Binding AutoSaveLog}"/>
                                                <CheckBox Content="Show toast notifications"
                                                          Style="{StaticResource DarkCheckBox}"
                                                          IsChecked="{Binding EnableToasts}"/>
                                                <CheckBox Content="Write audit entries to Windows Event Log"
                                                          Style="{StaticResource DarkCheckBox}"
                                                          IsChecked="{Binding WriteEventLog}"/>

                                                <WrapPanel x:Name="RestartDelayPanel"
                                                           Margin="0,10,0,0"
                                                           VerticalAlignment="Center">
                                                    <TextBlock Text="Restart delay"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource TextSecondary}"
                                                               FontWeight="SemiBold"/>
                                                    <TextBox Width="72"
                                                             Margin="12,0,10,0"
                                                             Style="{StaticResource DarkTextBox}"
                                                             AutomationProperties.Name="Restart delay in seconds"
                                                             ToolTip="Use a value between 5 and 300 seconds for post-patch restart countdowns."
                                                             Text="{Binding RestartDelayText, UpdateSourceTrigger=LostFocus}"
                                                             VerticalContentAlignment="Center"/>
                                                    <TextBlock Text="seconds"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource TextDim}"/>
                                                </WrapPanel>

                                                <WrapPanel x:Name="PreferenceActionsPanel"
                                                           Margin="0,10,0,0">
                                                    <Button Content="Open Data"
                                                            Margin="0,0,8,8"
                                                            HorizontalAlignment="Left"
                                                            Style="{StaticResource SecondaryButton}"
                                                            AutomationProperties.Name="Open data folder"
                                                            ToolTip="Open the working folder that stores logs, exports, backups, and diagnostics."
                                                            Command="{Binding OpenDataFolderCommand}"/>
                                                    <Button Content="Restore Defaults"
                                                            Margin="0,0,0,8"
                                                            HorizontalAlignment="Left"
                                                            Style="{StaticResource SecondaryButton}"
                                                            AutomationProperties.Name="Restore recommended defaults"
                                                            ToolTip="Restore the app's recommended safety-first settings."
                                                            Command="{Binding UseRecommendedSetupCommand}"/>
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>
                            </TabItem>

                            <TabItem Header="Storage" Style="{StaticResource WorkspaceTabItem}">
                                <StackPanel Visibility="Collapsed">
                                <Border Style="{StaticResource SurfaceCard}" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="Storage" Style="{StaticResource SectionEyebrow}"/>
                                        <TextBlock Text="{Binding DriveInventorySummaryText}"
                                                   Margin="0,8,0,0"
                                                   Style="{StaticResource BodyCopy}"/>

                                        <TextBlock Margin="0,18,0,0"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextDim}"
                                                   Text="No drive data came back from the latest scan. Refresh readiness or confirm the app still has administrator access.">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasDriveData}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <Expander Margin="0,16,0,0"
                                                  IsExpanded="False">
                                            <Expander.Style>
                                                <Style TargetType="Expander" BasedOn="{StaticResource DarkExpander}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasDriveData}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Expander.Style>
                                            <Expander.Header>
                                                <TextBlock Text="Drive details"
                                                           FontWeight="SemiBold"/>
                                            </Expander.Header>
                                            <ItemsControl ItemsSource="{Binding Drives}" Margin="0,8,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,0,0,10"
                                                                Padding="14,12"
                                                                Background="{DynamicResource BgMedium}"
                                                                BorderBrush="{DynamicResource Border}"
                                                                BorderThickness="1"
                                                                CornerRadius="6">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="18"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>

                                                                <StackPanel>
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <Border Width="3"
                                                                                Height="14"
                                                                                Margin="0,0,10,0"
                                                                                VerticalAlignment="Center"
                                                                                Background="{Binding DotColor, Converter={StaticResource StrToBrush}}"
                                                                                CornerRadius="1"/>
                                                                        <TextBlock Text="{Binding Name}"
                                                                                   Foreground="{DynamicResource TextPrimary}"
                                                                                   FontSize="13"
                                                                                   FontWeight="SemiBold"
                                                                                   TextTrimming="CharacterEllipsis"/>
                                                                    </StackPanel>
                                                                    <TextBlock Text="{Binding Size}"
                                                                               Margin="20,6,0,0"
                                                                               Foreground="{DynamicResource TextDim}"
                                                                               FontSize="12"/>
                                                                    <WrapPanel Margin="20,8,0,0">
                                                                        <TextBlock Text="{Binding Temperature, StringFormat=Temp {0}}"
                                                                                   Margin="0,0,12,6"
                                                                                   Foreground="{Binding TempColor, Converter={StaticResource StrToBrush}}"
                                                                                   FontSize="11.5"
                                                                                   Visibility="{Binding ShowTemp, Converter={StaticResource BoolVis}}"/>
                                                                        <TextBlock Text="{Binding Wear, StringFormat=Health {0}}"
                                                                                   Margin="0,0,12,6"
                                                                                   Foreground="{Binding WearColor, Converter={StaticResource StrToBrush}}"
                                                                                   FontSize="11.5"
                                                                                   ToolTip="{Binding SmartTooltip}"
                                                                                   Visibility="{Binding ShowWear, Converter={StaticResource BoolVis}}"/>
                                                                        <TextBlock Text="{Binding Firmware, StringFormat=FW {0}}"
                                                                                   Margin="0,0,0,6"
                                                                                   Foreground="{DynamicResource TextMuted}"
                                                                                   FontSize="11.5"
                                                                                   Visibility="{Binding ShowFirmware, Converter={StaticResource BoolVis}}"/>
                                                                    </WrapPanel>
                                                                </StackPanel>

                                                                <WrapPanel Grid.Column="2"
                                                                           HorizontalAlignment="Right"
                                                                           VerticalAlignment="Top"
                                                                           ItemHeight="28">
                                                                    <Border Margin="0,0,6,6"
                                                                            Padding="8,4"
                                                                            Background="{DynamicResource SurfaceInset}"
                                                                            BorderBrush="{Binding BusPillFg, Converter={StaticResource StrToBrush}}"
                                                                            BorderThickness="1"
                                                                            CornerRadius="3">
                                                                        <TextBlock Text="{Binding BusType}"
                                                                                   Foreground="{Binding BusPillFg, Converter={StaticResource StrToBrush}}"
                                                                                   FontSize="10.5"
                                                                                   FontWeight="SemiBold"/>
                                                                    </Border>

                                                                    <Border Margin="0,0,6,6"
                                                                            Padding="8,4"
                                                                            Background="{DynamicResource YellowBg}"
                                                                            BorderBrush="{DynamicResource Yellow}"
                                                                            BorderThickness="1"
                                                                            CornerRadius="3"
                                                                            Visibility="{Binding IsBoot, Converter={StaticResource BoolVis}}">
                                                                        <TextBlock Text="Boot"
                                                                                   Foreground="{DynamicResource Yellow}"
                                                                                   FontSize="10.5"
                                                                                   FontWeight="SemiBold"/>
                                                                    </Border>

                                                                    <Border Margin="0,0,0,6"
                                                                            Padding="8,4"
                                                                            Background="{DynamicResource SurfaceInset}"
                                                                            BorderBrush="{Binding DriverBadgeFg, Converter={StaticResource StrToBrush}}"
                                                                            BorderThickness="1"
                                                                            CornerRadius="3"
                                                                            Visibility="{Binding ShowDriverBadge, Converter={StaticResource BoolVis}}">
                                                                        <TextBlock Text="{Binding DriverBadgeText}"
                                                                                   Foreground="{Binding DriverBadgeFg, Converter={StaticResource StrToBrush}}"
                                                                                   FontSize="10.5"
                                                                                   FontWeight="SemiBold"/>
                                                                    </Border>
                                                                </WrapPanel>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Expander>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SurfaceCard}">
                                    <StackPanel>
                                        <TextBlock Text="Technical details" Style="{StaticResource SectionEyebrow}"/>
                                        <TextBlock Text="Expand the exact keys only when you want to inspect the change set behind the patch."
                                                   Margin="0,8,0,0"
                                                   Style="{StaticResource BodyCopy}"/>

                                        <Grid Margin="0,16,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>

                                            <Expander Grid.Column="0"
                                                      IsExpanded="False"
                                                      Style="{StaticResource DarkExpander}">
                                                <Expander.Header>
                                                    <TextBlock Text="Patch keys"
                                                               FontWeight="SemiBold"/>
                                                </Expander.Header>
                                                <StackPanel>
                                                    <TextBlock Text="Feature flags that enable the native path and its related optimizations."
                                                               Style="{StaticResource BodyCopy}"/>
                                                    <ItemsControl ItemsSource="{Binding RegistryFlags}" Margin="0,12,0,0">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Margin="0,0,0,10"
                                                                        Padding="14,12"
                                                                        Background="{DynamicResource BgMedium}"
                                                                        BorderBrush="{DynamicResource Border}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="6">
                                                                    <Grid>
                                                                        <Grid.RowDefinitions>
                                                                            <RowDefinition Height="Auto"/>
                                                                            <RowDefinition Height="Auto"/>
                                                                        </Grid.RowDefinitions>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                            <ColumnDefinition Width="120"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                        </Grid.ColumnDefinitions>

                                                                        <Border Width="3"
                                                                                Height="14"
                                                                                Margin="0,0,10,0"
                                                                                VerticalAlignment="Center"
                                                                                Background="{Binding DotColor, Converter={StaticResource StrToBrush}}"
                                                                                CornerRadius="1"/>
                                                                        <TextBlock Grid.Column="1"
                                                                                   Text="{Binding Id}"
                                                                                   Foreground="{DynamicResource TextPrimary}"
                                                                                   FontFamily="Cascadia Code,Consolas"
                                                                                   FontSize="11"
                                                                                   FontWeight="SemiBold"/>
                                                                        <TextBlock Grid.Column="2"
                                                                                   Text="{Binding Name}"
                                                                                   Foreground="{DynamicResource TextMuted}"
                                                                                   FontSize="12"
                                                                                   TextWrapping="Wrap"/>
                                                                        <Border Grid.Row="1"
                                                                                Grid.Column="1"
                                                                                Grid.ColumnSpan="2"
                                                                                Margin="0,8,0,0"
                                                                                HorizontalAlignment="Left"
                                                                                Style="{StaticResource StatusChipBorder}"
                                                                                BorderBrush="{Binding DotColor, Converter={StaticResource StrToBrush}}">
                                                                            <TextBlock Text="{Binding StatusLabel}"
                                                                                       Style="{StaticResource StatusChipText}"
                                                                                       Foreground="{Binding DotColor, Converter={StaticResource StrToBrush}}"/>
                                                                        </Border>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Expander>

                                            <Expander Grid.Column="2"
                                                      IsExpanded="False"
                                                      Style="{StaticResource DarkExpander}">
                                                <Expander.Header>
                                                    <TextBlock Text="Recovery keys"
                                                               FontWeight="SemiBold"/>
                                                </Expander.Header>
                                                <StackPanel>
                                                    <TextBlock Text="Safe Mode safeguards that keep offline rollback usable if you need it."
                                                               Style="{StaticResource BodyCopy}"/>
                                                    <ItemsControl ItemsSource="{Binding SafeBootFlags}" Margin="0,12,0,0">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Margin="0,0,0,10"
                                                                        Padding="14,12"
                                                                        Background="{DynamicResource BgMedium}"
                                                                        BorderBrush="{DynamicResource Border}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="6">
                                                                    <Grid>
                                                                        <Grid.RowDefinitions>
                                                                            <RowDefinition Height="Auto"/>
                                                                            <RowDefinition Height="Auto"/>
                                                                        </Grid.RowDefinitions>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                            <ColumnDefinition Width="120"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                        </Grid.ColumnDefinitions>

                                                                        <Border Width="3"
                                                                                Height="14"
                                                                                Margin="0,0,10,0"
                                                                                VerticalAlignment="Center"
                                                                                Background="{Binding DotColor, Converter={StaticResource StrToBrush}}"
                                                                                CornerRadius="1"/>
                                                                        <TextBlock Grid.Column="1"
                                                                                   Text="{Binding Id}"
                                                                                   Foreground="{DynamicResource TextPrimary}"
                                                                                   FontFamily="Cascadia Code,Consolas"
                                                                                   FontSize="11"
                                                                                   FontWeight="SemiBold"/>
                                                                        <TextBlock Grid.Column="2"
                                                                                   Text="{Binding Name}"
                                                                                   Foreground="{DynamicResource TextMuted}"
                                                                                   FontSize="12"
                                                                                   TextWrapping="Wrap"/>
                                                                        <Border Grid.Row="1"
                                                                                Grid.Column="1"
                                                                                Grid.ColumnSpan="2"
                                                                                Margin="0,8,0,0"
                                                                                HorizontalAlignment="Left"
                                                                                Style="{StaticResource StatusChipBorder}"
                                                                                BorderBrush="{Binding DotColor, Converter={StaticResource StrToBrush}}">
                                                                            <TextBlock Text="{Binding StatusLabel}"
                                                                                       Style="{StaticResource StatusChipText}"
                                                                                       Foreground="{Binding DotColor, Converter={StaticResource StrToBrush}}"/>
                                                                        </Border>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Expander>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                                </StackPanel>
                            </TabItem>
                        </TabControl>

                        <GridSplitter x:Name="MainContentSplitter"
                                      Grid.Row="0"
                                      Grid.Column="1"
                                      Width="6"
                                      Focusable="True"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Stretch"
                                      AutomationProperties.Name="Resize overview and validation panels"
                                      Background="Transparent"
                                      Visibility="Collapsed"
                                      Cursor="SizeWE"
                                      ShowsPreview="True"/>

                        <Border x:Name="WorkspaceSurface"
                                Grid.Row="0"
                                Grid.Column="0"
                                Grid.ColumnSpan="3"
                                Style="{StaticResource SurfaceCard}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition x:Name="ActivityRailSpacerColumn" Width="10"/>
                                    <ColumnDefinition x:Name="ActivityRailColumn" Width="400"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Visibility="Collapsed">
                                    <TextBlock Text="Validation" Style="{StaticResource SectionEyebrow}"/>
                                    <TextBlock Text="Activity shows what happened. Benchmarks and telemetry help validate the result. Recovery keeps rollback nearby."
                                               Margin="0,8,0,0"
                                               Style="{StaticResource BodyCopy}"/>
                                </StackPanel>

                                <TabControl x:Name="WorkspaceTabs"
                                            Grid.Row="0"
                                            Grid.Column="0"
                                            Grid.RowSpan="2"
                                            Margin="0"
                                            SelectedIndex="1"
                                            Style="{StaticResource WorkspaceTabControl}"
                                            KeyboardNavigation.TabNavigation="Cycle"
                                            AutomationProperties.Name="Workspace tabs"
                                            SelectionChanged="WorkspaceTabs_SelectionChanged">
<TabItem Style="{StaticResource WorkspaceTabItem}">
                                        <TabItem.Header>
                                            <StackPanel Orientation="Horizontal"
                                                        DataContext="{Binding DataContext, ElementName=WorkspaceTabs}">
                                                <TextBlock Text="Benchmark"/>
                                                <Border Style="{StaticResource TabBadgeBorder}"
                                                        BorderBrush="{Binding BenchmarkTabBadgeColor, Converter={StaticResource StrToBrush}}">
                                                    <TextBlock Text="{Binding BenchmarkTabBadgeText}"
                                                               Foreground="{Binding BenchmarkTabBadgeColor, Converter={StaticResource StrToBrush}}"
                                                               Style="{StaticResource TabBadgeText}"/>
                                                </Border>
                                            </StackPanel>
                                        </TabItem.Header>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <Border Style="{StaticResource InsetCard}" Visibility="Collapsed">
                                                <TextBlock Text="Validate the patch with a before-and-after run from this machine."
                                                           Style="{StaticResource BodyCopy}"/>
                                            </Border>

                                            <Border x:Name="BenchmarkEmptyState"
                                                    Grid.Row="1"
                                                    Margin="0"
                                                    Style="{StaticResource EmptyStateCard}">
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <Border Width="40"
                                                            Height="40"
                                                            Background="{DynamicResource AccentBg}"
                                                            BorderBrush="{DynamicResource BorderLight}"
                                                            BorderThickness="1"
                                                            CornerRadius="4">
                                                        <Grid Width="24" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <Border Width="4" Height="9" Background="{DynamicResource Accent}" CornerRadius="2" HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
                                                            <Border Width="4" Height="16" Margin="10,0,0,0" Background="{DynamicResource Accent}" CornerRadius="2" HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
                                                            <Border Width="4" Height="12" Background="{DynamicResource Accent}" CornerRadius="2" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                                                        </Grid>
                                                    </Border>
                                                    <TextBlock Margin="0,10,0,0"
                                                               Text="No benchmark history yet"
                                                               Style="{StaticResource EmptyStateTitle}"/>
                                                    <TextBlock Text="Run a benchmark before or after applying the patch to build a machine-specific comparison."
                                                               Margin="0,6,0,0"
                                                               Style="{StaticResource EmptyStateBody}"/>
                                                    <Button Content="Run Benchmark"
                                                            Margin="0,12,0,0"
                                                            HorizontalAlignment="Center"
                                                            Style="{StaticResource ActionButton}"
                                                            AutomationProperties.Name="Run first benchmark"
                                                            Command="{Binding RunBenchmarkCommand}"/>
                                                </StackPanel>
                                            </Border>

                                            <Grid x:Name="BenchmarkWorkspacePanel"
                                                  Grid.Row="1"
                                                  Margin="0"
                                                  Visibility="Collapsed">
                                                <views:BenchmarkComparisonView x:Name="BenchmarkView"/>
                                            </Grid>
                                        </Grid>
                                    </TabItem>

                                    <TabItem Style="{StaticResource WorkspaceTabItem}">
                                        <TabItem.Header>
                                            <StackPanel Orientation="Horizontal"
                                                        DataContext="{Binding DataContext, ElementName=WorkspaceTabs}">
                                                <TextBlock Text="Telemetry"/>
                                                <Border Style="{StaticResource TabBadgeBorder}"
                                                        BorderBrush="{Binding TelemetryTabBadgeColor, Converter={StaticResource StrToBrush}}">
                                                    <TextBlock Text="{Binding TelemetryTabBadgeText}"
                                                               Foreground="{Binding TelemetryTabBadgeColor, Converter={StaticResource StrToBrush}}"
                                                               Style="{StaticResource TabBadgeText}"/>
                                                </Border>
                                            </StackPanel>
                                        </TabItem.Header>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <Border Style="{StaticResource InsetCard}">
                                                <WrapPanel>
                                                    <StackPanel MaxWidth="460"
                                                                Margin="0,0,14,8">
                                                        <TextBlock Text="Capture a fresh SMART snapshot and compare it against recent local history."
                                                                   Style="{StaticResource BodyCopy}"/>
                                                    </StackPanel>

                                                    <Button Margin="0,0,0,12"
                                                            VerticalAlignment="Center"
                                                            Content="Capture Snapshot"
                                                            Style="{StaticResource SecondaryButton}"
                                                            AutomationProperties.Name="Capture telemetry snapshot"
                                                            ToolTip="Poll the currently selected NVMe drive again and refresh the local telemetry view."
                                                            Click="RefreshTelemetry_Click"/>
                                                </WrapPanel>
                                            </Border>

                                            <Border x:Name="TelemetryEmptyState"
                                                    Grid.Row="1"
                                                    Margin="0,10,0,0"
                                                    Style="{StaticResource EmptyStateCard}">
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <Border Width="40"
                                                            Height="40"
                                                            Background="{DynamicResource AccentBg}"
                                                            BorderBrush="{DynamicResource BorderLight}"
                                                            BorderThickness="1"
                                                            CornerRadius="4">
                                                        <Viewbox Width="25" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <Path Data="M 1 12 L 6 12 L 9 5 L 13 18 L 16 10 L 20 10 L 23 12"
                                                                  Stroke="{DynamicResource Accent}"
                                                                  StrokeThickness="2"
                                                                  StrokeStartLineCap="Round"
                                                                  StrokeEndLineCap="Round"
                                                                  StrokeLineJoin="Round"/>
                                                        </Viewbox>
                                                    </Border>
                                                    <TextBlock Margin="0,10,0,0"
                                                               Text="No NVMe telemetry source available"
                                                               Style="{StaticResource EmptyStateTitle}"/>
                                                    <TextBlock Text="This workspace activates when the current scan finds at least one NVMe drive that Windows can surface for health checks."
                                                               Margin="0,6,0,0"
                                                               Style="{StaticResource EmptyStateBody}"/>
                                                    <Button Content="Refresh Readiness"
                                                            Margin="0,12,0,0"
                                                            HorizontalAlignment="Center"
                                                            Style="{StaticResource SecondaryButton}"
                                                            AutomationProperties.Name="Refresh readiness checks"
                                                            ToolTip="Run readiness checks again and rescan hardware inventory (F5)."
                                                            Command="{Binding RefreshCommand}"/>
                                                </StackPanel>
                                            </Border>

                                            <Grid x:Name="TelemetryWorkspacePanel"
                                                  Grid.Row="1"
                                                  Margin="0,10,0,0"
                                                  Visibility="Collapsed">
                                                <views:TelemetryView x:Name="TelemetryPanelControl"/>
                                            </Grid>
                                        </Grid>
                                    </TabItem>

                                    <TabItem Style="{StaticResource WorkspaceTabItem}">
                                        <TabItem.Header>
                                            <StackPanel Orientation="Horizontal"
                                                        DataContext="{Binding DataContext, ElementName=WorkspaceTabs}">
                                                <TextBlock Text="Recovery"/>
                                                <Border Style="{StaticResource TabBadgeBorder}"
                                                        BorderBrush="{Binding RecoveryTabBadgeColor, Converter={StaticResource StrToBrush}}">
                                                    <TextBlock Text="{Binding RecoveryTabBadgeText}"
                                                               Foreground="{Binding RecoveryTabBadgeColor, Converter={StaticResource StrToBrush}}"
                                                               Style="{StaticResource TabBadgeText}"/>
                                                </Border>
                                            </StackPanel>
                                        </TabItem.Header>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <Border Style="{StaticResource InsetCard}">
                                                <WrapPanel>
                                                    <StackPanel MaxWidth="430"
                                                                Margin="0,0,14,8">
                                                        <TextBlock Text="Keep rollback files and support exports close before you restart or hand off the machine."
                                                                   Style="{StaticResource BodyCopy}"/>
                                                        <TextBlock Text="{Binding RecoveryWorkspaceSummaryText}"
                                                                   Margin="0,6,0,0"
                                                                   Foreground="{DynamicResource TextPrimary}"
                                                                   FontSize="13"
                                                                   FontWeight="SemiBold"
                                                                   TextWrapping="Wrap"/>
                                                    </StackPanel>

                                                    <WrapPanel VerticalAlignment="Center">
                                                        <Button Content="Refresh"
                                                                Margin="0,0,8,8"
                                                                Style="{StaticResource SecondaryButton}"
                                                                AutomationProperties.Name="Refresh recovery assets"
                                                                ToolTip="Rescan the working folder for recovery kits, verification scripts, and diagnostics."
                                                                Command="{Binding RefreshRecoveryAssetsCommand}"/>
                                                        <Button Content="Open Data"
                                                                Margin="0,0,0,8"
                                                                Style="{StaticResource SecondaryButton}"
                                                                AutomationProperties.Name="Open data folder"
                                                                ToolTip="Open the working folder that stores recovery exports and diagnostics."
                                                                Command="{Binding OpenDataFolderCommand}"/>
                                                    </WrapPanel>
                                                </WrapPanel>
                                            </Border>

                                            <Border Grid.Row="1"
                                                    Margin="0,10,0,0"
                                                    Style="{StaticResource InsetCard}">
                                                <UniformGrid Columns="3">
                                                    <Grid Margin="0,0,12,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Width="3"
                                                                Height="36"
                                                                Background="{Binding PreparationStageColor, Converter={StaticResource StrToBrush}}"
                                                                CornerRadius="1"
                                                                Opacity="0.76"
                                                                VerticalAlignment="Top"/>
                                                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                            <TextBlock Text="Prepare" Style="{StaticResource SectionEyebrow}"/>
                                                            <TextBlock Text="{Binding PreparationStageStateText}"
                                                                       Margin="0,4,0,0"
                                                                       Foreground="{Binding PreparationStageColor, Converter={StaticResource StrToBrush}}"
                                                                       FontSize="14"
                                                                       FontWeight="SemiBold"
                                                                       TextWrapping="Wrap"/>
                                                            <TextBlock Text="{Binding PreparationStageDetailText}"
                                                                       Margin="0,3,0,0"
                                                                       FontSize="11.5"
                                                                       Foreground="{DynamicResource TextMuted}"
                                                                       TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                    </Grid>

                                                    <Grid Margin="6,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Width="3"
                                                                Height="36"
                                                                Background="{Binding RestartStageColor, Converter={StaticResource StrToBrush}}"
                                                                CornerRadius="1"
                                                                Opacity="0.76"
                                                                VerticalAlignment="Top"/>
                                                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                            <TextBlock Text="Restart" Style="{StaticResource SectionEyebrow}"/>
                                                            <TextBlock Text="{Binding RestartStageStateText}"
                                                                       Margin="0,4,0,0"
                                                                       Foreground="{Binding RestartStageColor, Converter={StaticResource StrToBrush}}"
                                                                       FontSize="14"
                                                                       FontWeight="SemiBold"
                                                                       TextWrapping="Wrap"/>
                                                            <TextBlock Text="{Binding RestartStageDetailText}"
                                                                       Margin="0,3,0,0"
                                                                       FontSize="11.5"
                                                                       Foreground="{DynamicResource TextMuted}"
                                                                       TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                    </Grid>

                                                    <Grid Margin="12,0,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Width="3"
                                                                Height="36"
                                                                Background="{Binding ValidationStageColor, Converter={StaticResource StrToBrush}}"
                                                                CornerRadius="1"
                                                                Opacity="0.76"
                                                                VerticalAlignment="Top"/>
                                                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                            <TextBlock Text="Validate" Style="{StaticResource SectionEyebrow}"/>
                                                            <TextBlock Text="{Binding ValidationStageStateText}"
                                                                       Margin="0,4,0,0"
                                                                       Foreground="{Binding ValidationStageColor, Converter={StaticResource StrToBrush}}"
                                                                       FontSize="14"
                                                                       FontWeight="SemiBold"
                                                                       TextWrapping="Wrap"/>
                                                            <TextBlock Text="{Binding ValidationStageDetailText}"
                                                                       Margin="0,3,0,0"
                                                                       FontSize="11.5"
                                                                       Foreground="{DynamicResource TextMuted}"
                                                                       TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </UniformGrid>
                                            </Border>

                                            <Border Grid.Row="2"
                                                    Margin="0,10,0,0"
                                                    VerticalAlignment="Top"
                                                    Style="{StaticResource InsetCard}">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="1.05*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel>
                                                        <TextBlock Text="Recovery Kit" Style="{StaticResource SectionEyebrow}"/>
                                                        <TextBlock Text="{Binding RecoveryKitStatusText}"
                                                                   Margin="0,3,0,0"
                                                                   Foreground="{DynamicResource TextSecondary}"
                                                                   FontSize="12"
                                                                   TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <Border Grid.Column="1"
                                                            Margin="14,0,10,0"
                                                            VerticalAlignment="Top">
                                                        <Border.Style>
                                                            <Style TargetType="Border" BasedOn="{StaticResource StatusChipBorder}">
                                                                <Setter Property="Background" Value="{DynamicResource YellowBg}"/>
                                                                <Setter Property="BorderBrush" Value="{DynamicResource Yellow}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasRecoveryKit}" Value="True">
                                                                        <Setter Property="Background" Value="{DynamicResource GreenBg}"/>
                                                                        <Setter Property="BorderBrush" Value="{DynamicResource Green}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock>
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock" BasedOn="{StaticResource StatusChipText}">
                                                                    <Setter Property="Text" Value="Missing"/>
                                                                    <Setter Property="Foreground" Value="{DynamicResource Yellow}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding HasRecoveryKit}" Value="True">
                                                                            <Setter Property="Text" Value="Ready"/>
                                                                            <Setter Property="Foreground" Value="{DynamicResource Green}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top">
                                                        <Button Content="Open"
                                                                Margin="0,0,8,0"
                                                                Style="{StaticResource SecondaryButton}"
                                                                ToolTip="Open the most recent recovery kit folder. Available after a kit has been generated or detected."
                                                                AutomationProperties.Name="Open recovery kit folder"
                                                                IsEnabled="{Binding HasRecoveryKit}"
                                                                Command="{Binding OpenLatestRecoveryKitCommand}"/>
                                                        <Button Content="Create"
                                                                Style="{StaticResource SecondaryButton}"
                                                                ToolTip="Export a fresh recovery kit so rollback stays available even if this install becomes unbootable."
                                                                AutomationProperties.Name="Create recovery kit copy"
                                                                IsEnabled="{Binding ButtonsEnabled}"
                                                                Command="{Binding ExportRecoveryKitCommand}"/>
                                                    </StackPanel>

                                                    <Border Grid.Row="1"
                                                            Grid.ColumnSpan="3"
                                                            Margin="0,8"
                                                            Height="1"
                                                            Background="{DynamicResource Border}"/>

                                                    <StackPanel Grid.Row="2">
                                                        <TextBlock Text="Verification Script" Style="{StaticResource SectionEyebrow}"/>
                                                        <TextBlock Text="{Binding VerificationScriptStatusText}"
                                                                   Margin="0,3,0,0"
                                                                   Foreground="{DynamicResource TextSecondary}"
                                                                   FontSize="12"
                                                                   TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <Border Grid.Row="2"
                                                            Grid.Column="1"
                                                            Margin="14,0,10,0"
                                                            VerticalAlignment="Top">
                                                        <Border.Style>
                                                            <Style TargetType="Border" BasedOn="{StaticResource StatusChipBorder}">
                                                                <Setter Property="Background" Value="{DynamicResource YellowBg}"/>
                                                                <Setter Property="BorderBrush" Value="{DynamicResource Yellow}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasVerificationScript}" Value="True">
                                                                        <Setter Property="Background" Value="{DynamicResource GreenBg}"/>
                                                                        <Setter Property="BorderBrush" Value="{DynamicResource Green}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock>
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock" BasedOn="{StaticResource StatusChipText}">
                                                                    <Setter Property="Text" Value="Missing"/>
                                                                    <Setter Property="Foreground" Value="{DynamicResource Yellow}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding HasVerificationScript}" Value="True">
                                                                            <Setter Property="Text" Value="Ready"/>
                                                                            <Setter Property="Foreground" Value="{DynamicResource Green}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>
                                                    <StackPanel Grid.Row="2" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top">
                                                        <Button Content="Review"
                                                                Margin="0,0,8,0"
                                                                Style="{StaticResource SecondaryButton}"
                                                                ToolTip="Open the latest verification script. Available after a script has been generated or detected."
                                                                AutomationProperties.Name="Review verification script"
                                                                IsEnabled="{Binding HasVerificationScript}"
                                                                Command="{Binding OpenVerificationScriptCommand}"/>
                                                        <Button Content="Generate"
                                                                Style="{StaticResource SecondaryButton}"
                                                                ToolTip="Create a post-reboot PowerShell checklist for the patch and Safe Mode keys."
                                                                AutomationProperties.Name="Generate verification script"
                                                                IsEnabled="{Binding ButtonsEnabled}"
                                                                Command="{Binding GenerateVerificationScriptCommand}"/>
                                                    </StackPanel>

                                                    <Border Grid.Row="3"
                                                            Grid.ColumnSpan="3"
                                                            Margin="0,8"
                                                            Height="1"
                                                            Background="{DynamicResource Border}"/>

                                                    <StackPanel Grid.Row="4">
                                                        <TextBlock Text="Diagnostics Report" Style="{StaticResource SectionEyebrow}"/>
                                                        <TextBlock Text="{Binding DiagnosticsReportStatusText}"
                                                                   Margin="0,3,0,0"
                                                                   Foreground="{DynamicResource TextSecondary}"
                                                                   FontSize="12"
                                                                   TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <Border Grid.Row="4"
                                                            Grid.Column="1"
                                                            Margin="14,0,10,0"
                                                            VerticalAlignment="Top">
                                                        <Border.Style>
                                                            <Style TargetType="Border" BasedOn="{StaticResource StatusChipBorder}">
                                                                <Setter Property="Background" Value="{DynamicResource YellowBg}"/>
                                                                <Setter Property="BorderBrush" Value="{DynamicResource Yellow}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasDiagnosticsReport}" Value="True">
                                                                        <Setter Property="Background" Value="{DynamicResource GreenBg}"/>
                                                                        <Setter Property="BorderBrush" Value="{DynamicResource Green}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock>
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock" BasedOn="{StaticResource StatusChipText}">
                                                                    <Setter Property="Text" Value="Missing"/>
                                                                    <Setter Property="Foreground" Value="{DynamicResource Yellow}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding HasDiagnosticsReport}" Value="True">
                                                                            <Setter Property="Text" Value="Ready"/>
                                                                            <Setter Property="Foreground" Value="{DynamicResource Green}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>
                                                    <StackPanel Grid.Row="4" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top">
                                                        <Button Content="Review"
                                                                Margin="0,0,8,0"
                                                                Style="{StaticResource SecondaryButton}"
                                                                ToolTip="Open the latest diagnostics report. Available after a report has been generated or detected."
                                                                AutomationProperties.Name="Review diagnostics report"
                                                                IsEnabled="{Binding HasDiagnosticsReport}"
                                                                Command="{Binding OpenLatestDiagnosticsReportCommand}"/>
                                                        <Button Content="Export"
                                                                Margin="0,0,8,0"
                                                                Style="{StaticResource SecondaryButton}"
                                                                ToolTip="Export a fresh diagnostics report with health data, configuration, and recent activity."
                                                                AutomationProperties.Name="Export diagnostics report"
                                                                IsEnabled="{Binding ButtonsEnabled}"
                                                                Command="{Binding ExportDiagnosticsCommand}"/>
                                                        <Button Content="Bundle ZIP"
                                                                Style="{StaticResource SecondaryButton}"
                                                                ToolTip="Bundle the diagnostics report, config, crash logs, recent registry backups, and SQLite database into a single shareable ZIP."
                                                                AutomationProperties.Name="Export support bundle zip"
                                                                IsEnabled="{Binding ButtonsEnabled}"
                                                                Command="{Binding ExportSupportBundleCommand}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>

                                            <Border Grid.Row="3"
                                                    Margin="0,10,0,0"
                                                    Padding="12,10"
                                                    Background="{DynamicResource YellowBg}"
                                                    BorderBrush="{DynamicResource Border}"
                                                    BorderThickness="1"
                                                    CornerRadius="6">
                                                <StackPanel>
                                                    <TextBlock Text="Keep one off-device copy"
                                                               Foreground="{DynamicResource Yellow}"
                                                               FontSize="11.5"
                                                               FontWeight="SemiBold"/>
                                                    <TextBlock Text="Before a restart or handoff, place the recovery kit somewhere outside this machine."
                                                               Margin="0,6,0,0"
                                                               Foreground="{DynamicResource TextSecondary}"
                                                               FontSize="12"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </TabItem>

                                    <TabItem Style="{StaticResource WorkspaceTabItem}">
                                        <TabItem.Header>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Tuning"/>
                                            </StackPanel>
                                        </TabItem.Header>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <Border Style="{StaticResource InsetCard}" Visibility="Collapsed">
                                                <TextBlock Text="Advanced StorNVMe tuning sits outside the default patch path. Use it only when you need deeper control."
                                                           Style="{StaticResource BodyCopy}"/>
                                            </Border>

                                            <views:TuningPanel x:Name="TuningPanelControl"
                                                               Grid.Row="1"
                                                               Margin="0"/>
                                        </Grid>
                                    </TabItem>

                                    <TabItem Style="{StaticResource WorkspaceTabItem}">
                                        <TabItem.Header>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Diagnostics"/>
                                            </StackPanel>
                                        </TabItem.Header>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <Border Style="{StaticResource InsetCard}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="Read-only diagnostics" Style="{StaticResource SectionEyebrow}"/>
                                                        <TextBlock Text="Probe watchdog health, reliability history, minidumps, and planned registry writes without changing the system."
                                                                   Margin="0,4,0,0"
                                                                   Style="{StaticResource BodyCopy}"/>
                                                    </StackPanel>

                                                    <WrapPanel Grid.Column="1"
                                                               Margin="16,0,0,0"
                                                               VerticalAlignment="Center">
                                                        <Button Content="Watchdog"
                                                                Command="{Binding RefreshWatchdogStatusCommand}"
                                                                Style="{StaticResource SecondaryButton}"
                                                                AutomationProperties.Name="Refresh watchdog status"
                                                                Margin="0,0,8,0"/>
                                                        <Button Content="Reliability"
                                                                Command="{Binding RefreshReliabilityCommand}"
                                                                Style="{StaticResource SecondaryButton}"
                                                                AutomationProperties.Name="Refresh reliability correlation"
                                                                Margin="0,0,8,0"/>
                                                        <Button Content="Minidumps"
                                                                Command="{Binding TriageMinidumpsCommand}"
                                                                Style="{StaticResource SecondaryButton}"
                                                                AutomationProperties.Name="Triage minidumps"
                                                                Margin="0,0,8,0"/>
                                                        <Button Content="Dry Run"
                                                                Command="{Binding PreviewDryRunCommand}"
                                                                Style="{StaticResource SecondaryButton}"
                                                                AutomationProperties.Name="Preview dry-run plan"/>
                                                    </WrapPanel>
                                                </Grid>
                                            </Border>

                                            <Border Grid.Row="1"
                                                    Style="{StaticResource InsetCard}"
                                                    Margin="0,8,0,0"
                                                    VerticalAlignment="Top">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="118"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Text="Watchdog" Style="{StaticResource SectionEyebrow}"/>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding WatchdogVerdictText}"
                                                               TextWrapping="Wrap"
                                                               Foreground="{DynamicResource TextPrimary}"
                                                               FontSize="12.5"
                                                               FontWeight="SemiBold"/>

                                                    <Border Grid.Row="1"
                                                            Grid.ColumnSpan="2"
                                                            Margin="0,8"
                                                            Height="1"
                                                            Background="{DynamicResource Border}"/>
                                                    <TextBlock Grid.Row="2"
                                                               Text="Reliability"
                                                               Style="{StaticResource SectionEyebrow}"/>
                                                    <TextBlock Grid.Row="2"
                                                               Grid.Column="1"
                                                               Text="{Binding ReliabilitySummaryText}"
                                                               TextWrapping="Wrap"
                                                               Foreground="{DynamicResource TextSecondary}"
                                                               FontSize="12.5"/>

                                                    <Border Grid.Row="3"
                                                            Grid.ColumnSpan="2"
                                                            Margin="0,8"
                                                            Height="1"
                                                            Background="{DynamicResource Border}"/>
                                                    <TextBlock Grid.Row="4"
                                                               Text="Minidumps"
                                                               Style="{StaticResource SectionEyebrow}"/>
                                                    <StackPanel Grid.Row="4"
                                                                Grid.Column="1"
                                                                Margin="0">
                                                        <TextBlock Text="{Binding MinidumpSummaryText}"
                                                                   TextWrapping="Wrap"
                                                                   Foreground="{DynamicResource TextSecondary}"
                                                                   FontSize="12.5"/>

                                                        <Expander Margin="0,10,0,0"
                                                                  IsExpanded="True"
                                                                  Style="{StaticResource DarkExpander}">
                                                            <Expander.Header>
                                                                <TextBlock Text="Dry-run preview"
                                                                           FontWeight="SemiBold"/>
                                                            </Expander.Header>
                                                            <TextBox Text="{Binding DryRunPreviewText, Mode=OneWay}"
                                                                     IsReadOnly="True"
                                                                     TextWrapping="Wrap"
                                                                     AcceptsReturn="True"
                                                                     VerticalScrollBarVisibility="Auto"
                                                                     AutomationProperties.Name="Dry-run preview output"
                                                                     FontFamily="Cascadia Code, Consolas, monospace"
                                                                     FontSize="11.5"
                                                                     MinHeight="120"
                                                                     MaxHeight="240"/>
                                                        </Expander>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </TabItem>

                                    <TabItem Style="{StaticResource WorkspaceTabItem}">
                                        <TabItem.Header>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Settings"/>
                                            </StackPanel>
                                        </TabItem.Header>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    Style="{StaticResource InsetCard}"
                                                    VerticalAlignment="Top">
                                                <StackPanel>
                                                    <TextBlock Text="Patch profile" Style="{StaticResource SectionEyebrow}"/>
                                                    <TextBlock Text="{Binding OptionsSummaryText}"
                                                               Margin="0,4,0,0"
                                                               Style="{StaticResource BodyCopy}"/>

                                                    <TextBlock Text="Install mode"
                                                               Margin="0,9,0,2"
                                                               Foreground="{DynamicResource TextPrimary}"
                                                               FontSize="12.5"
                                                               FontWeight="SemiBold"/>
                                                    <RadioButton Content="Safe profile (recommended)"
                                                                 Style="{StaticResource DarkRadioButton}"
                                                                 GroupName="VisiblePatchProfile"
                                                                 ToolTip="Writes the primary flag plus Safe Boot entries. This is the lowest-risk default."
                                                                 IsChecked="{Binding IsSafeModeSelected}"/>
                                                    <RadioButton Content="Full profile"
                                                                 Style="{StaticResource DarkRadioButton}"
                                                                 GroupName="VisiblePatchProfile"
                                                                 ToolTip="Adds related optimization flags. Use only when the machine-specific evidence supports the higher-risk profile."
                                                                 IsChecked="{Binding IsFullModeSelected}"/>
                                                    <TextBlock Text="{Binding PatchProfileHelpText}"
                                                               Margin="0,6,0,0"
                                                               Foreground="{DynamicResource TextMuted}"
                                                               FontSize="11.5"
                                                               TextWrapping="Wrap"/>

                                                    <Border Margin="0,8,0,0"
                                                            Padding="10,8"
                                                            Background="{DynamicResource YellowBg}"
                                                            BorderBrush="{DynamicResource Border}"
                                                            BorderThickness="1"
                                                            CornerRadius="6">
                                                        <TextBlock Text="DirectStorage and BypassIO may fall back on nvmedisk.sys. Keep removal available on gaming systems."
                                                                   Foreground="{DynamicResource Yellow}"
                                                                   FontSize="12"
                                                                   TextWrapping="Wrap"/>
                                                    </Border>
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="2"
                                                    Style="{StaticResource InsetCard}"
                                                    VerticalAlignment="Top">
                                                <StackPanel>
                                                    <TextBlock Text="Audit and alerts" Style="{StaticResource SectionEyebrow}"/>
                                                    <TextBlock Text="{Binding PreferenceSummaryText}"
                                                               Margin="0,4,0,0"
                                                               Style="{StaticResource BodyCopy}"/>

                                                    <Grid Margin="0,10,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="12"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Theme"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource TextSecondary}"
                                                                   FontWeight="SemiBold"/>
                                                        <ComboBox x:Name="ThemeModeSelector"
                                                                  Grid.Column="2"
                                                                  MinWidth="180"
                                                                  HorizontalAlignment="Left"
                                                                  Style="{StaticResource DarkComboBox}"
                                                                  AutomationProperties.Name="Theme mode"
                                                                  ToolTip="Choose whether the app follows Windows, uses a fixed light or dark theme, or switches to the accessible contrast palette."
                                                                  SelectionChanged="ThemeModeSelector_SelectionChanged">
                                                            <ComboBoxItem Content="System" Tag="System" Style="{StaticResource DarkComboBoxItem}"/>
                                                            <ComboBoxItem Content="Light" Tag="Light" Style="{StaticResource DarkComboBoxItem}"/>
                                                            <ComboBoxItem Content="Dark" Tag="Dark" Style="{StaticResource DarkComboBoxItem}"/>
                                                            <ComboBoxItem Content="High Contrast" Tag="HighContrast" Style="{StaticResource DarkComboBoxItem}"/>
                                                        </ComboBox>
                                                    </Grid>
                                                    <TextBlock Text="{Binding ThemeModeSummaryText}"
                                                               Margin="0,6,0,0"
                                                               Foreground="{DynamicResource TextDim}"
                                                               FontSize="11.5"
                                                               TextWrapping="Wrap"/>

                                                    <Grid Margin="0,8,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition/>
                                                            <ColumnDefinition Width="10"/>
                                                            <ColumnDefinition/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <CheckBox Content="Auto-save activity log"
                                                                      Style="{StaticResource DarkCheckBox}"
                                                                      IsChecked="{Binding AutoSaveLog}"/>
                                                            <CheckBox Content="Toast notifications"
                                                                      Style="{StaticResource DarkCheckBox}"
                                                                      IsChecked="{Binding EnableToasts}"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2">
                                                            <CheckBox Content="Windows Event Log"
                                                                      Style="{StaticResource DarkCheckBox}"
                                                                      IsChecked="{Binding WriteEventLog}"/>
                                                            <CheckBox Content="Server 2025 key"
                                                                      Style="{StaticResource DarkCheckBox}"
                                                                      IsChecked="{Binding IncludeServerKey}"/>
                                                        </StackPanel>
                                                    </Grid>

                                                    <Grid Margin="0,10,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="84"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Restart delay"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource TextSecondary}"
                                                                   FontWeight="SemiBold"/>
                                                        <TextBox Grid.Column="1"
                                                                 Margin="10,0"
                                                                 Style="{StaticResource DarkTextBox}"
                                                                 AutomationProperties.Name="Restart delay in seconds"
                                                                 ToolTip="Use a value between 5 and 300 seconds for post-patch restart countdowns."
                                                                 Text="{Binding RestartDelayText, UpdateSourceTrigger=LostFocus}"
                                                                 VerticalContentAlignment="Center"/>
                                                        <TextBlock Grid.Column="2"
                                                                   Text="seconds"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource TextDim}"/>
                                                    </Grid>

                                                    <WrapPanel Margin="0,10,0,0">
                                                        <Button Content="Open Data"
                                                                Margin="0,0,8,0"
                                                                Style="{StaticResource SecondaryButton}"
                                                                AutomationProperties.Name="Open data folder"
                                                                ToolTip="Open the working folder that stores logs, exports, backups, and diagnostics."
                                                                Command="{Binding OpenDataFolderCommand}"/>
                                                        <Button Content="Restore Defaults"
                                                                Style="{StaticResource SecondaryButton}"
                                                                AutomationProperties.Name="Restore recommended defaults"
                                                                ToolTip="Restore the app's recommended safety-first settings."
                                                                Command="{Binding UseRecommendedSetupCommand}"/>
                                                    </WrapPanel>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </TabItem>
                                </TabControl>

                                <Border x:Name="ActivityRail"
                                        Grid.Row="0"
                                        Grid.Column="2"
                                        Grid.RowSpan="2"
                                        Padding="8"
                                        Background="{DynamicResource SurfaceInset}"
                                        BorderBrush="{DynamicResource Border}"
                                        BorderThickness="1"
                                        CornerRadius="7"
                                        AutomationProperties.Name="Always visible activity log">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="Activity"
                                                           Foreground="{DynamicResource TextPrimary}"
                                                           FontSize="15"
                                                           FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding LogRetentionText}"
                                                           Margin="0,4,0,0"
                                                           Foreground="{DynamicResource TextDim}"
                                                           FontSize="10.5"
                                                           LineHeight="14"
                                                           MaxHeight="16"
                                                           TextTrimming="CharacterEllipsis"
                                                           TextWrapping="NoWrap"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1"
                                                        Margin="12,0,0,0"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Top">
                                                <Border Padding="6,3"
                                                        Background="{DynamicResource BgMedium}"
                                                        BorderBrush="{DynamicResource Border}"
                                                        BorderThickness="1"
                                                        CornerRadius="5">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding LogEntryCount}"
                                                                   Foreground="{DynamicResource TextPrimary}"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"/>
                                                        <TextBlock Text=" log"
                                                                   Margin="3,0,0,0"
                                                                   Foreground="{DynamicResource TextDim}"
                                                                   FontSize="10.5"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border Margin="6,0,0,0"
                                                        Padding="6,3"
                                                        Background="{DynamicResource BgMedium}"
                                                        BorderBrush="{DynamicResource Border}"
                                                        BorderThickness="1"
                                                        CornerRadius="5">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding LogWarningCount}"
                                                                   Foreground="{DynamicResource Yellow}"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"/>
                                                        <TextBlock Text=" warn"
                                                                   Margin="3,0,0,0"
                                                                   Foreground="{DynamicResource TextDim}"
                                                                   FontSize="10.5"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border Margin="6,0,0,0"
                                                        Padding="6,3"
                                                        Background="{DynamicResource BgMedium}"
                                                        BorderBrush="{DynamicResource Border}"
                                                        BorderThickness="1"
                                                        CornerRadius="5">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding LogErrorCount}"
                                                                   Foreground="{DynamicResource Red}"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"/>
                                                        <TextBlock Text=" err"
                                                                   Margin="3,0,0,0"
                                                                   Foreground="{DynamicResource TextDim}"
                                                                   FontSize="10.5"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border Width="3"
                                                        Height="18"
                                                        Margin="8,2,2,0"
                                                        Background="{Binding ActivityTabBadgeColor, Converter={StaticResource StrToBrush}}"
                                                        CornerRadius="1"/>
                                            </StackPanel>
                                        </Grid>

                                        <Grid Grid.Row="1" Margin="0,6,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Button Content="Copy"
                                                    Grid.Column="0"
                                                    MinWidth="0"
                                                    AutomationProperties.Name="Copy activity log"
                                                    Command="{Binding CopyLogCommand}">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding LogEntryCount}" Value="0">
                                                                <Setter Property="IsEnabled" Value="False"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                            <Button Content="Export"
                                                    Grid.Column="2"
                                                    MinWidth="0"
                                                    AutomationProperties.Name="Export activity log"
                                                    Command="{Binding ExportLogCommand}">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding LogEntryCount}" Value="0">
                                                                <Setter Property="IsEnabled" Value="False"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                            <Button Content="Clear"
                                                    Grid.Column="4"
                                                    MinWidth="0"
                                                    AutomationProperties.Name="Clear activity log"
                                                    Click="ClearLog_Click">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource WarningSecondaryButton}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding LogEntryCount}" Value="0">
                                                                <Setter Property="IsEnabled" Value="False"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </Grid>

                                        <Border Grid.Row="2"
                                                Margin="0,6,0,0"
                                                Padding="8"
                                                CornerRadius="7">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{DynamicResource BgDarkest}"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource Border}"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                                            <Setter Property="BorderBrush" Value="{DynamicResource Focus}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <ScrollViewer x:Name="ActivityRailLogScroller"
                                                              VerticalScrollBarVisibility="Auto">
                                                    <TextBox x:Name="ActivityRailLogOutput"
                                                             Text="{Binding LogText, Mode=OneWay}"
                                                             Background="Transparent"
                                                             BorderThickness="0"
                                                             CaretBrush="Transparent"
                                                             AutomationProperties.Name="Persistent activity log output"
                                                             FontFamily="Cascadia Code,Consolas,Courier New"
                                                             FontSize="10.5"
                                                             Foreground="{DynamicResource TextSecondary}"
                                                             IsReadOnly="True"
                                                             IsTabStop="True"
                                                             Padding="0"
                                                             SelectionBrush="{DynamicResource AccentBg}"
                                                             TextChanged="LogOutput_TextChanged"
                                                             TextWrapping="Wrap">
                                                        <TextBox.ContextMenu>
                                                            <ContextMenu>
                                                                <MenuItem Header="Copy Selection" Click="CopySelection_Click"/>
                                                                <MenuItem Header="Select All" Click="SelectAll_Click"/>
                                                                <Separator/>
                                                                <MenuItem Header="Copy Entire Log" Command="{Binding CopyLogCommand}"/>
                                                                <MenuItem Header="Clear Log" Click="ClearLog_Click"/>
                                                            </ContextMenu>
                                                        </TextBox.ContextMenu>
                                                    </TextBox>
                                                </ScrollViewer>

                                                <Border IsHitTestVisible="False">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding LogEntryCount}" Value="0">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                MaxWidth="260">
                                                        <TextBlock Text="No activity yet"
                                                                   Foreground="{DynamicResource TextPrimary}"
                                                                   FontSize="15"
                                                                   FontWeight="SemiBold"
                                                                   TextAlignment="Center"/>
                                                        <TextBlock Text="Checks and driver actions will stream here."
                                                                   Margin="0,8,0,0"
                                                                   Foreground="{DynamicResource TextDim}"
                                                                   FontSize="11"
                                                                   TextAlignment="Center"
                                                                   TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </Border>

                                        <StackPanel Grid.Row="3"
                                                    Margin="0,6,0,0"
                                                    Visibility="{Binding ProgressVisible, Converter={StaticResource BoolVis}}">
                                            <ProgressBar Height="6"
                                                         Value="{Binding ProgressValue}"
                                                         Foreground="{DynamicResource Accent}"
                                                         Template="{StaticResource RoundProgress}"
                                                         AutomationProperties.Name="Current operation progress"
                                                         AutomationProperties.LiveSetting="Polite"/>
                                            <TextBlock Text="{Binding ProgressText}"
                                                       Margin="0,6,0,0"
                                                       Foreground="{DynamicResource TextDim}"
                                                       FontSize="10.5"
                                                       TextTrimming="CharacterEllipsis"
                                                       AutomationProperties.LiveSetting="Polite"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>

                    <Border Grid.Row="3" Margin="24,12,24,14" Visibility="Collapsed">
                        <Grid>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Foreground="{DynamicResource TextDim}"
                                           FontSize="11"
                                           Text="Verify, back up, apply, reboot, confirm."/>
                                <WrapPanel Margin="0,8,0,0"
                                           Visibility="{Binding ProgressVisible, Converter={StaticResource BoolVis}}">
                                    <TextBlock Text="{Binding ProgressText}"
                                               Margin="0,0,12,8"
                                               Foreground="{DynamicResource TextSecondary}"
                                               FontSize="11"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="420"/>
                                    <ProgressBar Width="180"
                                                 Height="6"
                                                 Margin="0,4,0,8"
                                                 VerticalAlignment="Center"
                                                 Value="{Binding ProgressValue}"
                                                 Foreground="{DynamicResource Accent}"
                                                 AutomationProperties.Name="Footer operation progress"
                                                 AutomationProperties.LiveSetting="Polite"
                                                 Template="{StaticResource RoundProgress}"/>
                                </WrapPanel>
                            </StackPanel>

                            <WrapPanel x:Name="FooterActionsPanel"
                                       Orientation="Horizontal"
                                       HorizontalAlignment="Right"
                                       ItemHeight="34">
                                <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource TextDim}">
                                    <Hyperlink Foreground="{DynamicResource TextMuted}" TextDecorations="None" Click="GitHub_Click">GitHub</Hyperlink>
                                </TextBlock>
                                <TextBlock Margin="8,0" VerticalAlignment="Center" Foreground="{DynamicResource TextDimmer}" Text="•"/>
                                <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource TextDim}">
                                    <Hyperlink Foreground="{DynamicResource TextMuted}" TextDecorations="None" Click="Docs_Click">Microsoft docs</Hyperlink>
                                </TextBlock>
                                <Button Content="Open Data"
                                        Margin="16,0,0,0"
                                        Style="{StaticResource SecondaryButton}"
                                        AutomationProperties.Name="Open data folder"
                                        Command="{Binding OpenDataFolderCommand}"/>
                            </WrapPanel>
                        </Grid>
                    </Border>
                </Grid>

                <Border Panel.ZIndex="4"
                        Background="{DynamicResource OverlayScrimBrush}"
                        AutomationProperties.Name="Readiness refresh overlay"
                        AutomationProperties.LiveSetting="Polite"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolVis}}">
                    <Grid>
                                <Border MaxWidth="500"
                                Margin="18"
                                Padding="20,18"
                                Background="{DynamicResource BgDark}"
                                BorderBrush="{DynamicResource BorderLight}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Effect="{DynamicResource WindowShadow}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <StackPanel>
                                <TextBlock Text="Checking readiness"
                                           Foreground="{DynamicResource TextPrimary}"
                                           FontSize="24"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="Verifying Windows build, storage path, NVMe inventory, and rollback safety."
                                           Margin="0,10,0,0"
                                           Style="{StaticResource BodyCopy}"/>

                                <ProgressBar Margin="0,14,0,0"
                                             Height="6"
                                             Foreground="{DynamicResource Accent}"
                                             AutomationProperties.Name="Refreshing readiness progress"
                                             AutomationProperties.LiveSetting="Polite"
                                             Template="{StaticResource RoundProgressIndeterminate}"/>

                                <UniformGrid Margin="0,12,0,0" Columns="3">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,14,0">
                                        <Border Width="3" Height="14" Margin="0,1,8,0" Background="{DynamicResource Accent}" CornerRadius="1"/>
                                        <TextBlock Text="Build and driver" Style="{StaticResource BodyCopy}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,14,0">
                                        <Border Width="3" Height="14" Margin="0,1,8,0" Background="{DynamicResource Accent}" CornerRadius="1"/>
                                        <TextBlock Text="Drive inventory" Style="{StaticResource BodyCopy}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="3" Height="14" Margin="0,1,8,0" Background="{DynamicResource Accent}" CornerRadius="1"/>
                                        <TextBlock Text="Rollback safety" Style="{StaticResource BodyCopy}"/>
                                    </StackPanel>
                                </UniformGrid>

                                <TextBlock Text="This can take a few seconds while Windows storage and WMI data settle."
                                           Margin="0,16,0,0"
                                           Foreground="{DynamicResource TextDim}"
                                           FontSize="12"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
