                                                                    Opacity="0.16"
                                                                    VerticalAlignment="Top"/>
                                                            <Ellipse Width="9"
                                                                     Height="9"
                                                                     Margin="10.5,10.5,0,0"
                                                                     HorizontalAlignment="Left"
                                                                     VerticalAlignment="Top"
                                                                     Fill="{Binding ToneColor, Converter={StaticResource StrToBrush}}"/>

                                                            <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                                                <TextBlock Text="{Binding Title}"
                                                                           Foreground="{Binding ToneColor, Converter={StaticResource StrToBrush}}"
                                                                           FontSize="13"
                                                                           FontWeight="SemiBold"
                                                                           TextWrapping="Wrap"/>
                                                                <TextBlock Text="{Binding Detail}"
                                                                           Margin="0,8,0,0"
                                                                           Foreground="{StaticResource TextSecondary}"
                                                                           FontSize="12"
                                                                           TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SurfaceCard}" Margin="0,0,0,16">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Style="{StaticResource InsetCard}">
                                            <StackPanel>
                                                <TextBlock Text="Patch Defaults" Style="{StaticResource SectionEyebrow}"/>
                                                <TextBlock Text="{Binding OptionsSummaryText}"
                                                           Margin="0,8,0,0"
                                                           Style="{StaticResource BodyCopy}"/>

                                                <TextBlock Text="Install Mode"
                                                           Margin="0,16,0,6"
                                                           Foreground="{StaticResource TextPrimary}"
                                                           FontSize="12.5"
                                                           FontWeight="SemiBold"/>
                                                <RadioButton Content="Safe Mode (recommended) — primary flag only"
                                                             Style="{StaticResource DarkRadioButton}"
                                                             GroupName="PatchProfile"
                                                             ToolTip="Writes just 735209102 plus Safe Boot entries. Swaps the driver with the lowest crash risk."
                                                             IsChecked="{Binding IsSafeModeSelected}"/>
                                                <RadioButton Content="Full Mode — all three feature flags"
                                                             Style="{StaticResource DarkRadioButton}"
                                                             GroupName="PatchProfile"
                                                             ToolTip="Adds 1853569164 (UxAccOptimization) and 156965516 (Standalone_Future). Higher peak performance on some drives, higher BSOD risk on others."
                                                             IsChecked="{Binding IsFullModeSelected}"/>
                                                <TextBlock Text="{Binding PatchProfileHelpText}"
                                                           Margin="0,8,0,0"
                                                           Foreground="{StaticResource TextMuted}"
                                                           FontSize="11.5"
                                                           TextWrapping="Wrap"/>

                                                <CheckBox Content="Include Microsoft Server 2025 compatibility key"
                                                          Style="{StaticResource DarkCheckBox}"
                                                          IsChecked="{Binding IncludeServerKey}"/>
                                                <CheckBox Content="Skip confirmation warnings for expert runs"
                                                          Style="{StaticResource DarkCheckBox}"
                                                          IsChecked="{Binding SkipWarnings}"/>

                                                <Border Margin="0,14,0,0"
                                                        Padding="14,12"
                                                        Background="{StaticResource AccentBg}"
                                                        BorderBrush="{StaticResource BorderLight}"
                                                        BorderThickness="1"
                                                        CornerRadius="12">
                                                    <TextBlock Text="Safe Mode is the community-recommended default for 2026. The Server 2025 key is optional and mostly relevant on server SKUs — leave it off unless you know you need it."
                                                               Foreground="{StaticResource TextSecondary}"
                                                               FontSize="12"
                                                               TextWrapping="Wrap"/>
                                                </Border>

                                                <Border Margin="0,10,0,0"
                                                        Padding="14,12"
                                                        Background="{StaticResource YellowBg}"
                                                        BorderBrush="{StaticResource Border}"
                                                        BorderThickness="1"
                                                        CornerRadius="12">
                                                    <TextBlock Text="Heads-up for gamers: nvmedisk.sys does not honor BypassIO, so DirectStorage titles fall back to the slower path. Skip the patch on your gaming rig, or keep a one-click removal ready."
                                                               Foreground="{StaticResource Yellow}"
                                                               FontSize="12"
                                                               TextWrapping="Wrap"/>
                                                </Border>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="2" Style="{StaticResource InsetCard}">
                                            <StackPanel>
                                                <TextBlock Text="Audit &amp; Alerts" Style="{StaticResource SectionEyebrow}"/>
                                                <TextBlock Text="{Binding PreferenceSummaryText}"
                                                           Margin="0,8,0,0"
                                                           Style="{StaticResource BodyCopy}"/>

                                                <CheckBox Content="Auto-save activity log on exit"
                                                          Style="{StaticResource DarkCheckBox}"
                                                          IsChecked="{Binding AutoSaveLog}"/>
                                                <CheckBox Content="Show toast notifications"
                                                          Style="{StaticResource DarkCheckBox}"
                                                          IsChecked="{Binding EnableToasts}"/>
                                                <CheckBox Content="Write audit entries to Windows Event Log"
                                                          Style="{StaticResource DarkCheckBox}"
                                                          IsChecked="{Binding WriteEventLog}"/>

                                                <StackPanel Orientation="Horizontal" Margin="0,14,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="Restart delay"
                                                               VerticalAlignment="Center"
                                                               Foreground="{StaticResource TextSecondary}"
                                                               FontWeight="SemiBold"/>
                                                    <TextBox Width="72"
                                                             Margin="12,0,10,0"
                                                             Style="{StaticResource DarkTextBox}"
                                                             Text="{Binding RestartDelayText, UpdateSourceTrigger=LostFocus}"
                                                             VerticalContentAlignment="Center"/>
                                                    <TextBlock Text="seconds"
                                                               VerticalAlignment="Center"
                                                               Foreground="{StaticResource TextDim}"/>
                                                </StackPanel>

                                                <Button Content="Open Data Folder"
                                                        Margin="0,14,0,0"
                                                        HorizontalAlignment="Left"
                                                        Style="{StaticResource SecondaryButton}"
                                                        Command="{Binding OpenDataFolderCommand}"/>
                                                <Button Content="Use Recommended Setup"
                                                        Margin="0,10,0,0"
                                                        HorizontalAlignment="Left"
                                                        Style="{StaticResource SecondaryButton}"
                                                        Command="{Binding UseRecommendedSetupCommand}"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource SurfaceCard}" Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock Text="Detected Storage" Style="{StaticResource SectionEyebrow}"/>
                                        <TextBlock Text="{Binding DriveInventorySummaryText}"
                                                   Margin="0,8,0,0"
                                                   Style="{StaticResource BodyCopy}"/>

                                        <TextBlock Margin="0,18,0,0"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextDim}"
                                                   Text="No drive data was returned by the latest scan. Refresh the checks or confirm the app still has administrator access.">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasDriveData}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <ItemsControl ItemsSource="{Binding Drives}" Margin="0,18,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,10"
                                                            Padding="16,14"
                                                            Background="{StaticResource BgMedium}"
                                                            BorderBrush="{StaticResource Border}"
                                                            BorderThickness="1"
                                                            CornerRadius="14">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="18"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <StackPanel>
                                                                <StackPanel Orientation="Horizontal">
                                                                    <Ellipse Width="10"
                                                                             Height="10"
                                                                             Margin="0,0,10,0"
                                                                             VerticalAlignment="Center"
                                                                             Fill="{Binding DotColor, Converter={StaticResource StrToBrush}}"/>
                                                                    <TextBlock Text="{Binding Name}"
                                                                               Foreground="{StaticResource TextPrimary}"
                                                                               FontSize="13"
                                                                               FontWeight="SemiBold"
                                                                               TextTrimming="CharacterEllipsis"/>
                                                                </StackPanel>
                                                                <TextBlock Text="{Binding Size}"
                                                                           Margin="20,6,0,0"
                                                                           Foreground="{StaticResource TextDim}"
                                                                           FontSize="12"/>
                                                            </StackPanel>

                                                            <WrapPanel Grid.Column="2"
                                                                       HorizontalAlignment="Right"
                                                                       VerticalAlignment="Center"
                                                                       ItemHeight="28">
                                                                <Border Margin="0,0,6,6"
                                                                        Padding="10,5"
                                                                        Background="{Binding BusPillBg, Converter={StaticResource StrToBrush}}"
                                                                        CornerRadius="999">
                                                                    <TextBlock Text="{Binding BusType}"
                                                                               Foreground="{Binding BusPillFg, Converter={StaticResource StrToBrush}}"
                                                                               FontSize="11"
                                                                               FontWeight="SemiBold"/>
                                                                </Border>

                                                                <Border Margin="0,0,6,6"
                                                                        Padding="10,5"
                                                                        Background="{StaticResource YellowBg}"
                                                                        CornerRadius="999"
                                                                        Visibility="{Binding IsBoot, Converter={StaticResource BoolVis}}">
                                                                    <TextBlock Text="Boot"
                                                                               Foreground="{StaticResource Yellow}"
                                                                               FontSize="11"
                                                                               FontWeight="SemiBold"/>
                                                                </Border>

                                                                <Border Margin="0,0,6,6"
                                                                        Padding="10,5"
                                                                        Background="{Binding DriverBadgeBg, Converter={StaticResource StrToBrush}}"
                                                                        CornerRadius="999"
                                                                        Visibility="{Binding ShowDriverBadge, Converter={StaticResource BoolVis}}">
                                                                    <TextBlock Text="{Binding DriverBadgeText}"
                                                                               Foreground="{Binding DriverBadgeFg, Converter={StaticResource StrToBrush}}"
                                                                               FontSize="11"
                                                                               FontWeight="SemiBold"/>
                                                                </Border>

                                                                <Border Margin="0,0,6,6"
                                                                        Padding="10,5"
                                                                        Background="{StaticResource SurfaceInset}"
                                                                        CornerRadius="999"
                                                                        ToolTip="Drive temperature"
                                                                        Visibility="{Binding ShowTemp, Converter={StaticResource BoolVis}}">
                                                                    <TextBlock Text="{Binding Temperature}"
                                                                               Foreground="{Binding TempColor, Converter={StaticResource StrToBrush}}"
                                                                               FontSize="11"
                                                                               FontWeight="SemiBold"/>
                                                                </Border>

                                                                <Border Margin="0,0,6,6"
                                                                        Padding="10,5"
                                                                        Background="{StaticResource SurfaceInset}"
                                                                        CornerRadius="999"
                                                                        ToolTip="{Binding SmartTooltip}"
                                                                        Visibility="{Binding ShowWear, Converter={StaticResource BoolVis}}">
                                                                    <TextBlock Text="{Binding Wear}"
                                                                               Foreground="{Binding WearColor, Converter={StaticResource StrToBrush}}"
                                                                               FontSize="11"
                                                                               FontWeight="SemiBold"/>
                                                                </Border>

                                                                <Border Margin="0,0,0,6"
                                                                        Padding="10,5"
                                                                        Background="{StaticResource SurfaceInset}"
                                                                        CornerRadius="999"
                                                                        ToolTip="Firmware version"
                                                                        Visibility="{Binding ShowFirmware, Converter={StaticResource BoolVis}}">
                                                                    <TextBlock Text="{Binding Firmware}"
                                                                               Foreground="{StaticResource TextMuted}"
                                                                               FontSize="11"/>
                                                                </Border>
                                                            </WrapPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SurfaceCard}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Registry Change Set" Style="{StaticResource SectionEyebrow}"/>
                                            <TextBlock Text="Feature flags that enable the native path and its supporting optimizations."
                                                       Margin="0,8,0,0"
                                                       Style="{StaticResource BodyCopy}"/>

                                            <ItemsControl ItemsSource="{Binding RegistryFlags}" Margin="0,18,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,0,0,10"
                                                                Padding="14,12"
                                                                Background="{StaticResource BgMedium}"
                                                                BorderBrush="{StaticResource Border}"
                                                                BorderThickness="1"
                                                                CornerRadius="12">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="120"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>

                                                                <Ellipse Width="9"
                                                                         Height="9"
                                                                         Margin="0,0,10,0"
                                                                         VerticalAlignment="Center"
                                                                         Fill="{Binding DotColor, Converter={StaticResource StrToBrush}}"/>
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding Id}"
                                                                           Foreground="{StaticResource TextPrimary}"
                                                                           FontFamily="Cascadia Code,Consolas"
                                                                           FontSize="11"
                                                                           FontWeight="SemiBold"/>
                                                                <TextBlock Grid.Column="2"
                                                                           Text="{Binding Name}"
                                                                           Foreground="{StaticResource TextMuted}"
                                                                           FontSize="12"
                                                                           TextWrapping="Wrap"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Recovery Safeguards" Style="{StaticResource SectionEyebrow}"/>
                                            <TextBlock Text="Critical recovery keys that keep Safe Mode usable if you need to roll back offline."
                                                       Margin="0,8,0,0"
                                                       Style="{StaticResource BodyCopy}"/>

                                            <ItemsControl ItemsSource="{Binding SafeBootFlags}" Margin="0,18,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,0,0,10"
                                                                Padding="14,12"
                                                                Background="{StaticResource BgMedium}"
                                                                BorderBrush="{StaticResource Border}"
                                                                BorderThickness="1"
                                                                CornerRadius="12">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="120"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>

                                                                <Ellipse Width="9"
                                                                         Height="9"
                                                                         Margin="0,0,10,0"
                                                                         VerticalAlignment="Center"
                                                                         Fill="{Binding DotColor, Converter={StaticResource StrToBrush}}"/>
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding Id}"
                                                                           Foreground="{StaticResource TextPrimary}"
                                                                           FontFamily="Cascadia Code,Consolas"
                                                                           FontSize="11"
                                                                           FontWeight="SemiBold"/>
                                                                <TextBlock Grid.Column="2"
                                                                           Text="{Binding Name}"
                                                                           Foreground="{StaticResource TextMuted}"
                                                                           FontSize="12"
                                                                           TextWrapping="Wrap"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <GridSplitter Grid.Column="1"
                                      Width="6"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Stretch"
                                      Background="Transparent"
                                      Cursor="SizeWE"
                                      ShowsPreview="True"/>

                        <Border Grid.Column="2" Style="{StaticResource SurfaceCard}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Validation Workspace" Style="{StaticResource SectionEyebrow}"/>
                                    <TextBlock Text="Use activity for traceability, benchmarks for before-and-after validation, telemetry for health trends, recovery for rollback confidence, and tuning only when you need deeper control."
                                               Margin="0,8,0,0"
                                               Style="{StaticResource BodyCopy}"/>
                                </StackPanel>

                                <TabControl x:Name="WorkspaceTabs"
                                            Grid.Row="1"
                                            Margin="0,18,0,0"
                                            Style="{StaticResource WorkspaceTabControl}"
                                            KeyboardNavigation.TabNavigation="Cycle"
                                            AutomationProperties.Name="Workspace tabs"
                                            SelectionChanged="WorkspaceTabs_SelectionChanged">
                                    <TabItem Style="{StaticResource WorkspaceTabItem}">
                                        <TabItem.Header>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Activity" VerticalAlignment="Center"/>
                                                <Border Margin="8,0,0,0"
                                                        Padding="8,3"
                                                        Background="{StaticResource BgMedium}"
                                                        BorderBrush="{Binding ActivityTabBadgeColor, Converter={StaticResource StrToBrush}}"
                                                        BorderThickness="1"
                                                        CornerRadius="999">
                                                    <TextBlock Text="{Binding ActivityTabBadgeText}"
                                                               Foreground="{Binding ActivityTabBadgeColor, Converter={StaticResource StrToBrush}}"
                                                               FontSize="10.5"
                                                               FontWeight="SemiBold"/>
                                                </Border>
                                            </StackPanel>
                                        </TabItem.Header>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel>
                                                    <TextBlock Text="Live activity keeps every step auditable, from preflight checks through restart prompts."
                                                               Style="{StaticResource BodyCopy}"/>
                                                    <TextBlock Text="{Binding LogRetentionText}"
                                                               Margin="0,8,0,0"
                                                               Foreground="{StaticResource TextDim}"
                                                               FontSize="11"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="16,0,0,0">
                                                    <Button Content="Copy"
                                                            Margin="0,0,8,0"
                                                            Style="{StaticResource SecondaryButton}"
                                                            AutomationProperties.Name="Copy activity log"
                                                            Command="{Binding CopyLogCommand}"/>
                                                    <Button Content="Export"
                                                            Margin="0,0,8,0"
                                                            Style="{StaticResource SecondaryButton}"
                                                            AutomationProperties.Name="Export activity log"
                                                            Command="{Binding ExportLogCommand}"/>
                                                    <Button Content="Clear"
                                                            Style="{StaticResource SecondaryButton}"
                                                            AutomationProperties.Name="Clear activity log"
                                                            Click="ClearLog_Click"/>
                                                </StackPanel>
                                            </Grid>

                                            <Grid Grid.Row="1" Margin="0,18,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="12"/>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="12"/>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="12"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Column="0" Style="{StaticResource InsetCard}">
                                                    <StackPanel>
                                                        <TextBlock Text="Entries" Style="{StaticResource SectionEyebrow}"/>
