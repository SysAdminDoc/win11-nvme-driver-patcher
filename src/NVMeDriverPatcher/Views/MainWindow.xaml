<Window x:Class="NVMeDriverPatcher.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:NVMeDriverPatcher.Views"
        Title="NVMe Driver Patcher"
        Height="968"
        Width="1440"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        AllowsTransparency="True"
        Background="#00000000"
        WindowStartupLocation="CenterScreen"
        MinHeight="780"
        MinWidth="1080"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Grid x:Name="RootFrame" Margin="16">
        <Border x:Name="ShellBorder"
                Background="{StaticResource WindowCanvasBrush}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="1"
                CornerRadius="18"
                ClipToBounds="False">
            <Border.Effect>
                <StaticResource ResourceKey="WindowShadow"/>
            </Border.Effect>

            <Grid ClipToBounds="True">
                <Border x:Name="ShellAccentBar"
                        Height="1"
                        VerticalAlignment="Top"
                        Background="{StaticResource AccentLineBrush}"
                        CornerRadius="18,18,0,0"
                        Panel.ZIndex="2"/>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border x:Name="TitleBarRegion"
                            Grid.Row="0"
                            Padding="24,18,24,0"
                            Background="Transparent"
                            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal">
                                <Border Width="40"
                                        Height="40"
                                        Margin="0,0,14,0"
                                        Background="{StaticResource SurfaceInset}"
                                        BorderBrush="{StaticResource Border}"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <Grid>
                                        <TextBlock Text="NVMe"
                                                   FontSize="11"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource Accent}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <StackPanel>
                                    <TextBlock Text="NVMe Driver Patcher"
                                               FontSize="24"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimary}"/>
                                    <TextBlock Text="Enable, verify, and roll back the Windows 11 native NVMe driver."
                                               FontSize="12.5"
                                               Foreground="{StaticResource TextMuted}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Top">
                                <Button Style="{StaticResource BadgeButton}"
                                        Margin="0,0,10,0"
                                        Background="{StaticResource YellowBg}"
                                        Foreground="{StaticResource Yellow}"
                                        Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolVis}}"
                                        Command="{Binding OpenUpdateUrlCommand}"
                                        ToolTip="{Binding UpdateTooltip}">
                                    <TextBlock Text="{Binding UpdateVersionText}" FontSize="11" FontWeight="SemiBold"/>
                                </Button>

                                <Border Margin="0,0,14,0"
                                        Padding="10,6"
                                        Background="{StaticResource SurfaceInset}"
                                        BorderBrush="{StaticResource Border}"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                    <TextBlock Text="{Binding VersionText}"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextMuted}"/>
                                </Border>

                                <Button Content="&#x2013;"
                                        Style="{StaticResource WindowChromeButton}"
                                        AutomationProperties.Name="Minimize window"
                                        Click="Minimize_Click"/>
                                <Button x:Name="MaximizeRestoreButton"
                                        Content="&#x25A1;"
                                        Margin="6,0,0,0"
                                        Style="{StaticResource WindowChromeButton}"
                                        AutomationProperties.Name="Maximize window"
                                        Click="MaximizeRestore_Click"/>
                                <Button Content="&#x2715;"
                                        Margin="6,0,0,0"
                                        Style="{StaticResource CloseWindowChromeButton}"
                                        AutomationProperties.Name="Close window"
                                        Click="Close_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid x:Name="OverviewGrid" Grid.Row="1" Margin="24,18,24,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.15*"/>
                            <ColumnDefinition x:Name="OverviewSpacerColumn" Width="20"/>
                            <ColumnDefinition Width="0.85*"/>
                        </Grid.ColumnDefinitions>

                        <Border x:Name="ReadinessCard"
                                Grid.Row="0"
                                Grid.Column="0"
                                Style="{StaticResource SurfaceCard}">
                              <Grid>
                                  <Grid.RowDefinitions>
                                      <RowDefinition Height="Auto"/>
                                      <RowDefinition Height="Auto"/>
                                      <RowDefinition Height="Auto"/>
                                      <RowDefinition Height="Auto"/>
                                      <RowDefinition Height="Auto"/>
                                  </Grid.RowDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Readiness" Style="{StaticResource SectionEyebrow}"/>
                                    <TextBlock Text="{Binding StatusText}"
                                               Margin="0,8,0,0"
                                               FontSize="28"
                                               FontWeight="SemiBold"
                                               Foreground="{Binding StatusColor, Converter={StaticResource StrToBrush}}"/>
                                    <TextBlock Text="{Binding StatusSummaryText}"
                                               Margin="0,8,0,0"
                                               Style="{StaticResource BodyCopy}"/>

                                    <Border Margin="0,14,0,0"
                                            Padding="14,12"
                                            Background="{StaticResource YellowBg}"
                                            BorderBrush="{StaticResource Border}"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Visibility="{Binding ShowViVeToolFallbackBadge, Converter={StaticResource BoolVis}}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Registry override blocked by Windows"
                                                           Foreground="{StaticResource Yellow}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"/>
                                                <TextBlock Text="Your last patch applied the feature flags, but Windows is still using the legacy driver. This is the Feb/Mar 2026 Microsoft block. The ViVeTool fallback writes to a different feature store that still works."
                                                           Margin="0,6,0,0"
                                                           Foreground="{StaticResource TextSecondary}"
                                                           FontSize="12"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                    Content="Try ViVeTool Fallback"
                                                    Margin="14,0,0,0"
                                                    VerticalAlignment="Center"
                                                    Style="{StaticResource SecondaryButton}"
                                                    ToolTip="Downloads ViVeTool from its official GitHub release, caches it in this app's tools folder, then applies feature IDs 60786016 and 48433719. Requires a restart."
                                                    IsEnabled="{Binding ButtonsEnabled}"
                                                    Command="{Binding ApplyViVeToolFallbackCommand}"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>

                                <Border Grid.Row="2"
                                        Margin="0,20,0,0"
                                        Style="{StaticResource InsetCard}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="Build"
                                                   Style="{StaticResource SectionEyebrow}"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding BuildSummaryText}"
                                                   Foreground="{StaticResource TextPrimary}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"/>

                                        <Border Grid.Row="1"
                                                Grid.ColumnSpan="2"
                                                Margin="0,12"
                                                Height="1"
                                                Background="{StaticResource Border}"/>
                                        <TextBlock Grid.Row="1"
                                                   Text="Drives"
                                                   Style="{StaticResource SectionEyebrow}"/>
                                        <TextBlock Grid.Row="1"
                                                   Grid.Column="1"
                                                   Text="{Binding DriveInventorySummaryText}"
                                                   Foreground="{StaticResource TextPrimary}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"/>

                                        <Border Grid.Row="2"
                                                Grid.ColumnSpan="2"
                                                Margin="0,-1,0,12"
                                                Height="1"
                                                Background="{StaticResource Border}"/>
                                        <TextBlock Grid.Row="2"
                                                   Text="Risk"
                                                   Margin="0,12,0,0"
                                                   Style="{StaticResource SectionEyebrow}"/>
                                        <TextBlock Grid.Row="2"
                                                   Grid.Column="1"
                                                   Margin="0,12,0,0"
                                                   Text="{Binding RiskSummaryText}"
                                                   Foreground="{StaticResource TextPrimary}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"/>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="3"
                                        Margin="0,12,0,0"
                                        Style="{StaticResource InsetCard}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock Text="Driver State" Style="{StaticResource SectionEyebrow}"/>
                                            <TextBlock Text="{Binding DriverLabelText}"
                                                       Margin="0,6,0,0"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       FontSize="13"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1"
                                                    Margin="24,0,0,0"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="Warnings" Style="{StaticResource SectionEyebrow}" HorizontalAlignment="Right"/>
                                            <TextBlock Text="{Binding WarningCount}"
                                                       Foreground="{StaticResource Yellow}"
                                                       FontSize="22"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Right"/>
                                        </StackPanel>

                                        <TextBlock Grid.ColumnSpan="2"
                                                   Margin="0,46,0,0"
                                                   Foreground="{StaticResource TextDim}"
                                                   FontSize="11"
                                                   Text="{Binding BenchLabelText}"
                                                   Visibility="{Binding BenchLabelVisible, Converter={StaticResource BoolVis}}"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <Border x:Name="ControlsCard"
                                Grid.Row="0"
                                Grid.Column="2"
                                Style="{StaticResource SurfaceCard}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Actions" Style="{StaticResource SectionEyebrow}"/>
                                    <TextBlock Text="Apply the change, confirm the result, or recover cleanly."
                                                Margin="0,8,0,0"
                                                Style="{StaticResource BodyCopy}"/>
                                </StackPanel>

                                <Border Grid.Row="1"
                                        Margin="0,18,0,0"
                                        Style="{StaticResource InsetCard}">
                                    <StackPanel>
                                            <TextBlock Text="Next step" Style="{StaticResource SectionEyebrow}"/>
                                            <TextBlock Text="{Binding NextStepTitle}"
                                                       Margin="0,8,0,0"
                                                       Foreground="{Binding NextStepColor, Converter={StaticResource StrToBrush}}"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding NextStepDescription}"
                                                       Margin="0,8,0,0"
                                                       Style="{StaticResource BodyCopy}"/>

                                            <WrapPanel Margin="0,14,0,0">
                                                <Button Content="{Binding NextStepPrimaryActionText}"
                                                        Margin="0,0,10,10"
                                                        Padding="14,8"
                                                        Style="{StaticResource ActionButton}"
                                                        AutomationProperties.Name="Recommended primary action"
                                                        Visibility="{Binding HasNextStepPrimaryAction, Converter={StaticResource BoolVis}}"
                                                        IsEnabled="{Binding NextStepPrimaryActionEnabled}"
                                                        Click="RecommendedPrimaryAction_Click"/>
                                                <Button Content="{Binding NextStepSecondaryActionText}"
                                                        Margin="0,0,0,10"
                                                        Padding="14,8"
                                                        Style="{StaticResource SecondaryButton}"
                                                        AutomationProperties.Name="Recommended secondary action"
                                                        Visibility="{Binding HasNextStepSecondaryAction, Converter={StaticResource BoolVis}}"
                                                        IsEnabled="{Binding NextStepSecondaryActionEnabled}"
                                                        Click="RecommendedSecondaryAction_Click"/>
                                            </WrapPanel>
                                            <TextBlock Text="Preparation details stay available below when you need backups, benchmarks, recovery files, or diagnostics."
                                                       Margin="0,2,0,0"
                                                       Foreground="{StaticResource TextDim}"
                                                       FontSize="11.5"
                                                       TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="2"
                                        Margin="0,18,0,0"
                                        Style="{StaticResource InsetCard}">
                                    <StackPanel>
                                        <TextBlock Text="What changes" Style="{StaticResource SectionEyebrow}"/>
                                        <TextBlock Text="{Binding ChangePlanSummaryText}"
                                                   Margin="0,8,0,0"
                                                   Style="{StaticResource BodyCopy}"/>
                                        <Expander Margin="0,14,0,0"
                                                  IsExpanded="False"
                                                  Style="{StaticResource DarkExpander}">
                                            <Expander.Header>
                                                <TextBlock Text="Change details"
                                                           FontWeight="SemiBold"/>
                                            </Expander.Header>
                                            <StackPanel>
                                                <Border Padding="12,10"
                                                        Background="{StaticResource BgMedium}"
                                                        BorderBrush="{StaticResource Border}"
                                                        BorderThickness="1"
                                                        CornerRadius="10">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasChangePlanSteps}" Value="False">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="Waiting for the readiness scan to finish before building a machine-specific plan."
                                                               Foreground="{StaticResource TextSecondary}"
                                                               FontSize="12"
                                                               TextWrapping="Wrap"/>
                                                </Border>

                                                <ItemsControl ItemsSource="{Binding ChangePlanSteps}" Margin="0,10,0,0">
                                                    <ItemsControl.Style>
                                                        <Style TargetType="ItemsControl">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasChangePlanSteps}" Value="False">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ItemsControl.Style>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Margin="0,0,0,10"
                                                                    Padding="12,10"
                                                                    Background="{StaticResource BgMedium}"
                                                                    BorderBrush="{StaticResource Border}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="10">
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding Title}"
                                                                               Foreground="{Binding ToneColor, Converter={StaticResource StrToBrush}}"
                                                                               FontSize="12.5"
                                                                               FontWeight="SemiBold"
                                                                               TextWrapping="Wrap"/>
                                                                    <TextBlock Text="{Binding Detail}"
                                                                               Margin="0,6,0,0"
                                                                               Foreground="{StaticResource TextSecondary}"
                                                                               FontSize="12"
                                                                               TextWrapping="Wrap"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Expander>
                                    </StackPanel>
                                </Border>

                                <WrapPanel Grid.Row="3"
                                           Margin="0,22,0,0"
                                           ItemHeight="48">
                                    <Button Content="{Binding ApplyButtonText}"
                                            MinWidth="220"
                                            MaxWidth="320"
                                            Margin="0,0,12,12"
                                            Background="{StaticResource GreenBg}"
                                            BorderBrush="{StaticResource Green}"
                                            Foreground="{StaticResource TextPrimary}"
                                            Style="{StaticResource ActionButton}"
                                            AutomationProperties.Name="Apply patch"
                                            IsEnabled="{Binding ApplyEnabled}"
                                            ToolTip="{Binding ApplyButtonTooltipText}"
                                            Command="{Binding ApplyPatchCommand}"/>

                                    <Button Content="Remove Patch"
                                            MinWidth="220"
                                            MaxWidth="320"
                                            Margin="0,0,0,12"
                                            Style="{StaticResource OutlinedActionButton}"
                                            AutomationProperties.Name="Remove patch"
                                            IsEnabled="{Binding RemoveEnabled}"
                                            ToolTip="{Binding RemoveButtonTooltipText}"
                                            Command="{Binding RemovePatchCommand}"/>
                                </WrapPanel>

                                  <Border Grid.Row="4"
                                          Margin="0,16,0,0"
                                          Padding="14,12"
                                          Background="{StaticResource BgMedium}"
                                          BorderBrush="{StaticResource Border}"
                                          BorderThickness="1"
                                          CornerRadius="12">
                                      <TextBlock Text="{Binding ActionReadinessText}"
                                                 Foreground="{Binding ActionReadinessColor, Converter={StaticResource StrToBrush}}"
                                                 FontSize="12"
                                                 FontWeight="SemiBold"
                                                 TextWrapping="Wrap"/>
                                  </Border>

                                  <Border Grid.Row="5"
                                          Margin="0,18,0,0"
                                          Style="{StaticResource InsetCard}">
                                      <StackPanel>
                                          <TextBlock Text="Prepare" Style="{StaticResource SectionEyebrow}"/>
                                          <TextBlock Text="Create the backups and evidence you want before touching the live driver path."
                                                     Margin="0,8,0,0"
                                                     Style="{StaticResource BodyCopy}"/>

                                          <WrapPanel Margin="0,16,0,0"
                                                     ItemHeight="40">
                                              <Button Content="Create Backup"
                                                      MinWidth="168"
                                                      MaxWidth="220"
                                                      Margin="0,0,12,12"
                                                      Style="{StaticResource SecondaryButton}"
                                                      ToolTip="Export a manual registry backup so the current state can be restored quickly if needed."
                                                      AutomationProperties.Name="Create backup"
                                                      IsEnabled="{Binding ButtonsEnabled}"
                                                      Command="{Binding RunBackupCommand}"/>
                                              <Button Content="Run Benchmark"
                                                      MinWidth="168"
                                                      MaxWidth="220"
                                                      Margin="0,0,12,12"
                                                      Style="{StaticResource SecondaryButton}"
                                                      ToolTip="Capture a machine-specific performance run for before-and-after comparison."
                                                      AutomationProperties.Name="Run benchmark"
                                                      IsEnabled="{Binding ButtonsEnabled}"
                                                      Command="{Binding RunBenchmarkCommand}"/>
                                              <Button Content="Cancel Benchmark"
                                                      MinWidth="168"
                                                      MaxWidth="220"
                                                      Margin="0,0,12,12"
                                                      Style="{StaticResource SecondaryButton}"
                                                      ToolTip="Stop the current DiskSpd run. Partial data is discarded."
                                                      AutomationProperties.Name="Cancel running benchmark"
                                                      Visibility="{Binding BenchmarkRunning, Converter={StaticResource BoolVis}}"
                                                      Command="{Binding CancelBenchmarkCommand}"/>
                                              <Button Content="Export Diagnostics"
                                                      MinWidth="168"
                                                      MaxWidth="220"
                                                      Margin="0,0,12,12"
                                                      Style="{StaticResource SecondaryButton}"
                                                      ToolTip="Save a support-ready snapshot with readiness, health, and recent activity details."
                                                      AutomationProperties.Name="Export diagnostics"
                                                      IsEnabled="{Binding ButtonsEnabled}"
                                                      Command="{Binding ExportDiagnosticsCommand}"/>
                                              <Button Content="Create Recovery Kit"
                                                      MinWidth="168"
                                                      MaxWidth="220"
                                                      Margin="0,0,0,12"
                                                      Style="{StaticResource SecondaryButton}"
                                                      ToolTip="Generate offline rollback files for Windows and WinRE before a risky restart or handoff."
                                                      AutomationProperties.Name="Create recovery kit"
                                                      IsEnabled="{Binding ButtonsEnabled}"
                                                      Command="{Binding ExportRecoveryKitCommand}"/>
                                          </WrapPanel>
                                      </StackPanel>
                                  </Border>

                                  <Border Grid.Row="6"
                                          Margin="0,18,0,0"
                                          Style="{StaticResource InsetCard}">
                                      <StackPanel>
                                          <TextBlock Text="Recent local data" Style="{StaticResource SectionEyebrow}"/>
                                          <TextBlock Text="Local backups, snapshots, and benchmarks stay close so you can see what changed and when."
                                                     Margin="0,8,0,0"
                                                     Style="{StaticResource BodyCopy}"/>
                                          <Expander Margin="0,14,0,0"
                                                    IsExpanded="False"
                                                    Style="{StaticResource DarkExpander}">
                                              <Expander.Header>
                                                  <TextBlock Text="History details"
                                                             FontWeight="SemiBold"/>
                                              </Expander.Header>
                                              <StackPanel>
                                                  <Border Padding="12,10"
                                                          Background="{StaticResource BgMedium}"
                                                          BorderBrush="{StaticResource Border}"
                                                          BorderThickness="1"
                                                          CornerRadius="10">
                                                      <StackPanel>
                                                          <TextBlock Text="Registry Backups" Style="{StaticResource SectionEyebrow}"/>
                                                          <TextBlock Text="{Binding BackupHistoryText}"
                                                                     Margin="0,6,0,0"
                                                                     Foreground="{StaticResource TextSecondary}"
                                                                     FontSize="12"
                                                                     TextWrapping="Wrap"/>
                                                      </StackPanel>
                                                  </Border>

                                                  <Border Margin="0,10,0,0"
                                                          Padding="12,10"
                                                          Background="{StaticResource BgMedium}"
                                                          BorderBrush="{StaticResource Border}"
                                                          BorderThickness="1"
                                                          CornerRadius="10">
                                                      <StackPanel>
                                                          <TextBlock Text="Change Snapshots" Style="{StaticResource SectionEyebrow}"/>
                                                          <TextBlock Text="{Binding SnapshotHistoryText}"
                                                                     Margin="0,6,0,0"
                                                                     Foreground="{StaticResource TextSecondary}"
                                                                     FontSize="12"
                                                                     TextWrapping="Wrap"/>
                                                      </StackPanel>
                                                  </Border>

                                                  <Border Margin="0,10,0,0"
                                                          Padding="12,10"
                                                          Background="{StaticResource BgMedium}"
                                                          BorderBrush="{StaticResource Border}"
                                                          BorderThickness="1"
                                                          CornerRadius="10">
                                                      <StackPanel>
                                                          <TextBlock Text="Benchmark Runs" Style="{StaticResource SectionEyebrow}"/>
                                                          <TextBlock Text="{Binding BenchmarkHistoryText}"
                                                                     Margin="0,6,0,0"
                                                                     Foreground="{StaticResource TextSecondary}"
                                                                     FontSize="12"
                                                                     TextWrapping="Wrap"/>
                                                      </StackPanel>
                                                  </Border>
                                              </StackPanel>
                                          </Expander>
                                      </StackPanel>
                                  </Border>
                              </Grid>
                          </Border>
                    </Grid>

                    <Grid x:Name="MainContentGrid" Grid.Row="2" Margin="32,22,32,0">
                        <Grid.RowDefinitions>
                            <RowDefinition x:Name="MainContentPrimaryRow" Height="*"/>
                            <RowDefinition x:Name="MainContentSecondaryRow" Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.02*"/>
                            <ColumnDefinition x:Name="MainContentSpacerColumn" Width="20"/>
                            <ColumnDefinition Width="0.98*"/>
                        </Grid.ColumnDefinitions>

                        <ScrollViewer x:Name="OverviewScrollViewer"
                                      Grid.Row="0"
                                      Grid.Column="0"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Border Style="{StaticResource SurfaceCard}" Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock Text="Readiness Checklist" Style="{StaticResource SectionEyebrow}"/>
                                        <TextBlock Text="Review the blockers before changing the driver."
                                                   Margin="0,8,0,0"
                                                   Style="{StaticResource BodyCopy}"/>

                                        <Grid Margin="0,18,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition Width="14"/>
                                                <ColumnDefinition/>
                                            </Grid.ColumnDefinitions>

                                            <ItemsControl Grid.Column="0" ItemsSource="{Binding LeftChecks}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,0,0,10"
                                                                Padding="14,12"
                                                                Background="{StaticResource BgMedium}"
                                                                BorderBrush="{StaticResource Border}"
                                                                BorderThickness="1"
                                                                CornerRadius="12"
                                                                ToolTip="{Binding Tooltip}">
                                                            <StackPanel>
                                                                <StackPanel Orientation="Horizontal">
                                                                    <Ellipse Width="9"
                                                                             Height="9"
                                                                             Margin="0,0,10,0"
                                                                             VerticalAlignment="Center"
                                                                             Fill="{Binding Color, Converter={StaticResource StrToBrush}}"/>
                                                                    <TextBlock Text="{Binding Label}"
                                                                               Foreground="{StaticResource TextSecondary}"
                                                                               FontWeight="SemiBold"/>
                                                                </StackPanel>
                                                                <TextBlock Text="{Binding Message}"
                                                                           Margin="19,8,0,0"
                                                                           Foreground="{Binding Color, Converter={StaticResource StrToBrush}}"
                                                                           FontSize="12"
                                                                           TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <ItemsControl Grid.Column="2" ItemsSource="{Binding RightChecks}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,0,0,10"
                                                                Padding="14,12"
                                                                Background="{StaticResource BgMedium}"
                                                                BorderBrush="{StaticResource Border}"
                                                                BorderThickness="1"
                                                                CornerRadius="12"
                                                                ToolTip="{Binding Tooltip}">
                                                            <StackPanel>
                                                                <StackPanel Orientation="Horizontal">
                                                                    <Ellipse Width="9"
                                                                             Height="9"
                                                                             Margin="0,0,10,0"
                                                                             VerticalAlignment="Center"
                                                                             Fill="{Binding Color, Converter={StaticResource StrToBrush}}"/>
                                                                    <TextBlock Text="{Binding Label}"
                                                                               Foreground="{StaticResource TextSecondary}"
                                                                               FontWeight="SemiBold"/>
                                                                </StackPanel>
                                                                <TextBlock Text="{Binding Message}"
                                                                           Margin="19,8,0,0"
                                                                           Foreground="{Binding Color, Converter={StaticResource StrToBrush}}"
                                                                           FontSize="12"
                                                                           TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SurfaceCard}" Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock Text="Compatibility Notes" Style="{StaticResource SectionEyebrow}"/>
                                        <TextBlock Text="{Binding AttentionSummaryText}"
                                                   Margin="0,8,0,0"
                                                   Style="{StaticResource BodyCopy}"/>

                                        <Border Margin="0,18,0,0"
                                                Padding="16,14"
                                                Background="{StaticResource SurfaceInset}"
                                                BorderBrush="{StaticResource Border}"
                                                BorderThickness="1"
                                                CornerRadius="14">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasAttentionNotes}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <TextBlock Text="No extra compatibility notes"
                                                           Foreground="{StaticResource TextPrimary}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"/>
                                                <TextBlock Text="The latest scan did not surface any vendor or platform notes beyond the standard readiness checks."
                                                           Margin="0,8,0,0"
                                                           Foreground="{StaticResource TextSecondary}"
                                                           FontSize="12"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>

                                        <ItemsControl ItemsSource="{Binding AttentionNotes}" Margin="0,18,0,0">
                                            <ItemsControl.Style>
                                                <Style TargetType="ItemsControl">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasAttentionNotes}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ItemsControl.Style>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,10"
                                                            Padding="16,14"
                                                            Background="{StaticResource BgMedium}"
                                                            BorderBrush="{StaticResource Border}"
                                                            BorderThickness="1"
                                                            CornerRadius="14">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>

                                                            <Border Width="30"
                                                                    Height="30"
                                                                    Background="{Binding ToneColor, Converter={StaticResource StrToBrush}}"
                                                                    CornerRadius="15"
                                                                    Opacity="0.16"
                                                                    VerticalAlignment="Top"/>
                                                            <Ellipse Width="9"
                                                                     Height="9"
                                                                     Margin="10.5,10.5,0,0"
                                                                     HorizontalAlignment="Left"
                                                                     VerticalAlignment="Top"
                                                                     Fill="{Binding ToneColor, Converter={StaticResource StrToBrush}}"/>

                                                            <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                                                <TextBlock Text="{Binding Title}"
                                                                           Foreground="{Binding ToneColor, Converter={StaticResource StrToBrush}}"
                                                                           FontSize="13"
                                                                           FontWeight="SemiBold"
                                                                           TextWrapping="Wrap"/>
                                                                <TextBlock Text="{Binding Detail}"
                                                                           Margin="0,8,0,0"
                                                                           Foreground="{StaticResource TextSecondary}"
                                                                           FontSize="12"
                                                                           TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SurfaceCard}" Margin="0,0,0,16">
                                    <Grid x:Name="SettingsColumnsGrid">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition/>
                                            <ColumnDefinition x:Name="SettingsSpacerColumn" Width="16"/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>

                                        <Border x:Name="PatchDefaultsCard" Grid.Row="0" Grid.Column="0" Style="{StaticResource InsetCard}">
                                            <StackPanel>
                                                <TextBlock Text="Patch Defaults" Style="{StaticResource SectionEyebrow}"/>
                                                <TextBlock Text="{Binding OptionsSummaryText}"
                                                           Margin="0,8,0,0"
                                                           Style="{StaticResource BodyCopy}"/>

                                                <TextBlock Text="Install Mode"
                                                           Margin="0,16,0,6"
                                                           Foreground="{StaticResource TextPrimary}"
                                                           FontSize="12.5"
                                                           FontWeight="SemiBold"/>
                                                <RadioButton Content="Safe Mode (recommended) — primary flag only"
                                                             Style="{StaticResource DarkRadioButton}"
                                                             GroupName="PatchProfile"
                                                             ToolTip="Writes just 735209102 plus Safe Boot entries. Swaps the driver with the lowest crash risk."
                                                             IsChecked="{Binding IsSafeModeSelected}"/>
                                                <RadioButton Content="Full Mode — all three feature flags"
                                                             Style="{StaticResource DarkRadioButton}"
                                                             GroupName="PatchProfile"
                                                             ToolTip="Adds 1853569164 (UxAccOptimization) and 156965516 (Standalone_Future). Higher peak performance on some drives, higher BSOD risk on others."
                                                             IsChecked="{Binding IsFullModeSelected}"/>
                                                <TextBlock Text="{Binding PatchProfileHelpText}"
                                                           Margin="0,8,0,0"
                                                           Foreground="{StaticResource TextMuted}"
                                                           FontSize="11.5"
                                                           TextWrapping="Wrap"/>

                                                <CheckBox Content="Include Microsoft Server 2025 compatibility key"
                                                          Style="{StaticResource DarkCheckBox}"
                                                          IsChecked="{Binding IncludeServerKey}"/>
                                                <CheckBox Content="Skip confirmation warnings for expert runs"
                                                          Style="{StaticResource DarkCheckBox}"
                                                          IsChecked="{Binding SkipWarnings}"/>

                                                <Border Margin="0,14,0,0"
                                                        Padding="14,12"
                                                        Background="{StaticResource SurfaceInset}"
                                                        BorderBrush="{StaticResource Border}"
                                                        BorderThickness="1"
                                                        CornerRadius="12">
                                                    <TextBlock Text="Safe Mode is still the safest default for most systems. Add the Server 2025 key only when you need the broader compatibility path."
                                                               Foreground="{StaticResource TextSecondary}"
                                                               FontSize="12"
                                                               TextWrapping="Wrap"/>
                                                </Border>

                                                <Border Margin="0,10,0,0"
                                                        Padding="14,12"
                                                        Background="{StaticResource YellowBg}"
                                                        BorderBrush="{StaticResource Border}"
                                                        BorderThickness="1"
                                                        CornerRadius="12">
                                                    <TextBlock Text="Heads-up for gamers: nvmedisk.sys does not honor BypassIO, so DirectStorage titles fall back to the slower path. Skip the patch on your gaming rig, or keep a one-click removal ready."
                                                               Foreground="{StaticResource Yellow}"
                                                               FontSize="12"
                                                               TextWrapping="Wrap"/>
                                                </Border>
                                            </StackPanel>
                                        </Border>

                                        <Border x:Name="AuditAlertsCard" Grid.Row="0" Grid.Column="2" Style="{StaticResource InsetCard}">
                                            <StackPanel>
                                                <TextBlock Text="Audit &amp; Alerts" Style="{StaticResource SectionEyebrow}"/>
                                                <TextBlock Text="{Binding PreferenceSummaryText}"
                                                           Margin="0,8,0,0"
                                                           Style="{StaticResource BodyCopy}"/>

                                                <CheckBox Content="Auto-save activity log on exit"
                                                          Style="{StaticResource DarkCheckBox}"
                                                          IsChecked="{Binding AutoSaveLog}"/>
                                                <CheckBox Content="Show toast notifications"
                                                          Style="{StaticResource DarkCheckBox}"
                                                          IsChecked="{Binding EnableToasts}"/>
                                                <CheckBox Content="Write audit entries to Windows Event Log"
                                                          Style="{StaticResource DarkCheckBox}"
                                                          IsChecked="{Binding WriteEventLog}"/>

                                                <WrapPanel x:Name="RestartDelayPanel"
                                                           Margin="0,14,0,0"
                                                           VerticalAlignment="Center">
                                                    <TextBlock Text="Restart delay"
                                                               VerticalAlignment="Center"
                                                               Foreground="{StaticResource TextSecondary}"
                                                               FontWeight="SemiBold"/>
                                                    <TextBox Width="72"
                                                             Margin="12,0,10,0"
                                                             Style="{StaticResource DarkTextBox}"
                                                             AutomationProperties.Name="Restart delay in seconds"
                                                             ToolTip="Use a value between 5 and 300 seconds for post-patch restart countdowns."
                                                             Text="{Binding RestartDelayText, UpdateSourceTrigger=LostFocus}"
                                                             VerticalContentAlignment="Center"/>
                                                    <TextBlock Text="seconds"
                                                               VerticalAlignment="Center"
                                                               Foreground="{StaticResource TextDim}"/>
                                                </WrapPanel>

                                                <WrapPanel x:Name="PreferenceActionsPanel"
                                                           Margin="0,14,0,0">
                                                    <Button Content="Open Data"
                                                            Margin="0,0,10,10"
                                                            HorizontalAlignment="Left"
                                                            Style="{StaticResource SecondaryButton}"
                                                            AutomationProperties.Name="Open data folder"
                                                            ToolTip="Open the working folder that stores logs, exports, backups, and diagnostics."
                                                            Command="{Binding OpenDataFolderCommand}"/>
                                                    <Button Content="Restore Defaults"
                                                            Margin="0,0,0,10"
                                                            HorizontalAlignment="Left"
                                                            Style="{StaticResource SecondaryButton}"
                                                            AutomationProperties.Name="Restore recommended defaults"
                                                            ToolTip="Restore the app's recommended safety-first settings."
                                                            Command="{Binding UseRecommendedSetupCommand}"/>
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource SurfaceCard}" Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock Text="Storage" Style="{StaticResource SectionEyebrow}"/>
                                        <TextBlock Text="{Binding DriveInventorySummaryText}"
                                                   Margin="0,8,0,0"
                                                   Style="{StaticResource BodyCopy}"/>

                                        <TextBlock Margin="0,18,0,0"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextDim}"
                                                   Text="No drive data came back from the latest scan. Refresh readiness or confirm the app still has administrator access.">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasDriveData}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <Expander Margin="0,16,0,0"
                                                  IsExpanded="False">
                                            <Expander.Style>
                                                <Style TargetType="Expander" BasedOn="{StaticResource DarkExpander}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasDriveData}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Expander.Style>
                                            <Expander.Header>
                                                <TextBlock Text="Drive details"
                                                           FontWeight="SemiBold"/>
                                            </Expander.Header>
                                            <ItemsControl ItemsSource="{Binding Drives}" Margin="0,8,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,0,0,10"
                                                                Padding="14,12"
                                                                Background="{StaticResource BgMedium}"
                                                                BorderBrush="{StaticResource Border}"
                                                                BorderThickness="1"
                                                                CornerRadius="12">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="18"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>

                                                                <StackPanel>
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <Ellipse Width="10"
                                                                                 Height="10"
                                                                                 Margin="0,0,10,0"
                                                                                 VerticalAlignment="Center"
                                                                                 Fill="{Binding DotColor, Converter={StaticResource StrToBrush}}"/>
                                                                        <TextBlock Text="{Binding Name}"
                                                                                   Foreground="{StaticResource TextPrimary}"
                                                                                   FontSize="13"
                                                                                   FontWeight="SemiBold"
                                                                                   TextTrimming="CharacterEllipsis"/>
                                                                    </StackPanel>
                                                                    <TextBlock Text="{Binding Size}"
                                                                               Margin="20,6,0,0"
                                                                               Foreground="{StaticResource TextDim}"
                                                                               FontSize="12"/>
                                                                    <WrapPanel Margin="20,8,0,0">
                                                                        <TextBlock Text="{Binding Temperature, StringFormat=Temp {0}}"
                                                                                   Margin="0,0,12,6"
                                                                                   Foreground="{Binding TempColor, Converter={StaticResource StrToBrush}}"
                                                                                   FontSize="11.5"
                                                                                   Visibility="{Binding ShowTemp, Converter={StaticResource BoolVis}}"/>
                                                                        <TextBlock Text="{Binding Wear, StringFormat=Health {0}}"
                                                                                   Margin="0,0,12,6"
                                                                                   Foreground="{Binding WearColor, Converter={StaticResource StrToBrush}}"
                                                                                   FontSize="11.5"
                                                                                   ToolTip="{Binding SmartTooltip}"
                                                                                   Visibility="{Binding ShowWear, Converter={StaticResource BoolVis}}"/>
                                                                        <TextBlock Text="{Binding Firmware, StringFormat=FW {0}}"
                                                                                   Margin="0,0,0,6"
                                                                                   Foreground="{StaticResource TextMuted}"
                                                                                   FontSize="11.5"
                                                                                   Visibility="{Binding ShowFirmware, Converter={StaticResource BoolVis}}"/>
                                                                    </WrapPanel>
                                                                </StackPanel>

                                                                <WrapPanel Grid.Column="2"
                                                                           HorizontalAlignment="Right"
                                                                           VerticalAlignment="Top"
                                                                           ItemHeight="28">
                                                                    <Border Margin="0,0,6,6"
                                                                            Padding="8,4"
                                                                            Background="{Binding BusPillBg, Converter={StaticResource StrToBrush}}"
                                                                            CornerRadius="999">
                                                                        <TextBlock Text="{Binding BusType}"
                                                                                   Foreground="{Binding BusPillFg, Converter={StaticResource StrToBrush}}"
                                                                                   FontSize="10.5"
                                                                                   FontWeight="SemiBold"/>
                                                                    </Border>

                                                                    <Border Margin="0,0,6,6"
                                                                            Padding="8,4"
                                                                            Background="{StaticResource YellowBg}"
                                                                            CornerRadius="999"
                                                                            Visibility="{Binding IsBoot, Converter={StaticResource BoolVis}}">
                                                                        <TextBlock Text="Boot"
                                                                                   Foreground="{StaticResource Yellow}"
                                                                                   FontSize="10.5"
                                                                                   FontWeight="SemiBold"/>
                                                                    </Border>

                                                                    <Border Margin="0,0,0,6"
                                                                            Padding="8,4"
                                                                            Background="{Binding DriverBadgeBg, Converter={StaticResource StrToBrush}}"
                                                                            CornerRadius="999"
                                                                            Visibility="{Binding ShowDriverBadge, Converter={StaticResource BoolVis}}">
                                                                        <TextBlock Text="{Binding DriverBadgeText}"
                                                                                   Foreground="{Binding DriverBadgeFg, Converter={StaticResource StrToBrush}}"
                                                                                   FontSize="10.5"
                                                                                   FontWeight="SemiBold"/>
                                                                    </Border>
                                                                </WrapPanel>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Expander>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SurfaceCard}">
                                    <StackPanel>
                                        <TextBlock Text="Technical details" Style="{StaticResource SectionEyebrow}"/>
                                        <TextBlock Text="Expand the exact keys only when you want to inspect the change set behind the patch."
                                                   Margin="0,8,0,0"
                                                   Style="{StaticResource BodyCopy}"/>

                                        <Grid Margin="0,16,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>

                                            <Expander Grid.Column="0"
                                                      IsExpanded="False"
                                                      Style="{StaticResource DarkExpander}">
                                                <Expander.Header>
                                                    <TextBlock Text="Patch keys"
                                                               FontWeight="SemiBold"/>
                                                </Expander.Header>
                                                <StackPanel>
                                                    <TextBlock Text="Feature flags that enable the native path and its related optimizations."
                                                               Style="{StaticResource BodyCopy}"/>
                                                    <ItemsControl ItemsSource="{Binding RegistryFlags}" Margin="0,12,0,0">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Margin="0,0,0,10"
                                                                        Padding="14,12"
                                                                        Background="{StaticResource BgMedium}"
                                                                        BorderBrush="{StaticResource Border}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="12">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                            <ColumnDefinition Width="120"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                        </Grid.ColumnDefinitions>

                                                                        <Ellipse Width="9"
                                                                                 Height="9"
                                                                                 Margin="0,0,10,0"
                                                                                 VerticalAlignment="Center"
                                                                                 Fill="{Binding DotColor, Converter={StaticResource StrToBrush}}"/>
                                                                        <TextBlock Grid.Column="1"
                                                                                   Text="{Binding Id}"
                                                                                   Foreground="{StaticResource TextPrimary}"
                                                                                   FontFamily="Cascadia Code,Consolas"
                                                                                   FontSize="11"
                                                                                   FontWeight="SemiBold"/>
                                                                        <TextBlock Grid.Column="2"
                                                                                   Text="{Binding Name}"
                                                                                   Foreground="{StaticResource TextMuted}"
                                                                                   FontSize="12"
                                                                                   TextWrapping="Wrap"/>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Expander>

                                            <Expander Grid.Column="2"
                                                      IsExpanded="False"
                                                      Style="{StaticResource DarkExpander}">
                                                <Expander.Header>
                                                    <TextBlock Text="Recovery keys"
                                                               FontWeight="SemiBold"/>
                                                </Expander.Header>
                                                <StackPanel>
                                                    <TextBlock Text="Safe Mode safeguards that keep offline rollback usable if you need it."
                                                               Style="{StaticResource BodyCopy}"/>
                                                    <ItemsControl ItemsSource="{Binding SafeBootFlags}" Margin="0,12,0,0">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Margin="0,0,0,10"
                                                                        Padding="14,12"
                                                                        Background="{StaticResource BgMedium}"
                                                                        BorderBrush="{StaticResource Border}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="12">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                            <ColumnDefinition Width="120"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                        </Grid.ColumnDefinitions>

                                                                        <Ellipse Width="9"
                                                                                 Height="9"
                                                                                 Margin="0,0,10,0"
                                                                                 VerticalAlignment="Center"
                                                                                 Fill="{Binding DotColor, Converter={StaticResource StrToBrush}}"/>
                                                                        <TextBlock Grid.Column="1"
                                                                                   Text="{Binding Id}"
                                                                                   Foreground="{StaticResource TextPrimary}"
                                                                                   FontFamily="Cascadia Code,Consolas"
                                                                                   FontSize="11"
                                                                                   FontWeight="SemiBold"/>
                                                                        <TextBlock Grid.Column="2"
                                                                                   Text="{Binding Name}"
                                                                                   Foreground="{StaticResource TextMuted}"
                                                                                   FontSize="12"
                                                                                   TextWrapping="Wrap"/>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Expander>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <GridSplitter x:Name="MainContentSplitter"
                                      Grid.Row="0"
                                      Grid.Column="1"
                                      Width="6"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Stretch"
                                      Background="Transparent"
                                      Cursor="SizeWE"
                                      ShowsPreview="True"/>

                        <Border x:Name="WorkspaceSurface"
                                Grid.Row="0"
                                Grid.Column="2"
                                Style="{StaticResource SurfaceCard}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Validation" Style="{StaticResource SectionEyebrow}"/>
                                    <TextBlock Text="Activity shows what happened. Benchmarks and telemetry help validate the result. Recovery keeps rollback nearby."
                                               Margin="0,8,0,0"
                                               Style="{StaticResource BodyCopy}"/>
                                </StackPanel>

                                <TabControl x:Name="WorkspaceTabs"
                                            Grid.Row="1"
                                            Margin="0,18,0,0"
                                            Style="{StaticResource WorkspaceTabControl}"
                                            KeyboardNavigation.TabNavigation="Cycle"
                                            AutomationProperties.Name="Workspace tabs"
                                            SelectionChanged="WorkspaceTabs_SelectionChanged">
                                    <TabItem Style="{StaticResource WorkspaceTabItem}" Header="Activity">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel>
                                                    <TextBlock Text="Review the local audit trail for checks, changes, and restart prompts."
                                                               Style="{StaticResource BodyCopy}"/>
                                                    <TextBlock Text="{Binding LogRetentionText}"
                                                               Margin="0,8,0,0"
                                                               Foreground="{StaticResource TextDim}"
                                                               FontSize="11"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="16,0,0,0">
                                                    <Button Content="Copy"
                                                            Margin="0,0,8,0"
                                                            Style="{StaticResource SecondaryButton}"
                                                            AutomationProperties.Name="Copy activity log"
                                                            Command="{Binding CopyLogCommand}"/>
                                                    <Button Content="Export"
                                                            Margin="0,0,8,0"
                                                            Style="{StaticResource SecondaryButton}"
                                                            AutomationProperties.Name="Export activity log"
                                                            Command="{Binding ExportLogCommand}"/>
                                                    <Button Content="Clear"
                                                            Style="{StaticResource SecondaryButton}"
                                                            AutomationProperties.Name="Clear activity log"
                                                            Click="ClearLog_Click"/>
                                                </StackPanel>
                                            </Grid>

                                            <WrapPanel Grid.Row="1" Margin="0,18,0,0">
                                                <Border Width="120" Margin="0,0,12,12" Style="{StaticResource InsetCard}">
                                                    <StackPanel>
                                                        <TextBlock Text="Entries" Style="{StaticResource SectionEyebrow}"/>
                                                        <TextBlock Text="{Binding LogEntryCount}"
                                                                   Margin="0,8,0,0"
                                                                   Foreground="{StaticResource TextPrimary}"
                                                                   FontSize="24"
                                                                   FontWeight="SemiBold"/>
                                                    </StackPanel>
                                                </Border>

                                                <Border Width="120" Margin="0,0,12,12" Style="{StaticResource InsetCard}">
                                                    <StackPanel>
                                                        <TextBlock Text="Warnings" Style="{StaticResource SectionEyebrow}"/>
                                                        <TextBlock Text="{Binding LogWarningCount}"
                                                                   Margin="0,8,0,0"
                                                                   Foreground="{StaticResource Yellow}"
                                                                   FontSize="24"
                                                                   FontWeight="SemiBold"/>
                                                    </StackPanel>
                                                </Border>

                                                <Border Width="120" Margin="0,0,12,12" Style="{StaticResource InsetCard}">
                                                    <StackPanel>
                                                        <TextBlock Text="Errors" Style="{StaticResource SectionEyebrow}"/>
                                                        <TextBlock Text="{Binding LogErrorCount}"
                                                                   Margin="0,8,0,0"
                                                                   Foreground="{StaticResource Red}"
                                                                   FontSize="24"
                                                                   FontWeight="SemiBold"/>
                                                    </StackPanel>
                                                </Border>

                                                <Border MinWidth="260" MaxWidth="420" Margin="0,0,0,12" Style="{StaticResource InsetCard}">
                                                    <StackPanel>
                                                        <TextBlock Text="Audit Snapshot" Style="{StaticResource SectionEyebrow}"/>
                                                        <TextBlock Text="{Binding ActivitySummaryText}"
                                                                   Margin="0,8,0,0"
                                                                   Foreground="{StaticResource TextPrimary}"
                                                                   FontSize="13"
                                                                   FontWeight="SemiBold"
                                                                   TextWrapping="Wrap"/>
                                                        <TextBlock Text="{Binding LatestActivityText}"
                                                                   Margin="0,8,0,0"
                                                                   Foreground="{StaticResource TextSecondary}"
                                                                   FontSize="12"
                                                                   TextWrapping="Wrap"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   MaxHeight="34"/>
                                                    </StackPanel>
                                                </Border>
                                            </WrapPanel>

                                            <Border Grid.Row="2"
                                                    Margin="0,18,0,0"
                                                    Style="{StaticResource InsetCard}">
                                                <Grid>
                                                    <ScrollViewer x:Name="LogScroller" VerticalScrollBarVisibility="Auto">
                                                        <TextBox x:Name="LogOutput"
                                                                 Text="{Binding LogText, Mode=OneWay}"
                                                                 Background="Transparent"
                                                                 BorderThickness="0"
                                                                 CaretBrush="Transparent"
                                                                 AutomationProperties.Name="Activity log output"
                                                                 FontFamily="Cascadia Code,Consolas,Courier New"
                                                                 FontSize="11.5"
                                                                 Foreground="{StaticResource TextSecondary}"
                                                                 IsReadOnly="True"
                                                                 IsTabStop="False"
                                                                 Padding="0"
                                                                 SelectionBrush="{StaticResource AccentBg}"
                                                                 TextChanged="LogOutput_TextChanged"
                                                                 TextWrapping="Wrap">
                                                            <TextBox.ContextMenu>
                                                                <ContextMenu>
                                                                    <MenuItem Header="Copy Selection" Click="CopySelection_Click"/>
                                                                    <MenuItem Header="Select All" Click="SelectAll_Click"/>
                                                                    <Separator/>
                                                                    <MenuItem Header="Copy Entire Log" Command="{Binding CopyLogCommand}"/>
                                                                    <MenuItem Header="Clear Log" Click="ClearLog_Click"/>
                                                                </ContextMenu>
                                                            </TextBox.ContextMenu>
                                                        </TextBox>
                                                    </ScrollViewer>

                                                    <Border IsHitTestVisible="False">
                                                        <Border.Style>
                                                            <Style TargetType="Border" BasedOn="{StaticResource EmptyStateCard}">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding LogEntryCount}" Value="0">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <Border Width="48"
                                                                    Height="48"
                                                                    Background="{StaticResource AccentBg}"
                                                                    BorderBrush="{StaticResource BorderLight}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="24">
                                                                <TextBlock Text="i"
                                                                           Foreground="{StaticResource Accent}"
                                                                           FontSize="20"
                                                                           FontWeight="SemiBold"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"/>
                                                            </Border>
                                                            <TextBlock Margin="0,16,0,0"
                                                                       Text="No activity captured yet"
                                                                       Style="{StaticResource EmptyStateTitle}"/>
                                                            <TextBlock Text="Run checks or actions and this workspace will keep a local, exportable audit trail of what happened."
                                                                       Margin="0,10,0,0"
                                                                       Style="{StaticResource EmptyStateBody}"/>
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>
                                            </Border>

                                            <StackPanel Grid.Row="3" Margin="0,16,0,0">
                                                <ProgressBar Height="8"
                                                             Value="{Binding ProgressValue}"
                                                             Foreground="{StaticResource Accent}"
                                                             Template="{StaticResource RoundProgress}"
                                                             Visibility="{Binding ProgressVisible, Converter={StaticResource BoolVis}}"/>
                                                <TextBlock Text="{Binding ProgressText}"
                                                           Margin="0,8,0,0"
                                                           Foreground="{StaticResource TextDim}"
                                                           FontSize="11"
                                                           Visibility="{Binding ProgressVisible, Converter={StaticResource BoolVis}}"/>
                                            </StackPanel>
                                        </Grid>
                                    </TabItem>

                                    <TabItem Style="{StaticResource WorkspaceTabItem}" Header="Benchmark">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <Border Style="{StaticResource InsetCard}">
                                                <TextBlock Text="Validate the patch with a before-and-after run from this machine."
                                                           Style="{StaticResource BodyCopy}"/>
                                            </Border>

                                            <Border x:Name="BenchmarkEmptyState"
                                                    Grid.Row="1"
                                                    Margin="0,16,0,0"
                                                    Style="{StaticResource EmptyStateCard}">
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <Border Width="48"
                                                            Height="48"
                                                            Background="{StaticResource AccentBg}"
                                                            BorderBrush="{StaticResource BorderLight}"
                                                            BorderThickness="1"
                                                            CornerRadius="24">
                                                        <TextBlock Text="B"
                                                                   Foreground="{StaticResource Accent}"
                                                                   FontSize="20"
                                                                   FontWeight="SemiBold"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                    <TextBlock Margin="0,16,0,0"
                                                               Text="No benchmark history yet"
                                                               Style="{StaticResource EmptyStateTitle}"/>
                                                    <TextBlock Text="Run a benchmark before or after applying the patch to build a machine-specific comparison."
                                                               Margin="0,10,0,0"
                                                               Style="{StaticResource EmptyStateBody}"/>
                                                    <Button Content="Run Benchmark"
                                                            Margin="0,18,0,0"
                                                            HorizontalAlignment="Center"
                                                            Style="{StaticResource ActionButton}"
                                                            AutomationProperties.Name="Run first benchmark"
                                                            Command="{Binding RunBenchmarkCommand}"/>
                                                </StackPanel>
                                            </Border>

                                            <Grid x:Name="BenchmarkWorkspacePanel"
                                                  Grid.Row="1"
                                                  Margin="0,16,0,0"
                                                  Visibility="Collapsed">
                                                <views:BenchmarkComparisonView x:Name="BenchmarkView"/>
                                            </Grid>
                                        </Grid>
                                    </TabItem>

                                    <TabItem Style="{StaticResource WorkspaceTabItem}" Header="Telemetry">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <Border Style="{StaticResource InsetCard}">
                                                <WrapPanel>
                                                    <StackPanel MaxWidth="460"
                                                                Margin="0,0,18,12">
                                                        <TextBlock Text="Capture a fresh SMART snapshot and compare it against recent local history."
                                                                   Style="{StaticResource BodyCopy}"/>
                                                    </StackPanel>

                                                    <Button Margin="0,0,0,12"
                                                            VerticalAlignment="Center"
                                                            Content="Capture Snapshot"
                                                            Style="{StaticResource SecondaryButton}"
                                                            AutomationProperties.Name="Capture telemetry snapshot"
                                                            ToolTip="Poll the currently selected NVMe drive again and refresh the local telemetry view."
                                                            Click="RefreshTelemetry_Click"/>
                                                </WrapPanel>
                                            </Border>

                                            <Border x:Name="TelemetryEmptyState"
                                                    Grid.Row="1"
                                                    Margin="0,16,0,0"
                                                    Style="{StaticResource EmptyStateCard}">
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <Border Width="48"
                                                            Height="48"
                                                            Background="{StaticResource AccentBg}"
                                                            BorderBrush="{StaticResource BorderLight}"
                                                            BorderThickness="1"
                                                            CornerRadius="24">
                                                        <TextBlock Text="T"
                                                                   Foreground="{StaticResource Accent}"
                                                                   FontSize="20"
                                                                   FontWeight="SemiBold"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                    <TextBlock Margin="0,16,0,0"
                                                               Text="No NVMe telemetry source available"
                                                               Style="{StaticResource EmptyStateTitle}"/>
                                                    <TextBlock Text="This workspace activates when the current scan finds at least one NVMe drive that Windows can surface for health checks."
                                                               Margin="0,10,0,0"
                                                               Style="{StaticResource EmptyStateBody}"/>
                                                    <Button Content="Refresh Readiness"
                                                            Margin="0,18,0,0"
                                                            HorizontalAlignment="Center"
                                                            Style="{StaticResource SecondaryButton}"
                                                            AutomationProperties.Name="Refresh readiness checks"
                                                            ToolTip="Run readiness checks again and rescan hardware inventory (F5)."
                                                            Command="{Binding RefreshCommand}"/>
                                                </StackPanel>
                                            </Border>

                                            <Grid x:Name="TelemetryWorkspacePanel"
                                                  Grid.Row="1"
                                                  Margin="0,16,0,0"
                                                  Visibility="Collapsed">
                                                <views:TelemetryView x:Name="TelemetryPanelControl"/>
                                            </Grid>
                                        </Grid>
                                    </TabItem>

                                    <TabItem Style="{StaticResource WorkspaceTabItem}" Header="Recovery">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <Border Style="{StaticResource InsetCard}">
                                                <WrapPanel>
                                                    <StackPanel MaxWidth="430"
                                                                Margin="0,0,18,12">
                                                        <TextBlock Text="Keep rollback files and support exports close before you restart or hand off the machine."
                                                                   Style="{StaticResource BodyCopy}"/>
                                                        <TextBlock Text="{Binding RecoveryWorkspaceSummaryText}"
                                                                   Margin="0,10,0,0"
                                                                   Foreground="{StaticResource TextPrimary}"
                                                                   FontSize="13"
                                                                   FontWeight="SemiBold"
                                                                   TextWrapping="Wrap"/>
                                                    </StackPanel>

                                                    <WrapPanel VerticalAlignment="Center">
                                                        <Button Content="Refresh Assets"
                                                                Margin="0,0,10,10"
                                                                Style="{StaticResource SecondaryButton}"
                                                                AutomationProperties.Name="Refresh recovery assets"
                                                                ToolTip="Rescan the working folder for recovery kits, verification scripts, and diagnostics."
                                                                Command="{Binding RefreshRecoveryAssetsCommand}"/>
                                                        <Button Content="Open Data Folder"
                                                                Margin="0,0,0,10"
                                                                Style="{StaticResource SecondaryButton}"
                                                                AutomationProperties.Name="Open data folder"
                                                                ToolTip="Open the working folder that stores recovery exports and diagnostics."
                                                                Command="{Binding OpenDataFolderCommand}"/>
                                                    </WrapPanel>
                                                </WrapPanel>
                                            </Border>

                                            <WrapPanel Grid.Row="1" Margin="0,16,0,0">
                                                <Border MinWidth="220" MaxWidth="260" Margin="0,0,12,12" Style="{StaticResource InsetCard}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>

                                                        <Border Width="32"
                                                                Height="32"
                                                                Background="{Binding PreparationStageColor, Converter={StaticResource StrToBrush}}"
                                                                CornerRadius="16"
                                                                Opacity="0.16"
                                                                VerticalAlignment="Top"/>
                                                        <Ellipse Width="9"
                                                                 Height="9"
                                                                 Margin="11,11,0,0"
                                                                 Fill="{Binding PreparationStageColor, Converter={StaticResource StrToBrush}}"
                                                                 HorizontalAlignment="Left"
                                                                 VerticalAlignment="Top"/>

                                                        <StackPanel Grid.Column="1" Margin="14,0,0,0">
                                                            <TextBlock Text="Prepare" Style="{StaticResource SectionEyebrow}"/>
                                                            <TextBlock Text="{Binding PreparationStageStateText}"
                                                                       Margin="0,8,0,0"
                                                                       Foreground="{Binding PreparationStageColor, Converter={StaticResource StrToBrush}}"
                                                                       FontSize="16"
                                                                       FontWeight="SemiBold"
                                                                       TextWrapping="Wrap"/>
                                                            <TextBlock Text="{Binding PreparationStageDetailText}"
                                                                       Margin="0,8,0,0"
                                                                       Style="{StaticResource BodyCopy}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>

                                                <Border MinWidth="220" MaxWidth="260" Margin="0,0,12,12" Style="{StaticResource InsetCard}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>

                                                        <Border Width="32"
                                                                Height="32"
                                                                Background="{Binding RestartStageColor, Converter={StaticResource StrToBrush}}"
                                                                CornerRadius="16"
                                                                Opacity="0.16"
                                                                VerticalAlignment="Top"/>
                                                        <Ellipse Width="9"
                                                                 Height="9"
                                                                 Margin="11,11,0,0"
                                                                 Fill="{Binding RestartStageColor, Converter={StaticResource StrToBrush}}"
                                                                 HorizontalAlignment="Left"
                                                                 VerticalAlignment="Top"/>

                                                        <StackPanel Grid.Column="1" Margin="14,0,0,0">
                                                            <TextBlock Text="Restart" Style="{StaticResource SectionEyebrow}"/>
                                                            <TextBlock Text="{Binding RestartStageStateText}"
                                                                       Margin="0,8,0,0"
                                                                       Foreground="{Binding RestartStageColor, Converter={StaticResource StrToBrush}}"
                                                                       FontSize="16"
                                                                       FontWeight="SemiBold"
                                                                       TextWrapping="Wrap"/>
                                                            <TextBlock Text="{Binding RestartStageDetailText}"
                                                                       Margin="0,8,0,0"
                                                                       Style="{StaticResource BodyCopy}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>

                                                <Border MinWidth="220" MaxWidth="260" Margin="0,0,0,12" Style="{StaticResource InsetCard}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>

                                                        <Border Width="32"
                                                                Height="32"
                                                                Background="{Binding ValidationStageColor, Converter={StaticResource StrToBrush}}"
                                                                CornerRadius="16"
                                                                Opacity="0.16"
                                                                VerticalAlignment="Top"/>
                                                        <Ellipse Width="9"
                                                                 Height="9"
                                                                 Margin="11,11,0,0"
                                                                 Fill="{Binding ValidationStageColor, Converter={StaticResource StrToBrush}}"
                                                                 HorizontalAlignment="Left"
                                                                 VerticalAlignment="Top"/>

                                                        <StackPanel Grid.Column="1" Margin="14,0,0,0">
                                                            <TextBlock Text="Validate" Style="{StaticResource SectionEyebrow}"/>
                                                            <TextBlock Text="{Binding ValidationStageStateText}"
                                                                       Margin="0,8,0,0"
                                                                       Foreground="{Binding ValidationStageColor, Converter={StaticResource StrToBrush}}"
                                                                       FontSize="16"
                                                                       FontWeight="SemiBold"
                                                                       TextWrapping="Wrap"/>
                                                            <TextBlock Text="{Binding ValidationStageDetailText}"
                                                                       Margin="0,8,0,0"
                                                                       Style="{StaticResource BodyCopy}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </WrapPanel>

                                            <Grid Grid.Row="2" Margin="0,16,0,0">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <Border Style="{StaticResource InsetCard}" Margin="0,0,0,14">
                                                    <StackPanel>
                                                        <WrapPanel>
                                                            <StackPanel MaxWidth="500"
                                                                        Margin="0,0,18,10">
                                                                <TextBlock Text="Recovery Kit" Style="{StaticResource SectionEyebrow}"/>
                                                                <TextBlock Text="Offline rollback files for Windows and WinRE."
                                                                           Margin="0,8,0,0"
                                                                           Style="{StaticResource BodyCopy}"/>
                                                            </StackPanel>

                                                            <Border Margin="0,0,0,10">
                                                                <Border.Style>
                                                                    <Style TargetType="Border" BasedOn="{StaticResource StatusChipBorder}">
                                                                        <Setter Property="Background" Value="{StaticResource YellowBg}"/>
                                                                        <Setter Property="BorderBrush" Value="{StaticResource Yellow}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding HasRecoveryKit}" Value="True">
                                                                                <Setter Property="Background" Value="{StaticResource GreenBg}"/>
                                                                                <Setter Property="BorderBrush" Value="{StaticResource Green}"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <TextBlock>
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource StatusChipText}">
                                                                            <Setter Property="Text" Value="Missing"/>
                                                                            <Setter Property="Foreground" Value="{StaticResource Yellow}"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding HasRecoveryKit}" Value="True">
                                                                                    <Setter Property="Text" Value="Ready"/>
                                                                                    <Setter Property="Foreground" Value="{StaticResource Green}"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Border>
                                                        </WrapPanel>

                                                        <TextBlock Text="{Binding RecoveryKitStatusText}"
                                                                   Margin="0,2,0,0"
                                                                   Foreground="{StaticResource TextSecondary}"
                                                                   FontSize="12"
                                                                   TextWrapping="Wrap"/>

                                                        <WrapPanel Margin="0,16,0,0"
                                                                   ItemHeight="40">
                                                            <Button Content="Open Kit Folder"
                                                                    Margin="0,0,10,10"
                                                                    Style="{StaticResource SecondaryButton}"
                                                                    ToolTip="Open the most recent recovery kit folder. Available after a kit has been generated or detected."
                                                                    AutomationProperties.Name="Open recovery kit folder"
                                                                    IsEnabled="{Binding HasRecoveryKit}"
                                                                    Command="{Binding OpenLatestRecoveryKitCommand}"/>
                                                            <Button Content="Create Fresh Copy"
                                                                    Margin="0,0,0,10"
                                                                    Style="{StaticResource SecondaryButton}"
                                                                    ToolTip="Export a fresh recovery kit so rollback stays available even if this install becomes unbootable."
                                                                    AutomationProperties.Name="Create recovery kit copy"
                                                                    IsEnabled="{Binding ButtonsEnabled}"
                                                                    Command="{Binding ExportRecoveryKitCommand}"/>
                                                        </WrapPanel>
                                                    </StackPanel>
                                                </Border>

                                                <Border Grid.Row="1" Style="{StaticResource InsetCard}" Margin="0,0,0,14">
                                                    <StackPanel>
                                                        <WrapPanel>
                                                            <StackPanel MaxWidth="500"
                                                                        Margin="0,0,18,10">
                                                                <TextBlock Text="Verification Script" Style="{StaticResource SectionEyebrow}"/>
                                                                <TextBlock Text="Readable post-reboot confirmation for the patch and Safe Mode protections."
                                                                           Margin="0,8,0,0"
                                                                           Style="{StaticResource BodyCopy}"/>
                                                            </StackPanel>

                                                            <Border Margin="0,0,0,10">
                                                                <Border.Style>
                                                                    <Style TargetType="Border" BasedOn="{StaticResource StatusChipBorder}">
                                                                        <Setter Property="Background" Value="{StaticResource YellowBg}"/>
                                                                        <Setter Property="BorderBrush" Value="{StaticResource Yellow}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding HasVerificationScript}" Value="True">
                                                                                <Setter Property="Background" Value="{StaticResource GreenBg}"/>
                                                                                <Setter Property="BorderBrush" Value="{StaticResource Green}"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <TextBlock>
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource StatusChipText}">
                                                                            <Setter Property="Text" Value="Missing"/>
                                                                            <Setter Property="Foreground" Value="{StaticResource Yellow}"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding HasVerificationScript}" Value="True">
                                                                                    <Setter Property="Text" Value="Ready"/>
                                                                                    <Setter Property="Foreground" Value="{StaticResource Green}"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Border>
                                                        </WrapPanel>

                                                        <TextBlock Text="{Binding VerificationScriptStatusText}"
                                                                   Margin="0,2,0,0"
                                                                   Foreground="{StaticResource TextSecondary}"
                                                                   FontSize="12"
                                                                   TextWrapping="Wrap"/>

                                                        <WrapPanel Margin="0,16,0,0"
                                                                   ItemHeight="40">
                                                            <Button Content="Review Script"
                                                                    Margin="0,0,10,10"
                                                                    Style="{StaticResource SecondaryButton}"
                                                                    ToolTip="Open the latest verification script. Available after a script has been generated or detected."
                                                                    AutomationProperties.Name="Review verification script"
                                                                    IsEnabled="{Binding HasVerificationScript}"
                                                                    Command="{Binding OpenVerificationScriptCommand}"/>
                                                            <Button Content="Generate Script"
                                                                    Margin="0,0,0,10"
                                                                    Style="{StaticResource SecondaryButton}"
                                                                    ToolTip="Create a post-reboot PowerShell checklist for the patch and Safe Mode keys."
                                                                    AutomationProperties.Name="Generate verification script"
                                                                    IsEnabled="{Binding ButtonsEnabled}"
                                                                    Command="{Binding GenerateVerificationScriptCommand}"/>
                                                        </WrapPanel>
                                                    </StackPanel>
                                                </Border>

                                                <Border Grid.Row="2" Style="{StaticResource InsetCard}">
                                                    <StackPanel>
                                                        <WrapPanel>
                                                            <StackPanel MaxWidth="500"
                                                                        Margin="0,0,18,10">
                                                                <TextBlock Text="Diagnostics Report" Style="{StaticResource SectionEyebrow}"/>
                                                                <TextBlock Text="Support-ready system context, health data, and change history in one local report."
                                                                           Margin="0,8,0,0"
                                                                           Style="{StaticResource BodyCopy}"/>
                                                            </StackPanel>

                                                            <Border Margin="0,0,0,10">
                                                                <Border.Style>
                                                                    <Style TargetType="Border" BasedOn="{StaticResource StatusChipBorder}">
                                                                        <Setter Property="Background" Value="{StaticResource YellowBg}"/>
                                                                        <Setter Property="BorderBrush" Value="{StaticResource Yellow}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding HasDiagnosticsReport}" Value="True">
                                                                                <Setter Property="Background" Value="{StaticResource GreenBg}"/>
                                                                                <Setter Property="BorderBrush" Value="{StaticResource Green}"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <TextBlock>
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource StatusChipText}">
                                                                            <Setter Property="Text" Value="Missing"/>
                                                                            <Setter Property="Foreground" Value="{StaticResource Yellow}"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding HasDiagnosticsReport}" Value="True">
                                                                                    <Setter Property="Text" Value="Ready"/>
                                                                                    <Setter Property="Foreground" Value="{StaticResource Green}"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Border>
                                                        </WrapPanel>

                                                        <TextBlock Text="{Binding DiagnosticsReportStatusText}"
                                                                   Margin="0,2,0,0"
                                                                   Foreground="{StaticResource TextSecondary}"
                                                                   FontSize="12"
                                                                   TextWrapping="Wrap"/>

                                                        <WrapPanel Margin="0,16,0,0"
                                                                   ItemHeight="40">
                                                            <Button Content="Review Report"
                                                                    Margin="0,0,10,10"
                                                                    Style="{StaticResource SecondaryButton}"
                                                                    ToolTip="Open the latest diagnostics report. Available after a report has been generated or detected."
                                                                    AutomationProperties.Name="Review diagnostics report"
                                                                    IsEnabled="{Binding HasDiagnosticsReport}"
                                                                    Command="{Binding OpenLatestDiagnosticsReportCommand}"/>
                                                            <Button Content="Export Report"
                                                                    Margin="0,0,10,10"
                                                                    Style="{StaticResource SecondaryButton}"
                                                                    ToolTip="Export a fresh diagnostics report with health data, configuration, and recent activity."
                                                                    AutomationProperties.Name="Export diagnostics report"
                                                                    IsEnabled="{Binding ButtonsEnabled}"
                                                                    Command="{Binding ExportDiagnosticsCommand}"/>
                                                            <Button Content="Support Bundle (ZIP)"
                                                                    Margin="0,0,0,10"
                                                                    Style="{StaticResource SecondaryButton}"
                                                                    ToolTip="Bundle the diagnostics report, config, crash logs, recent registry backups, and SQLite database into a single shareable ZIP."
                                                                    AutomationProperties.Name="Export support bundle zip"
                                                                    IsEnabled="{Binding ButtonsEnabled}"
                                                                    Command="{Binding ExportSupportBundleCommand}"/>
                                                        </WrapPanel>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>

                                            <Border Grid.Row="3"
                                                    Margin="0,16,0,0"
                                                    Padding="14,12"
                                                    Background="{StaticResource YellowBg}"
                                                    BorderBrush="{StaticResource Border}"
                                                    BorderThickness="1"
                                                    CornerRadius="12">
                                                <StackPanel>
                                                    <TextBlock Text="Keep One Copy Off-Device"
                                                               Foreground="{StaticResource Yellow}"
                                                               FontSize="11.5"
                                                               FontWeight="SemiBold"/>
                                                    <TextBlock Text="For the safest rollback path, keep the recovery kit somewhere outside this machine before you restart or leave the system unattended."
                                                               Margin="0,6,0,0"
                                                               Foreground="{StaticResource TextSecondary}"
                                                               FontSize="12"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </TabItem>

                                    <TabItem Style="{StaticResource WorkspaceTabItem}" Header="Tuning">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <Border Style="{StaticResource InsetCard}">
                                                <TextBlock Text="Advanced StorNVMe tuning sits outside the default patch path. Use it only when you need deeper control."
                                                           Style="{StaticResource BodyCopy}"/>
                                            </Border>

                                            <views:TuningPanel x:Name="TuningPanelControl"
                                                               Grid.Row="1"
                                                               Margin="0,16,0,0"/>
                                        </Grid>
                                    </TabItem>
                                </TabControl>
                            </Grid>
                        </Border>
                    </Grid>

                    <Border Grid.Row="3" Margin="28,18,28,18">
                        <Grid>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Foreground="{StaticResource TextDim}"
                                           FontSize="11"
                                           Text="Verify, back up, apply, reboot, confirm."/>
                                <WrapPanel Margin="0,8,0,0"
                                           Visibility="{Binding ProgressVisible, Converter={StaticResource BoolVis}}">
                                    <TextBlock Text="{Binding ProgressText}"
                                               Margin="0,0,12,8"
                                               Foreground="{StaticResource TextSecondary}"
                                               FontSize="11"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="420"/>
                                    <ProgressBar Width="180"
                                                 Height="6"
                                                 Margin="0,4,0,8"
                                                 VerticalAlignment="Center"
                                                 Value="{Binding ProgressValue}"
                                                 Foreground="{StaticResource Accent}"
                                                 Template="{StaticResource RoundProgress}"/>
                                </WrapPanel>
                            </StackPanel>

                            <WrapPanel x:Name="FooterActionsPanel"
                                       Orientation="Horizontal"
                                       HorizontalAlignment="Right"
                                       ItemHeight="40">
                                <TextBlock VerticalAlignment="Center" Foreground="{StaticResource TextDim}">
                                    <Hyperlink Foreground="{StaticResource TextMuted}" TextDecorations="None" Click="GitHub_Click">GitHub</Hyperlink>
                                </TextBlock>
                                <TextBlock Margin="8,0" VerticalAlignment="Center" Foreground="{StaticResource TextDimmer}" Text="•"/>
                                <TextBlock VerticalAlignment="Center" Foreground="{StaticResource TextDim}">
                                    <Hyperlink Foreground="{StaticResource TextMuted}" TextDecorations="None" Click="Docs_Click">Microsoft docs</Hyperlink>
                                </TextBlock>
                                <Button Content="Open Data Folder"
                                        Margin="18,0,0,0"
                                        Style="{StaticResource SecondaryButton}"
                                        AutomationProperties.Name="Open data folder"
                                        Command="{Binding OpenDataFolderCommand}"/>
                                <Button Content="Refresh Readiness"
                                        Margin="10,0,0,0"
                                        Style="{StaticResource SecondaryButton}"
                                        AutomationProperties.Name="Refresh readiness checks"
                                        ToolTip="Run readiness checks again and rescan hardware inventory (F5)."
                                        Command="{Binding RefreshCommand}"
                                        IsEnabled="{Binding ButtonsEnabled}"/>
                            </WrapPanel>
                        </Grid>
                    </Border>
                </Grid>

                <Border Panel.ZIndex="4"
                        Background="#AA09090B"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolVis}}">
                    <Grid>
                        <Border MaxWidth="560"
                                Margin="24"
                                Padding="28,26"
                                Background="{StaticResource BgDark}"
                                BorderBrush="{StaticResource BorderLight}"
                                BorderThickness="1"
                                CornerRadius="22"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <Border.Effect>
                                <StaticResource ResourceKey="WindowShadow"/>
                            </Border.Effect>

                            <StackPanel>
                                <TextBlock Text="Refreshing readiness"
                                           Foreground="{StaticResource TextPrimary}"
                                           FontSize="26"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="Checking the current Windows build, storage path, NVMe inventory, and rollback safety before driver actions unlock."
                                           Margin="0,12,0,0"
                                           Style="{StaticResource BodyCopy}"/>

                                <ProgressBar Margin="0,22,0,0"
                                             Height="8"
                                             Foreground="{StaticResource Accent}"
                                             Template="{StaticResource RoundProgressIndeterminate}"/>

                                <WrapPanel Margin="0,22,0,0">
                                    <Border Width="150" Margin="0,0,12,12" Style="{StaticResource InsetCard}">
                                        <StackPanel>
                                            <TextBlock Text="Build &amp; Driver" Style="{StaticResource SectionEyebrow}"/>
                                            <TextBlock Text="Verifying Windows compatibility and the active NVMe stack."
                                                       Margin="0,8,0,0"
                                                       Style="{StaticResource BodyCopy}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Width="150" Margin="0,0,12,12" Style="{StaticResource InsetCard}">
                                        <StackPanel>
                                            <TextBlock Text="Drive Inventory" Style="{StaticResource SectionEyebrow}"/>
                                            <TextBlock Text="Enumerating local disks, NVMe health signals, and migration status."
                                                       Margin="0,8,0,0"
                                                       Style="{StaticResource BodyCopy}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Width="150" Style="{StaticResource InsetCard}">
                                        <StackPanel>
                                            <TextBlock Text="Rollback Safety" Style="{StaticResource SectionEyebrow}"/>
                                            <TextBlock Text="Reviewing recovery prerequisites, warnings, and compatibility blockers."
                                                       Margin="0,8,0,0"
                                                       Style="{StaticResource BodyCopy}"/>
                                        </StackPanel>
                                    </Border>
                                </WrapPanel>

                                <TextBlock Text="The first pass can take a few seconds while Windows storage and WMI data settle."
                                           Margin="0,18,0,0"
                                           Foreground="{StaticResource TextDim}"
                                           FontSize="12"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
