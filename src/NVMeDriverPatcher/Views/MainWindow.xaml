                                                                   Margin="0,8,0,0"
                                                                   Foreground="{StaticResource TextPrimary}"
                                                                   FontSize="24"
                                                                   FontWeight="SemiBold"/>
                                                    </StackPanel>
                                                </Border>

                                                <Border Grid.Column="2" Style="{StaticResource InsetCard}">
                                                    <StackPanel>
                                                        <TextBlock Text="Warnings" Style="{StaticResource SectionEyebrow}"/>
                                                        <TextBlock Text="{Binding LogWarningCount}"
                                                                   Margin="0,8,0,0"
                                                                   Foreground="{StaticResource Yellow}"
                                                                   FontSize="24"
                                                                   FontWeight="SemiBold"/>
                                                    </StackPanel>
                                                </Border>

                                                <Border Grid.Column="4" Style="{StaticResource InsetCard}">
                                                    <StackPanel>
                                                        <TextBlock Text="Errors" Style="{StaticResource SectionEyebrow}"/>
                                                        <TextBlock Text="{Binding LogErrorCount}"
                                                                   Margin="0,8,0,0"
                                                                   Foreground="{StaticResource Red}"
                                                                   FontSize="24"
                                                                   FontWeight="SemiBold"/>
                                                    </StackPanel>
                                                </Border>

                                                <Border Grid.Column="6" Style="{StaticResource InsetCard}">
                                                    <StackPanel>
                                                        <TextBlock Text="Audit Snapshot" Style="{StaticResource SectionEyebrow}"/>
                                                        <TextBlock Text="{Binding ActivitySummaryText}"
                                                                   Margin="0,8,0,0"
                                                                   Foreground="{StaticResource TextPrimary}"
                                                                   FontSize="13"
                                                                   FontWeight="SemiBold"
                                                                   TextWrapping="Wrap"/>
                                                        <TextBlock Text="{Binding LatestActivityText}"
                                                                   Margin="0,8,0,0"
                                                                   Foreground="{StaticResource TextSecondary}"
                                                                   FontSize="12"
                                                                   TextWrapping="Wrap"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   MaxHeight="34"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>

                                            <Border Grid.Row="2"
                                                    Margin="0,18,0,0"
                                                    Style="{StaticResource InsetCard}">
                                                <Grid>
                                                    <ScrollViewer x:Name="LogScroller" VerticalScrollBarVisibility="Auto">
                                                        <TextBox x:Name="LogOutput"
                                                                 Text="{Binding LogText, Mode=OneWay}"
                                                                 Background="Transparent"
                                                                 BorderThickness="0"
                                                                 CaretBrush="Transparent"
                                                                 AutomationProperties.Name="Activity log output"
                                                                 FontFamily="Cascadia Code,Consolas,Courier New"
                                                                 FontSize="11.5"
                                                                 Foreground="{StaticResource TextSecondary}"
                                                                 IsReadOnly="True"
                                                                 IsTabStop="False"
                                                                 Padding="0"
                                                                 SelectionBrush="{StaticResource AccentBg}"
                                                                 TextChanged="LogOutput_TextChanged"
                                                                 TextWrapping="Wrap">
                                                            <TextBox.ContextMenu>
                                                                <ContextMenu>
                                                                    <MenuItem Header="Copy Selection" Click="CopySelection_Click"/>
                                                                    <MenuItem Header="Select All" Click="SelectAll_Click"/>
                                                                    <Separator/>
                                                                    <MenuItem Header="Copy Entire Log" Command="{Binding CopyLogCommand}"/>
                                                                    <MenuItem Header="Clear Log" Click="ClearLog_Click"/>
                                                                </ContextMenu>
                                                            </TextBox.ContextMenu>
                                                        </TextBox>
                                                    </ScrollViewer>

                                                    <Border Background="#5509090B"
                                                            CornerRadius="14"
                                                            IsHitTestVisible="False">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding LogEntryCount}" Value="0">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <TextBlock Text="No activity captured yet"
                                                                       Foreground="{StaticResource TextPrimary}"
                                                                       FontSize="22"
                                                                       FontWeight="SemiBold"
                                                                       HorizontalAlignment="Center"/>
                                                            <TextBlock Text="Run checks or actions and this workspace will keep a local, exportable audit trail of what happened."
                                                                       Margin="0,10,0,0"
                                                                       Style="{StaticResource BodyCopy}"
                                                                       TextAlignment="Center"
                                                                       MaxWidth="380"/>
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>
                                            </Border>

                                            <StackPanel Grid.Row="3" Margin="0,16,0,0">
                                                <ProgressBar Height="8"
                                                             Value="{Binding ProgressValue}"
                                                             Foreground="{StaticResource Accent}"
                                                             Template="{StaticResource RoundProgress}"
                                                             Visibility="{Binding ProgressVisible, Converter={StaticResource BoolVis}}"/>
                                                <TextBlock Text="{Binding ProgressText}"
                                                           Margin="0,8,0,0"
                                                           Foreground="{StaticResource TextDim}"
                                                           FontSize="11"
                                                           Visibility="{Binding ProgressVisible, Converter={StaticResource BoolVis}}"/>
                                            </StackPanel>
                                        </Grid>
                                    </TabItem>

                                    <TabItem Style="{StaticResource WorkspaceTabItem}">
                                        <TabItem.Header>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Benchmarks" VerticalAlignment="Center"/>
                                                <Border Margin="8,0,0,0"
                                                        Padding="8,3"
                                                        Background="{StaticResource BgMedium}"
                                                        BorderBrush="{Binding BenchmarkTabBadgeColor, Converter={StaticResource StrToBrush}}"
                                                        BorderThickness="1"
                                                        CornerRadius="999">
                                                    <TextBlock Text="{Binding BenchmarkTabBadgeText}"
                                                               Foreground="{Binding BenchmarkTabBadgeColor, Converter={StaticResource StrToBrush}}"
                                                               FontSize="10.5"
                                                               FontWeight="SemiBold"/>
                                                </Border>
                                            </StackPanel>
                                        </TabItem.Header>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <Border Style="{StaticResource InsetCard}">
                                                <TextBlock Text="Use a before/after benchmark pass to validate whether the native stack helped this exact machine, not just the headline numbers."
                                                           Style="{StaticResource BodyCopy}"/>
                                            </Border>

                                            <Border x:Name="BenchmarkEmptyState"
                                                    Grid.Row="1"
                                                    Margin="0,16,0,0"
                                                    Style="{StaticResource InsetCard}">
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="No benchmark history yet"
                                                               Foreground="{StaticResource TextPrimary}"
                                                               FontSize="22"
                                                               FontWeight="SemiBold"
                                                               HorizontalAlignment="Center"/>
                                                    <TextBlock Text="Run a benchmark before or after applying the patch to build a machine-specific comparison."
                                                               Margin="0,10,0,0"
                                                               Style="{StaticResource BodyCopy}"
                                                               TextAlignment="Center"
                                                               MaxWidth="360"/>
                                                    <Button Content="Run Benchmark"
                                                            Margin="0,18,0,0"
                                                            HorizontalAlignment="Center"
                                                            Style="{StaticResource ActionButton}"
                                                            AutomationProperties.Name="Run first benchmark"
                                                            Command="{Binding RunBenchmarkCommand}"/>
                                                </StackPanel>
                                            </Border>

                                            <Grid x:Name="BenchmarkWorkspacePanel"
                                                  Grid.Row="1"
                                                  Margin="0,16,0,0"
                                                  Visibility="Collapsed">
                                                <views:BenchmarkComparisonView x:Name="BenchmarkView"/>
                                            </Grid>
                                        </Grid>
                                    </TabItem>

                                    <TabItem Style="{StaticResource WorkspaceTabItem}">
                                        <TabItem.Header>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Telemetry" VerticalAlignment="Center"/>
                                                <Border Margin="8,0,0,0"
                                                        Padding="8,3"
                                                        Background="{StaticResource BgMedium}"
                                                        BorderBrush="{Binding TelemetryTabBadgeColor, Converter={StaticResource StrToBrush}}"
                                                        BorderThickness="1"
                                                        CornerRadius="999">
                                                    <TextBlock Text="{Binding TelemetryTabBadgeText}"
                                                               Foreground="{Binding TelemetryTabBadgeColor, Converter={StaticResource StrToBrush}}"
                                                               FontSize="10.5"
                                                               FontWeight="SemiBold"/>
                                                </Border>
                                            </StackPanel>
                                        </TabItem.Header>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <Border Style="{StaticResource InsetCard}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel>
                                                        <TextBlock Text="Drive telemetry pairs live SMART polling with a rolling seven-day history so you can spot thermal drift or endurance changes with context."
                                                                   Style="{StaticResource BodyCopy}"/>
                                                    </StackPanel>

                                                    <Button Grid.Column="1"
                                                            Margin="18,0,0,0"
                                                            VerticalAlignment="Center"
                                                            Content="Capture Snapshot"
                                                            Style="{StaticResource SecondaryButton}"
                                                            AutomationProperties.Name="Capture telemetry snapshot"
                                                            Click="RefreshTelemetry_Click"/>
                                                </Grid>
                                            </Border>

                                            <Border x:Name="TelemetryEmptyState"
                                                    Grid.Row="1"
                                                    Margin="0,16,0,0"
                                                    Style="{StaticResource InsetCard}">
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="No NVMe telemetry source available"
                                                               Foreground="{StaticResource TextPrimary}"
                                                               FontSize="22"
                                                               FontWeight="SemiBold"
                                                               HorizontalAlignment="Center"/>
                                                    <TextBlock Text="This workspace activates when the current scan finds at least one NVMe drive that Windows can surface for health checks."
                                                               Margin="0,10,0,0"
                                                               Style="{StaticResource BodyCopy}"
                                                               TextAlignment="Center"
                                                               MaxWidth="420"/>
                                                    <Button Content="Refresh Checks"
                                                            Margin="0,18,0,0"
                                                            HorizontalAlignment="Center"
                                                            Style="{StaticResource SecondaryButton}"
                                                            AutomationProperties.Name="Refresh readiness checks"
                                                            Command="{Binding RefreshCommand}"/>
                                                </StackPanel>
                                            </Border>

                                            <Grid x:Name="TelemetryWorkspacePanel"
                                                  Grid.Row="1"
                                                  Margin="0,16,0,0"
                                                  Visibility="Collapsed">
                                                <views:TelemetryView x:Name="TelemetryPanelControl"/>
                                            </Grid>
                                        </Grid>
                                    </TabItem>

                                    <TabItem Style="{StaticResource WorkspaceTabItem}">
                                        <TabItem.Header>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Recovery" VerticalAlignment="Center"/>
                                                <Border Margin="8,0,0,0"
                                                        Padding="8,3"
                                                        Background="{StaticResource BgMedium}"
                                                        BorderBrush="{Binding RecoveryTabBadgeColor, Converter={StaticResource StrToBrush}}"
                                                        BorderThickness="1"
                                                        CornerRadius="999">
                                                    <TextBlock Text="{Binding RecoveryTabBadgeText}"
                                                               Foreground="{Binding RecoveryTabBadgeColor, Converter={StaticResource StrToBrush}}"
                                                               FontSize="10.5"
                                                               FontWeight="SemiBold"/>
                                                </Border>
                                            </StackPanel>
                                        </TabItem.Header>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <Border Style="{StaticResource InsetCard}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel>
                                                        <TextBlock Text="Recovery artifacts keep rollback, validation, and support handoffs calm when something changes after the patch."
                                                                   Style="{StaticResource BodyCopy}"/>
                                                        <TextBlock Text="{Binding RecoveryWorkspaceSummaryText}"
                                                                   Margin="0,10,0,0"
                                                                   Foreground="{StaticResource TextPrimary}"
                                                                   FontSize="13"
                                                                   FontWeight="SemiBold"
                                                                   TextWrapping="Wrap"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="1"
                                                                Margin="18,0,0,0"
                                                                Orientation="Horizontal"
                                                                VerticalAlignment="Center">
                                                        <Button Content="Refresh Assets"
                                                                Margin="0,0,10,0"
                                                                Style="{StaticResource SecondaryButton}"
                                                                AutomationProperties.Name="Refresh recovery assets"
                                                                Command="{Binding RefreshRecoveryAssetsCommand}"/>
                                                        <Button Content="Open Data Folder"
                                                                Style="{StaticResource SecondaryButton}"
                                                                AutomationProperties.Name="Open data folder"
                                                                Command="{Binding OpenDataFolderCommand}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>

                                            <UniformGrid Grid.Row="1"
                                                         Columns="3"
                                                         Margin="0,16,0,0">
                                                <Border Style="{StaticResource InsetCard}" Margin="0,0,12,0">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>

                                                        <Border Width="32"
                                                                Height="32"
                                                                Background="{Binding PreparationStageColor, Converter={StaticResource StrToBrush}}"
                                                                CornerRadius="16"
                                                                Opacity="0.16"
                                                                VerticalAlignment="Top"/>
                                                        <Ellipse Width="9"
                                                                 Height="9"
                                                                 Margin="11,11,0,0"
                                                                 Fill="{Binding PreparationStageColor, Converter={StaticResource StrToBrush}}"
                                                                 HorizontalAlignment="Left"
                                                                 VerticalAlignment="Top"/>

                                                        <StackPanel Grid.Column="1" Margin="14,0,0,0">
                                                            <TextBlock Text="Prepare" Style="{StaticResource SectionEyebrow}"/>
                                                            <TextBlock Text="{Binding PreparationStageStateText}"
                                                                       Margin="0,8,0,0"
                                                                       Foreground="{Binding PreparationStageColor, Converter={StaticResource StrToBrush}}"
                                                                       FontSize="16"
                                                                       FontWeight="SemiBold"
                                                                       TextWrapping="Wrap"/>
                                                            <TextBlock Text="{Binding PreparationStageDetailText}"
                                                                       Margin="0,8,0,0"
                                                                       Style="{StaticResource BodyCopy}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>

                                                <Border Style="{StaticResource InsetCard}" Margin="0,0,12,0">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>

                                                        <Border Width="32"
                                                                Height="32"
                                                                Background="{Binding RestartStageColor, Converter={StaticResource StrToBrush}}"
                                                                CornerRadius="16"
                                                                Opacity="0.16"
                                                                VerticalAlignment="Top"/>
                                                        <Ellipse Width="9"
                                                                 Height="9"
                                                                 Margin="11,11,0,0"
                                                                 Fill="{Binding RestartStageColor, Converter={StaticResource StrToBrush}}"
                                                                 HorizontalAlignment="Left"
                                                                 VerticalAlignment="Top"/>

                                                        <StackPanel Grid.Column="1" Margin="14,0,0,0">
                                                            <TextBlock Text="Restart" Style="{StaticResource SectionEyebrow}"/>
                                                            <TextBlock Text="{Binding RestartStageStateText}"
                                                                       Margin="0,8,0,0"
                                                                       Foreground="{Binding RestartStageColor, Converter={StaticResource StrToBrush}}"
                                                                       FontSize="16"
                                                                       FontWeight="SemiBold"
                                                                       TextWrapping="Wrap"/>
                                                            <TextBlock Text="{Binding RestartStageDetailText}"
                                                                       Margin="0,8,0,0"
                                                                       Style="{StaticResource BodyCopy}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>

                                                <Border Style="{StaticResource InsetCard}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>

                                                        <Border Width="32"
                                                                Height="32"
                                                                Background="{Binding ValidationStageColor, Converter={StaticResource StrToBrush}}"
                                                                CornerRadius="16"
                                                                Opacity="0.16"
                                                                VerticalAlignment="Top"/>
                                                        <Ellipse Width="9"
                                                                 Height="9"
                                                                 Margin="11,11,0,0"
                                                                 Fill="{Binding ValidationStageColor, Converter={StaticResource StrToBrush}}"
                                                                 HorizontalAlignment="Left"
                                                                 VerticalAlignment="Top"/>

                                                        <StackPanel Grid.Column="1" Margin="14,0,0,0">
                                                            <TextBlock Text="Validate" Style="{StaticResource SectionEyebrow}"/>
                                                            <TextBlock Text="{Binding ValidationStageStateText}"
                                                                       Margin="0,8,0,0"
                                                                       Foreground="{Binding ValidationStageColor, Converter={StaticResource StrToBrush}}"
                                                                       FontSize="16"
                                                                       FontWeight="SemiBold"
                                                                       TextWrapping="Wrap"/>
                                                            <TextBlock Text="{Binding ValidationStageDetailText}"
                                                                       Margin="0,8,0,0"
                                                                       Style="{StaticResource BodyCopy}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </UniformGrid>

                                            <Grid Grid.Row="2" Margin="0,16,0,0">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <Border Style="{StaticResource InsetCard}" Margin="0,0,0,14">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <StackPanel>
                                                            <TextBlock Text="Recovery Kit" Style="{StaticResource SectionEyebrow}"/>
                                                            <TextBlock Text="Offline rollback files for Windows and WinRE."
                                                                       Margin="0,8,0,0"
                                                                       Style="{StaticResource BodyCopy}"/>
                                                            <TextBlock Text="{Binding RecoveryKitStatusText}"
                                                                       Margin="0,12,0,0"
                                                                       Foreground="{StaticResource TextSecondary}"
                                                                       FontSize="12"
                                                                       TextWrapping="Wrap"/>
                                                        </StackPanel>

                                                        <StackPanel Grid.Column="1"
                                                                    Margin="18,0,0,0"
                                                                    VerticalAlignment="Center">
                                                            <Button Content="Open Kit Folder"
                                                                    Style="{StaticResource SecondaryButton}"
                                                                    AutomationProperties.Name="Open recovery kit folder"
                                                                    IsEnabled="{Binding HasRecoveryKit}"
                                                                    Command="{Binding OpenLatestRecoveryKitCommand}"/>
                                                            <Button Content="Create Fresh Copy"
                                                                    Margin="0,10,0,0"
                                                                    Style="{StaticResource SecondaryButton}"
                                                                    AutomationProperties.Name="Create recovery kit copy"
                                                                    IsEnabled="{Binding ButtonsEnabled}"
                                                                    Command="{Binding ExportRecoveryKitCommand}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>

                                                <Border Grid.Row="1" Style="{StaticResource InsetCard}" Margin="0,0,0,14">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <StackPanel>
                                                            <TextBlock Text="Verification Script" Style="{StaticResource SectionEyebrow}"/>
                                                            <TextBlock Text="Readable post-reboot confirmation for the patch and Safe Mode protections."
                                                                       Margin="0,8,0,0"
                                                                       Style="{StaticResource BodyCopy}"/>
                                                            <TextBlock Text="{Binding VerificationScriptStatusText}"
                                                                       Margin="0,12,0,0"
                                                                       Foreground="{StaticResource TextSecondary}"
                                                                       FontSize="12"
                                                                       TextWrapping="Wrap"/>
                                                        </StackPanel>

                                                        <StackPanel Grid.Column="1"
                                                                    Margin="18,0,0,0"
                                                                    VerticalAlignment="Center">
                                                            <Button Content="Review Script"
                                                                    Style="{StaticResource SecondaryButton}"
                                                                    AutomationProperties.Name="Review verification script"
                                                                    IsEnabled="{Binding HasVerificationScript}"
                                                                    Command="{Binding OpenVerificationScriptCommand}"/>
                                                            <Button Content="Generate Script"
                                                                    Margin="0,10,0,0"
                                                                    Style="{StaticResource SecondaryButton}"
                                                                    AutomationProperties.Name="Generate verification script"
                                                                    IsEnabled="{Binding ButtonsEnabled}"
                                                                    Command="{Binding GenerateVerificationScriptCommand}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>

                                                <Border Grid.Row="2" Style="{StaticResource InsetCard}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <StackPanel>
                                                            <TextBlock Text="Diagnostics Report" Style="{StaticResource SectionEyebrow}"/>
                                                            <TextBlock Text="Support-ready system context, health data, and change history in one local report."
                                                                       Margin="0,8,0,0"
                                                                       Style="{StaticResource BodyCopy}"/>
                                                            <TextBlock Text="{Binding DiagnosticsReportStatusText}"
                                                                       Margin="0,12,0,0"
                                                                       Foreground="{StaticResource TextSecondary}"
                                                                       FontSize="12"
                                                                       TextWrapping="Wrap"/>
                                                        </StackPanel>

                                                        <StackPanel Grid.Column="1"
                                                                    Margin="18,0,0,0"
                                                                    VerticalAlignment="Center">
                                                            <Button Content="Review Report"
                                                                    Style="{StaticResource SecondaryButton}"
                                                                    AutomationProperties.Name="Review diagnostics report"
                                                                    IsEnabled="{Binding HasDiagnosticsReport}"
                                                                    Command="{Binding OpenLatestDiagnosticsReportCommand}"/>
                                                            <Button Content="Export Report"
                                                                    Margin="0,10,0,0"
                                                                    Style="{StaticResource SecondaryButton}"
                                                                    AutomationProperties.Name="Export diagnostics report"
                                                                    IsEnabled="{Binding ButtonsEnabled}"
                                                                    Command="{Binding ExportDiagnosticsCommand}"/>
                                                            <Button Content="Support Bundle (ZIP)"
                                                                    Margin="0,10,0,0"
                                                                    Style="{StaticResource SecondaryButton}"
                                                                    ToolTip="Bundle the diagnostics report, config, crash logs, recent registry backups, and SQLite database into a single shareable zip."
                                                                    AutomationProperties.Name="Export support bundle zip"
                                                                    IsEnabled="{Binding ButtonsEnabled}"
                                                                    Command="{Binding ExportSupportBundleCommand}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </Grid>

                                            <Border Grid.Row="3"
                                                    Margin="0,16,0,0"
                                                    Padding="14,12"
                                                    Background="{StaticResource YellowBg}"
                                                    BorderBrush="{StaticResource Border}"
                                                    BorderThickness="1"
                                                    CornerRadius="12">
                                                <TextBlock Text="For the safest rollback path, keep the recovery kit somewhere outside this machine before you restart or leave the system unattended."
                                                           Foreground="{StaticResource Yellow}"
                                                           FontSize="12"
                                                           TextWrapping="Wrap"/>
                                            </Border>
                                        </Grid>
                                    </TabItem>

                                    <TabItem Style="{StaticResource WorkspaceTabItem}">
                                        <TabItem.Header>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Tuning" VerticalAlignment="Center"/>
                                                <Border Margin="8,0,0,0"
                                                        Padding="8,3"
                                                        Background="{StaticResource BgMedium}"
                                                        BorderBrush="{StaticResource Border}"
                                                        BorderThickness="1"
                                                        CornerRadius="999">
                                                    <TextBlock Text="Advanced"
                                                               Foreground="{StaticResource TextDim}"
                                                               FontSize="10.5"
                                                               FontWeight="SemiBold"/>
                                                </Border>
                                            </StackPanel>
                                        </TabItem.Header>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <Border Style="{StaticResource InsetCard}">
                                                <TextBlock Text="Advanced StorNVMe registry tuning is intentionally separated from the patch workflow. Use it only when you want to shape queue depth and power behavior beyond the default experience."
                                                           Style="{StaticResource BodyCopy}"/>
                                            </Border>

                                            <views:TuningPanel x:Name="TuningPanelControl"
                                                               Grid.Row="1"
                                                               Margin="0,16,0,0"/>
                                        </Grid>
                                    </TabItem>
                                </TabControl>
                            </Grid>
                        </Border>
                    </Grid>

                    <Border Grid.Row="3" Margin="28,18,28,18">
                        <Grid>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Foreground="{StaticResource TextDim}"
                                           FontSize="11"
                                           Text="Careful driver changes work best when you verify, back up, apply, reboot, and confirm in that order."/>
                                <StackPanel Orientation="Horizontal"
                                            Margin="0,8,0,0"
                                            Visibility="{Binding ProgressVisible, Converter={StaticResource BoolVis}}">
                                    <TextBlock Text="{Binding ProgressText}"
                                               Foreground="{StaticResource TextSecondary}"
                                               FontSize="11"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               Width="420"/>
                                    <ProgressBar Width="180"
                                                 Height="6"
                                                 Margin="12,0,0,0"
                                                 VerticalAlignment="Center"
                                                 Value="{Binding ProgressValue}"
                                                 Foreground="{StaticResource Accent}"
                                                 Template="{StaticResource RoundProgress}"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock VerticalAlignment="Center" Foreground="{StaticResource TextDim}">
                                    <Hyperlink Foreground="{StaticResource TextMuted}" TextDecorations="None" Click="GitHub_Click">GitHub</Hyperlink>
                                </TextBlock>
                                <TextBlock Margin="8,0" VerticalAlignment="Center" Foreground="{StaticResource TextDimmer}" Text="•"/>
                                <TextBlock VerticalAlignment="Center" Foreground="{StaticResource TextDim}">
                                    <Hyperlink Foreground="{StaticResource TextMuted}" TextDecorations="None" Click="Docs_Click">Microsoft docs</Hyperlink>
                                </TextBlock>
                                <Button Content="Open Data Folder"
                                        Margin="18,0,0,0"
                                        Style="{StaticResource SecondaryButton}"
                                        AutomationProperties.Name="Open data folder"
                                        Command="{Binding OpenDataFolderCommand}"/>
                                <Button Content="Refresh Checks"
                                        Margin="10,0,0,0"
                                        Style="{StaticResource SecondaryButton}"
                                        AutomationProperties.Name="Refresh readiness checks"
                                        Command="{Binding RefreshCommand}"
                                        IsEnabled="{Binding ButtonsEnabled}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <Border Panel.ZIndex="4"
                        Background="#AA09090B"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolVis}}">
                    <Grid>
                        <Border Width="520"
                                Padding="28,26"
                                Background="{StaticResource BgDark}"
                                BorderBrush="{StaticResource BorderLight}"
                                BorderThickness="1"
                                CornerRadius="22"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <Border.Effect>
                                <StaticResource ResourceKey="WindowShadow"/>
                            </Border.Effect>

                            <StackPanel>
                                <TextBlock Text="Refreshing system readiness"
                                           Foreground="{StaticResource TextPrimary}"
                                           FontSize="26"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="Checking the current Windows build, active storage path, NVMe inventory, and rollback safety before any driver action is exposed."
                                           Margin="0,12,0,0"
                                           Style="{StaticResource BodyCopy}"/>

                                <ProgressBar Margin="0,22,0,0"
                                             Height="8"
                                             Foreground="{StaticResource Accent}"
                                             Template="{StaticResource RoundProgressIndeterminate}"/>

                                <UniformGrid Columns="3" Margin="0,22,0,0">
                                    <Border Margin="0,0,10,0" Style="{StaticResource InsetCard}">
                                        <StackPanel>
                                            <TextBlock Text="Build &amp; Driver" Style="{StaticResource SectionEyebrow}"/>
                                            <TextBlock Text="Verifying Windows compatibility and the active NVMe stack."
                                                       Margin="0,8,0,0"
                                                       Style="{StaticResource BodyCopy}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Margin="0,0,10,0" Style="{StaticResource InsetCard}">
                                        <StackPanel>
                                            <TextBlock Text="Drive Inventory" Style="{StaticResource SectionEyebrow}"/>
                                            <TextBlock Text="Enumerating local disks, NVMe health signals, and migration status."
                                                       Margin="0,8,0,0"
                                                       Style="{StaticResource BodyCopy}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource InsetCard}">
                                        <StackPanel>
                                            <TextBlock Text="Rollback Safety" Style="{StaticResource SectionEyebrow}"/>
                                            <TextBlock Text="Reviewing recovery prerequisites, warnings, and compatibility blockers."
                                                       Margin="0,8,0,0"
                                                       Style="{StaticResource BodyCopy}"/>
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>

                                <TextBlock Text="The first pass can take a few seconds while Windows storage and WMI data settle."
