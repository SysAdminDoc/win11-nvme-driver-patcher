<Window x:Class="NVMeDriverPatcher.Views.ThemedDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        MinWidth="520"
        MaxWidth="760"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border Margin="10"
            Padding="0"
            Background="{DynamicResource WindowCanvasBrush}"
            BorderBrush="{DynamicResource BorderLight}"
            BorderThickness="1"
            CornerRadius="7"
            Effect="{DynamicResource WindowShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border x:Name="HeaderAccentBar"
                    Height="1"
                    VerticalAlignment="Top"
                    Background="{DynamicResource AccentLineBrush}"
                    CornerRadius="7,7,0,0"
                    Panel.ZIndex="3"/>

            <Border Grid.Row="0"
                    Padding="22,16"
                    Background="{DynamicResource WindowCanvasBrush}"
                    CornerRadius="7,7,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock x:Name="DlgEyebrow" Text="Confirmation" Style="{StaticResource SectionEyebrow}"/>
                        <TextBlock x:Name="DlgTitle"
                                   Margin="0,5,0,0"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                    </StackPanel>

                    <Button x:Name="BtnClose"
                            Grid.Column="1"
                            Content="&#x2715;"
                            Style="{StaticResource WindowChromeButton}"
                            AutomationProperties.Name="Close dialog"
                            Click="BtnClose_Click"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="22,16,22,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Width="40"
                        Height="40"
                        Background="{DynamicResource SurfaceInset}"
                        BorderBrush="{DynamicResource Border}"
                        BorderThickness="1"
                        CornerRadius="5"
                        VerticalAlignment="Top">
                    <Canvas x:Name="IconCanvas" Width="28" Height="28" Margin="5"/>
                </Border>

                <FlowDocumentScrollViewer Grid.Column="2"
                                          MaxHeight="430"
                                          VerticalScrollBarVisibility="Auto"
                                          IsToolBarVisible="False"
                                          Focusable="False"
                                          AutomationProperties.LiveSetting="Assertive">
                    <FlowDocument x:Name="DlgMessageDocument"
                                  PagePadding="0"
                                  FontFamily="Segoe UI Variable Text, Segoe UI"
                                  FontSize="13.5"
                                  Foreground="{DynamicResource TextSecondary}"
                                  TextAlignment="Left"/>
                </FlowDocumentScrollViewer>
            </Grid>

            <Border Grid.Row="2"
                    BorderBrush="{DynamicResource Border}"
                    BorderThickness="0,1,0,0"
                    Padding="22,12,22,16">
                <WrapPanel HorizontalAlignment="Right">
                <Button x:Name="BtnNo"
                        Content="Cancel"
                        MinWidth="96"
                        Margin="0,0,10,0"
                        Style="{StaticResource SecondaryButton}"
                        AutomationProperties.Name="Cancel dialog"
                        IsCancel="True"
                        Visibility="Collapsed"
                        Click="BtnNo_Click"/>
                <Button x:Name="BtnYes"
                        Content="Continue"
                        MinWidth="108"
                        Margin="0,0,10,0"
                        Style="{StaticResource ActionButton}"
                        AutomationProperties.Name="Confirm dialog"
                        IsDefault="True"
                        Visibility="Collapsed"
                        Click="BtnYes_Click"/>
                <Button x:Name="BtnOK"
                        Content="OK"
                        MinWidth="92"
                        Style="{StaticResource ActionButton}"
                        AutomationProperties.Name="Acknowledge dialog"
                        IsDefault="True"
                        Visibility="Collapsed"
                        Click="BtnOK_Click"/>
                </WrapPanel>
            </Border>
        </Grid>
    </Border>
</Window>
