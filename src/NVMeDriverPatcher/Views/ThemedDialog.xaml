<Window x:Class="NVMeDriverPatcher.Views.ThemedDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        MinWidth="420"
        MaxWidth="620"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Topmost="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border Margin="14"
            Padding="0"
            Background="{StaticResource WindowCanvasBrush}"
            BorderBrush="{StaticResource BorderLight}"
            BorderThickness="1"
            CornerRadius="22">
        <Border.Effect>
            <StaticResource ResourceKey="WindowShadow"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border x:Name="HeaderAccentBar"
                    Height="3"
                    VerticalAlignment="Top"
                    Background="{StaticResource Accent}"
                    CornerRadius="22,22,0,0"
                    Panel.ZIndex="3"/>

            <Border Grid.Row="0"
                    Padding="22,18"
                    Background="{StaticResource HeroSurfaceBrush}"
                    CornerRadius="22,22,0,0">
                <StackPanel>
                    <TextBlock x:Name="DlgEyebrow" Text="Confirmation" Style="{StaticResource SectionEyebrow}"/>
                    <TextBlock x:Name="DlgTitle"
                               Margin="0,8,0,0"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="24,24,24,18">
                <Canvas x:Name="IconCanvas" Width="32" Height="32" Margin="0,0,16,0" VerticalAlignment="Top"/>
                <ScrollViewer MaxHeight="420" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="DlgMessage"
                               MaxWidth="500"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondary}"
                               TextWrapping="Wrap"/>
                </ScrollViewer>
            </StackPanel>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="24,0,24,22">
                <Button x:Name="BtnNo"
                        Content="Cancel"
                        Width="96"
                        Margin="0,0,10,0"
                        Style="{StaticResource SecondaryButton}"
                        IsCancel="True"
                        Visibility="Collapsed"
                        Click="BtnNo_Click"/>
                <Button x:Name="BtnYes"
                        Content="Continue"
                        Width="108"
                        Margin="0,0,10,0"
                        Style="{StaticResource ActionButton}"
                        IsDefault="True"
                        Visibility="Collapsed"
                        Click="BtnYes_Click"/>
                <Button x:Name="BtnOK"
                        Content="OK"
                        Width="92"
                        Style="{StaticResource ActionButton}"
                        IsDefault="True"
                        IsCancel="True"
                        Visibility="Collapsed"
                        Click="BtnOK_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
