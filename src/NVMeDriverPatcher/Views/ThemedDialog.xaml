<Window x:Class="NVMeDriverPatcher.Views.ThemedDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" SizeToContent="WidthAndHeight" MinWidth="380" MaxWidth="560"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" Topmost="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Border CornerRadius="10" Background="#FF09090b" BorderBrush="#FF27272a" BorderThickness="1" Padding="0" Margin="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.5" Direction="270" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="#FF111113" CornerRadius="10,10,0,0" Padding="16,10">
                <TextBlock x:Name="DlgTitle" FontSize="13" FontWeight="SemiBold" Foreground="#FFfafafa" FontFamily="Segoe UI"/>
            </Border>

            <!-- Body -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="20,20,20,16">
                <Canvas x:Name="IconCanvas" Width="28" Height="28" Margin="0,0,16,0" VerticalAlignment="Top"/>
                <ScrollViewer MaxHeight="400" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="DlgMessage" FontSize="13" Foreground="#FFd4d4d8" FontFamily="Segoe UI"
                               TextWrapping="Wrap" MaxWidth="440" VerticalAlignment="Center"/>
                </ScrollViewer>
            </StackPanel>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,4,20,18">
                <Button x:Name="BtnNo" Content="No" Width="80" Height="32" FontSize="12" FontWeight="SemiBold"
                        Cursor="Hand" Margin="0,0,8,0" Visibility="Collapsed" Click="BtnNo_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="#FF18181b" CornerRadius="6" BorderBrush="#FF3f3f46" BorderThickness="1">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#FF27272a"/>
                                    <Setter TargetName="bd" Property="BorderBrush" Value="#FF52525b"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Foreground><SolidColorBrush Color="#FFd4d4d8"/></Button.Foreground>
                </Button>
                <Button x:Name="BtnYes" Content="Yes" Width="80" Height="32" FontSize="12" FontWeight="SemiBold"
                        Cursor="Hand" Visibility="Collapsed" Click="BtnYes_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="#FF3b82f6" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#FF2563eb"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Foreground><SolidColorBrush Color="#FFfafafa"/></Button.Foreground>
                </Button>
                <Button x:Name="BtnOK" Content="OK" Width="80" Height="32" FontSize="12" FontWeight="SemiBold"
                        Cursor="Hand" Visibility="Collapsed" Click="BtnOK_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="#FF3b82f6" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#FF2563eb"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Foreground><SolidColorBrush Color="#FFfafafa"/></Button.Foreground>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
