<Window x:Class="NVMeDriverPatcher.Views.ThemedDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        MinWidth="440"
        MaxWidth="660"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border Margin="14"
            Padding="0"
            Background="{StaticResource WindowCanvasBrush}"
            BorderBrush="{StaticResource BorderLight}"
            BorderThickness="1"
            CornerRadius="18">
        <Border.Effect>
            <StaticResource ResourceKey="WindowShadow"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border x:Name="HeaderAccentBar"
                    Height="1"
                    VerticalAlignment="Top"
                    Background="{StaticResource AccentLineBrush}"
                    CornerRadius="18,18,0,0"
                    Panel.ZIndex="3"/>

            <Border Grid.Row="0"
                    Padding="22,18"
                    Background="{StaticResource WindowCanvasBrush}"
                    CornerRadius="18,18,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock x:Name="DlgEyebrow" Text="Confirmation" Style="{StaticResource SectionEyebrow}"/>
                        <TextBlock x:Name="DlgTitle"
                                   Margin="0,8,0,0"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}"/>
                    </StackPanel>

                    <Button x:Name="BtnClose"
                            Grid.Column="1"
                            Content="&#x2715;"
                            Style="{StaticResource WindowChromeButton}"
                            AutomationProperties.Name="Close dialog"
                            Click="BtnClose_Click"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="22,20,22,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Width="40"
                        Height="40"
                        Background="{StaticResource SurfaceInset}"
                        BorderBrush="{StaticResource Border}"
                        BorderThickness="1"
                        CornerRadius="12"
                        VerticalAlignment="Top">
                    <Canvas x:Name="IconCanvas" Width="28" Height="28" Margin="6"/>
                </Border>

                <ScrollViewer Grid.Column="2" MaxHeight="420" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="DlgMessage"
                               MaxWidth="520"
                               FontSize="13.5"
                               LineHeight="21"
                               Foreground="{StaticResource TextSecondary}"
                               TextWrapping="Wrap"/>
                </ScrollViewer>
            </Grid>

            <Border Grid.Row="2"
                    BorderBrush="{StaticResource Border}"
                    BorderThickness="0,1,0,0"
                    Padding="22,14,22,20">
                <WrapPanel HorizontalAlignment="Right">
                <Button x:Name="BtnNo"
                        Content="Cancel"
                        Width="96"
                        Margin="0,0,10,0"
                        Style="{StaticResource SecondaryButton}"
                        AutomationProperties.Name="Cancel dialog"
                        IsCancel="True"
                        Visibility="Collapsed"
                        Click="BtnNo_Click"/>
                <Button x:Name="BtnYes"
                        Content="Continue"
                        Width="108"
                        Margin="0,0,10,0"
                        Style="{StaticResource ActionButton}"
                        AutomationProperties.Name="Confirm dialog"
                        IsDefault="True"
                        Visibility="Collapsed"
                        Click="BtnYes_Click"/>
                <Button x:Name="BtnOK"
                        Content="OK"
                        Width="92"
                        Style="{StaticResource ActionButton}"
                        AutomationProperties.Name="Acknowledge dialog"
                        IsDefault="True"
                        Visibility="Collapsed"
                        Click="BtnOK_Click"/>
                </WrapPanel>
            </Border>
        </Grid>
    </Border>
</Window>
