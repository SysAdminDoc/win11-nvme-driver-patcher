<UserControl x:Class="NVMeDriverPatcher.Views.TuningPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="#FF111113" CornerRadius="10" Padding="20,16" BorderBrush="#FF1a1a1e" BorderThickness="1">
        <StackPanel>
            <TextBlock Text="StorNVMe TUNING" Foreground="#FF52525b" FontSize="10" FontWeight="Bold" Margin="0,0,0,12"/>

            <!-- Profile selector -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <TextBlock Text="Profile:" Foreground="#FFd4d4d8" FontSize="12" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <Button x:Name="BtnPerformance" Content="Performance" Click="Profile_Click" Tag="Performance"
                        Style="{StaticResource SecondaryButton}" Height="28" FontSize="10" Margin="0,0,6,0"/>
                <Button x:Name="BtnBalanced" Content="Balanced" Click="Profile_Click" Tag="Balanced"
                        Style="{StaticResource SecondaryButton}" Height="28" FontSize="10" Margin="0,0,6,0"/>
                <Button x:Name="BtnPowerSave" Content="Power Save" Click="Profile_Click" Tag="PowerSave"
                        Style="{StaticResource SecondaryButton}" Height="28" FontSize="10"/>
            </StackPanel>

            <Border Height="1" Background="#FF1a1a1e" Margin="0,0,0,12"/>

            <!-- QueueDepth -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions><ColumnDefinition Width="180"/><ColumnDefinition/><ColumnDefinition Width="50"/></Grid.ColumnDefinitions>
                <TextBlock Text="Queue Depth" Foreground="#FFd4d4d8" FontSize="11" VerticalAlignment="Center"/>
                <Slider x:Name="SliderQueueDepth" Grid.Column="1" Minimum="16" Maximum="256" TickFrequency="16"
                        IsSnapToTickEnabled="True" VerticalAlignment="Center" ValueChanged="Slider_Changed"/>
                <TextBlock x:Name="QueueDepthValue" Grid.Column="2" Foreground="#FF3b82f6" FontSize="11"
                           FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>

            <!-- NvmeMaxReadSplit -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions><ColumnDefinition Width="180"/><ColumnDefinition/><ColumnDefinition Width="50"/></Grid.ColumnDefinitions>
                <TextBlock Text="Max Read Split (KB)" Foreground="#FFd4d4d8" FontSize="11" VerticalAlignment="Center"/>
                <Slider x:Name="SliderReadSplit" Grid.Column="1" Minimum="64" Maximum="1024" TickFrequency="64"
                        IsSnapToTickEnabled="True" VerticalAlignment="Center" ValueChanged="Slider_Changed"/>
                <TextBlock x:Name="ReadSplitValue" Grid.Column="2" Foreground="#FF3b82f6" FontSize="11"
                           FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>

            <!-- NvmeMaxWriteSplit -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions><ColumnDefinition Width="180"/><ColumnDefinition/><ColumnDefinition Width="50"/></Grid.ColumnDefinitions>
                <TextBlock Text="Max Write Split (KB)" Foreground="#FFd4d4d8" FontSize="11" VerticalAlignment="Center"/>
                <Slider x:Name="SliderWriteSplit" Grid.Column="1" Minimum="64" Maximum="1024" TickFrequency="64"
                        IsSnapToTickEnabled="True" VerticalAlignment="Center" ValueChanged="Slider_Changed"/>
                <TextBlock x:Name="WriteSplitValue" Grid.Column="2" Foreground="#FF3b82f6" FontSize="11"
                           FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>

            <!-- IoSubmissionQueueCount -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions><ColumnDefinition Width="180"/><ColumnDefinition/><ColumnDefinition Width="50"/></Grid.ColumnDefinitions>
                <TextBlock Text="I/O Submission Queues" Foreground="#FFd4d4d8" FontSize="11" VerticalAlignment="Center"/>
                <Slider x:Name="SliderQueueCount" Grid.Column="1" Minimum="1" Maximum="64" TickFrequency="1"
                        IsSnapToTickEnabled="True" VerticalAlignment="Center" ValueChanged="Slider_Changed"/>
                <TextBlock x:Name="QueueCountValue" Grid.Column="2" Foreground="#FF3b82f6" FontSize="11"
                           FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>

            <Border Height="1" Background="#FF1a1a1e" Margin="0,4,0,8"/>

            <StackPanel Orientation="Horizontal">
                <Button x:Name="BtnApplyTuning" Content="APPLY" Click="ApplyTuning_Click"
                        Style="{StaticResource SecondaryButton}" Height="28" FontSize="10" Margin="0,0,8,0">
                    <Button.Foreground><SolidColorBrush Color="#FF3b82f6"/></Button.Foreground>
                </Button>
                <Button x:Name="BtnResetTuning" Content="RESET TO DEFAULT" Click="ResetTuning_Click"
                        Style="{StaticResource SecondaryButton}" Height="28" FontSize="10"/>
                <TextBlock x:Name="TuningStatus" Foreground="#FF52525b" FontSize="10" VerticalAlignment="Center" Margin="12,0,0,0"/>
            </StackPanel>

            <TextBlock Text="Changes require reboot. Performance profile maximizes IOPS. Power Save reduces idle power."
                       Foreground="#FF3f3f46" FontSize="9" TextWrapping="Wrap" Margin="0,8,0,0"/>
        </StackPanel>
    </Border>
</UserControl>
