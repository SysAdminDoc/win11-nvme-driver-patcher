<UserControl x:Class="NVMeDriverPatcher.Views.TuningPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,4,0">
            <StackPanel>
                <TextBlock Text="StorNVMe Tuning" Style="{StaticResource SectionEyebrow}"/>
                <TextBlock Text="Adjust queue and power settings only when you need to go beyond the default patch path."
                           Margin="0,8,0,0"
                           Style="{StaticResource BodyCopy}"/>
            </StackPanel>

            <Border Margin="0,18,0,0" Style="{StaticResource InsetCard}">
                <StackPanel>
                    <TextBlock Text="Presets" Style="{StaticResource SectionEyebrow}"/>
                    <TextBlock Text="Start with a preset so the intent stays obvious, then move into custom values only when this machine needs it."
                               Margin="0,8,0,0"
                               Style="{StaticResource BodyCopy}"/>

                    <WrapPanel Margin="0,16,0,0">
                        <Button x:Name="BtnPerformance"
                                Content="Performance"
                                Click="Profile_Click"
                                Tag="Performance"
                                Style="{StaticResource SecondaryButton}"
                                AutomationProperties.Name="Choose performance tuning preset"
                                ToolTip="Bias queue and split settings toward throughput-heavy desktop workloads."
                                Margin="0,0,10,10"/>
                        <Button x:Name="BtnBalanced"
                                Content="Balanced"
                                Click="Profile_Click"
                                Tag="Balanced"
                                Style="{StaticResource SecondaryButton}"
                                AutomationProperties.Name="Choose balanced tuning preset"
                                ToolTip="Stay closest to Windows defaults while keeping the configuration easy to reason about."
                                Margin="0,0,10,10"/>
                        <Button x:Name="BtnPowerSave"
                                Content="Power Save"
                                Click="Profile_Click"
                                Tag="PowerSave"
                                Style="{StaticResource SecondaryButton}"
                                AutomationProperties.Name="Choose power save tuning preset"
                                ToolTip="Bias the tuning plan toward calmer idle behavior and battery-sensitive systems."
                                Margin="0,0,0,10"/>
                    </WrapPanel>

                    <Border Margin="0,8,0,0"
                            Padding="14,12"
                            Background="{StaticResource SurfaceInset}"
                            BorderBrush="{StaticResource Border}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <StackPanel>
                            <TextBlock Text="Preset Summary" Style="{StaticResource SectionEyebrow}"/>
                            <TextBlock x:Name="ProfileTitleText"
                                       Margin="0,8,0,0"
                                       Foreground="{StaticResource Accent}"
                                       FontSize="20"
                                       FontWeight="SemiBold"/>
                            <TextBlock x:Name="ProfileDescriptionText"
                                       Margin="0,8,0,0"
                                       Style="{StaticResource BodyCopy}"/>
                            <TextBlock x:Name="ProfileImpactText"
                                       Margin="0,10,0,0"
                                       Foreground="{StaticResource TextDim}"
                                       FontSize="11.5"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Margin="0,18,0,0" Style="{StaticResource InsetCard}">
                <StackPanel>
                    <TextBlock Text="Custom tuning" Style="{StaticResource SectionEyebrow}"/>
                    <TextBlock Text="Each override writes directly to StorNVMe registry parameters, so make changes one dimension at a time."
                               Margin="0,8,0,0"
                               Style="{StaticResource BodyCopy}"/>

                    <Expander Margin="0,18,0,0"
                              IsExpanded="False"
                              Style="{StaticResource DarkExpander}">
                        <Expander.Header>
                            <TextBlock Text="Custom parameters"
                                       FontWeight="SemiBold"/>
                        </Expander.Header>
                        <StackPanel>
                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="92"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Grid.ColumnSpan="2">
                                <TextBlock Text="Queue Depth" Foreground="{StaticResource TextSecondary}" FontWeight="SemiBold"/>
                                <TextBlock Text="Higher values increase outstanding I/O and usually favor throughput-heavy desktops."
                                           Margin="0,4,0,0"
                                           Foreground="{StaticResource TextDim}"
                                           FontSize="11.5"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <Slider x:Name="SliderQueueDepth"
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Minimum="16"
                                    Maximum="256"
                                    TickFrequency="16"
                                    IsSnapToTickEnabled="True"
                                    AutomationProperties.Name="Queue depth"
                                    Style="{StaticResource DarkSlider}"
                                    ValueChanged="Slider_Changed"/>
                            <TextBlock x:Name="QueueDepthValue"
                                       Grid.Row="1"
                                       Grid.Column="1"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource Accent}"
                                       FontSize="13"
                                       FontWeight="SemiBold"/>
                        </Grid>

                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="92"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Grid.ColumnSpan="2">
                                <TextBlock Text="Max Read Split" Foreground="{StaticResource TextSecondary}" FontWeight="SemiBold"/>
                                <TextBlock Text="Larger reads favor throughput while smaller splits can improve latency balance."
                                           Margin="0,4,0,0"
                                           Foreground="{StaticResource TextDim}"
                                           FontSize="11.5"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <Slider x:Name="SliderReadSplit"
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Minimum="64"
                                    Maximum="1024"
                                    TickFrequency="64"
                                    IsSnapToTickEnabled="True"
                                    AutomationProperties.Name="Maximum read split"
                                    Style="{StaticResource DarkSlider}"
                                    ValueChanged="Slider_Changed"/>
                            <TextBlock x:Name="ReadSplitValue"
                                       Grid.Row="1"
                                       Grid.Column="1"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource Accent}"
                                       FontSize="13"
                                       FontWeight="SemiBold"/>
                        </Grid>

                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="92"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Grid.ColumnSpan="2">
                                <TextBlock Text="Max Write Split" Foreground="{StaticResource TextSecondary}" FontWeight="SemiBold"/>
                                <TextBlock Text="Use larger write batches for burst throughput and smaller ones for tighter control."
                                           Margin="0,4,0,0"
                                           Foreground="{StaticResource TextDim}"
                                           FontSize="11.5"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <Slider x:Name="SliderWriteSplit"
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Minimum="64"
                                    Maximum="1024"
                                    TickFrequency="64"
                                    IsSnapToTickEnabled="True"
                                    AutomationProperties.Name="Maximum write split"
                                    Style="{StaticResource DarkSlider}"
                                    ValueChanged="Slider_Changed"/>
                            <TextBlock x:Name="WriteSplitValue"
                                       Grid.Row="1"
                                       Grid.Column="1"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource Accent}"
                                       FontSize="13"
                                       FontWeight="SemiBold"/>
                        </Grid>

                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="92"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Grid.ColumnSpan="2">
                                <TextBlock Text="I/O Submission Queues" Foreground="{StaticResource TextSecondary}" FontWeight="SemiBold"/>
                                <TextBlock Text="0 keeps Windows automatic queue allocation. Override it only when you have a clear reason to cap or expand parallelism."
                                           Margin="0,4,0,0"
                                           Foreground="{StaticResource TextDim}"
                                           FontSize="11.5"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <Slider x:Name="SliderQueueCount"
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Minimum="0"
                                    Maximum="64"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    AutomationProperties.Name="I/O submission queue count"
                                    Style="{StaticResource DarkSlider}"
                                    ValueChanged="Slider_Changed"/>
                            <TextBlock x:Name="QueueCountValue"
                                       Grid.Row="1"
                                       Grid.Column="1"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource Accent}"
                                       FontSize="13"
                                       FontWeight="SemiBold"/>
                        </Grid>

                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="92"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Grid.ColumnSpan="2">
                                <TextBlock Text="Idle Power Timeout" Foreground="{StaticResource TextSecondary}" FontWeight="SemiBold"/>
                                <TextBlock Text="0 disables idle power-down. Lower values favor faster power saving, while higher values stay more performance-biased."
                                           Margin="0,4,0,0"
                                           Foreground="{StaticResource TextDim}"
                                           FontSize="11.5"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <Slider x:Name="SliderIdlePowerTimeout"
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Minimum="0"
                                    Maximum="500"
                                    TickFrequency="25"
                                    IsSnapToTickEnabled="True"
                                    AutomationProperties.Name="Idle power timeout"
                                    Style="{StaticResource DarkSlider}"
                                    ValueChanged="Slider_Changed"/>
                            <TextBlock x:Name="IdlePowerValue"
                                       Grid.Row="1"
                                       Grid.Column="1"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource Accent}"
                                       FontSize="13"
                                       FontWeight="SemiBold"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="92"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Grid.ColumnSpan="2">
                                <TextBlock Text="Standby Power Timeout" Foreground="{StaticResource TextSecondary}" FontWeight="SemiBold"/>
                                <TextBlock Text="0 keeps deeper standby disabled. Higher values can save more power, but they may add wake latency on some controllers."
                                           Margin="0,4,0,0"
                                           Foreground="{StaticResource TextDim}"
                                           FontSize="11.5"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <Slider x:Name="SliderStandbyPowerTimeout"
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Minimum="0"
                                    Maximum="3000"
                                    TickFrequency="100"
                                    IsSnapToTickEnabled="True"
                                    AutomationProperties.Name="Standby power timeout"
                                    Style="{StaticResource DarkSlider}"
                                    ValueChanged="Slider_Changed"/>
                            <TextBlock x:Name="StandbyPowerValue"
                                       Grid.Row="1"
                                       Grid.Column="1"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource Accent}"
                                       FontSize="13"
                                       FontWeight="SemiBold"/>
                        </Grid>
                        </StackPanel>
                    </Expander>

                    <Border Margin="0,18,0,0"
                            Padding="16,14"
                            Background="{StaticResource YellowBg}"
                            BorderBrush="{StaticResource Border}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <TextBlock Text="Queue count 0 means automatic queue allocation, and timeout values of 0 disable that power-saving path. Benchmark after each reboot so the change earns its keep."
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>

            <Border Margin="0,18,0,0" Style="{StaticResource InsetCard}">
                <StackPanel>
                    <TextBlock Text="Apply Plan" Style="{StaticResource SectionEyebrow}"/>
                    <TextBlock Text="Review what is active now, what will be written next, and whether the change is still small enough to understand after a reboot."
                               Margin="0,8,0,0"
                               Style="{StaticResource BodyCopy}"/>

                    <WrapPanel Margin="0,18,0,0">
                        <Border Width="260" Margin="0,0,14,14" Style="{StaticResource MetricCard}">
                            <StackPanel>
                                <TextBlock Text="Current Baseline" Style="{StaticResource SectionEyebrow}"/>
                                <TextBlock x:Name="CurrentConfigText"
                                           Margin="0,8,0,0"
                                           Foreground="{StaticResource TextSecondary}"
                                           FontSize="12"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Width="260" Margin="0,0,0,14" Style="{StaticResource MetricCard}">
                            <StackPanel>
                                <TextBlock Text="Pending Write" Style="{StaticResource SectionEyebrow}"/>
                                <TextBlock x:Name="PendingConfigText"
                                           Margin="0,8,0,0"
                                           Foreground="{StaticResource TextSecondary}"
                                           FontSize="12"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </WrapPanel>

                    <WrapPanel Margin="0,18,0,0">
                        <Button x:Name="BtnApplyTuning"
                                Content="Apply Tuning"
                                Click="ApplyTuning_Click"
                                Style="{StaticResource ActionButton}"
                                AutomationProperties.Name="Apply StorNVMe tuning"
                                ToolTip="Write the pending tuning values to the registry. A reboot is required before they become active."
                                Margin="0,0,10,0"/>
                        <Button x:Name="BtnResetTuning"
                                Content="Reset to Defaults"
                                Click="ResetTuning_Click"
                                Style="{StaticResource WarningSecondaryButton}"
                                AutomationProperties.Name="Reset StorNVMe tuning to defaults"
                                ToolTip="Remove explicit StorNVMe overrides so Windows defaults return after reboot."/>
                    </WrapPanel>

                    <Border x:Name="TuningStatusCard"
                            Margin="0,16,0,0"
                            Padding="16,14"
                            Style="{StaticResource InsetCard}">
                        <StackPanel>
                            <TextBlock Text="Registry Write Status" Style="{StaticResource SectionEyebrow}"/>
                            <TextBlock x:Name="TuningStatus"
                                       Margin="0,8,0,0"
                                       Foreground="{StaticResource TextDim}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Changes take effect after a reboot. Performance favors throughput, Balanced stays closest to Windows defaults, and Power Save is better suited to battery-sensitive systems."
                               Margin="0,12,0,0"
                               Foreground="{StaticResource TextDim}"
                               FontSize="11.5"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
