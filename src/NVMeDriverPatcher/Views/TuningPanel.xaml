<UserControl x:Class="NVMeDriverPatcher.Views.TuningPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="0,0,4,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Text="StorNVMe Tuning" Style="{StaticResource SectionEyebrow}"/>
                <TextBlock Text="Adjust queue behavior and power-management knobs when you want to go beyond the default patch experience."
                           Margin="0,8,0,0"
                           Style="{StaticResource BodyCopy}"/>
            </StackPanel>

            <Border Grid.Row="1" Margin="0,18,0,0" Style="{StaticResource InsetCard}">
                <StackPanel>
                    <TextBlock Text="Preset Profiles" Style="{StaticResource SectionEyebrow}"/>
                    <TextBlock Text="Start with a preset so the tuning intent is clear, then adjust only what this machine actually needs."
                               Margin="0,8,0,0"
                               Style="{StaticResource BodyCopy}"/>

                    <WrapPanel Margin="0,14,0,0">
                        <Button x:Name="BtnPerformance"
                                Content="Performance"
                                Click="Profile_Click"
                                Tag="Performance"
                                Style="{StaticResource SecondaryButton}"
                                Margin="0,0,10,10"/>
                        <Button x:Name="BtnBalanced"
                                Content="Balanced"
                                Click="Profile_Click"
                                Tag="Balanced"
                                Style="{StaticResource SecondaryButton}"
                                Margin="0,0,10,10"/>
                        <Button x:Name="BtnPowerSave"
                                Content="Power Save"
                                Click="Profile_Click"
                                Tag="PowerSave"
                                Style="{StaticResource SecondaryButton}"
                                Margin="0,0,0,10"/>
                    </WrapPanel>

                    <Border Margin="0,6,0,0"
                            Padding="16,14"
                            Background="{StaticResource AccentBg}"
                            BorderBrush="{StaticResource BorderLight}"
                            BorderThickness="1"
                            CornerRadius="14">
                        <StackPanel>
                            <TextBlock Text="Preset Summary" Style="{StaticResource SectionEyebrow}"/>
                            <TextBlock x:Name="ProfileTitleText"
                                       Margin="0,8,0,0"
                                       Foreground="{StaticResource Accent}"
                                       FontSize="18"
                                       FontWeight="SemiBold"/>
                            <TextBlock x:Name="ProfileDescriptionText"
                                       Margin="0,8,0,0"
                                       Style="{StaticResource BodyCopy}"/>
                            <TextBlock x:Name="ProfileImpactText"
                                       Margin="0,10,0,0"
                                       Foreground="{StaticResource TextDim}"
                                       FontSize="11"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Margin="0,18,0,0" Style="{StaticResource InsetCard}">
                <StackPanel>
                    <TextBlock Text="Custom Parameters" Style="{StaticResource SectionEyebrow}"/>
                    <TextBlock Text="Each override writes directly to the StorNVMe registry parameters. Keep changes deliberate and validate after reboot."
                               Margin="0,8,0,0"
                               Style="{StaticResource BodyCopy}"/>

                    <StackPanel Margin="0,18,0,0">
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="86"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Queue Depth" Foreground="{StaticResource TextSecondary}" FontWeight="SemiBold"/>
                                <TextBlock Text="Higher values increase outstanding I/O for throughput-heavy systems."
                                           Margin="0,4,0,0"
                                           Foreground="{StaticResource TextDim}"
                                           FontSize="11"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <Slider x:Name="SliderQueueDepth"
                                    Grid.Column="1"
                                    Minimum="16"
                                    Maximum="256"
                                    TickFrequency="16"
                                    IsSnapToTickEnabled="True"
                                    Style="{StaticResource DarkSlider}"
                                    ValueChanged="Slider_Changed"/>
                            <TextBlock x:Name="QueueDepthValue"
                                       Grid.Column="2"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource Accent}"
                                       FontSize="13"
                                       FontWeight="SemiBold"/>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="86"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Max Read Split" Foreground="{StaticResource TextSecondary}" FontWeight="SemiBold"/>
                                <TextBlock Text="Larger reads favor throughput while smaller splits can improve latency balance."
                                           Margin="0,4,0,0"
                                           Foreground="{StaticResource TextDim}"
                                           FontSize="11"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <Slider x:Name="SliderReadSplit"
                                    Grid.Column="1"
                                    Minimum="64"
                                    Maximum="1024"
                                    TickFrequency="64"
                                    IsSnapToTickEnabled="True"
                                    Style="{StaticResource DarkSlider}"
                                    ValueChanged="Slider_Changed"/>
                            <TextBlock x:Name="ReadSplitValue"
                                       Grid.Column="2"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource Accent}"
                                       FontSize="13"
                                       FontWeight="SemiBold"/>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="86"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Max Write Split" Foreground="{StaticResource TextSecondary}" FontWeight="SemiBold"/>
                                <TextBlock Text="Use larger write batches for desktop burst performance and smaller ones for tighter control."
                                           Margin="0,4,0,0"
                                           Foreground="{StaticResource TextDim}"
                                           FontSize="11"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <Slider x:Name="SliderWriteSplit"
                                    Grid.Column="1"
                                    Minimum="64"
                                    Maximum="1024"
                                    TickFrequency="64"
                                    IsSnapToTickEnabled="True"
                                    Style="{StaticResource DarkSlider}"
                                    ValueChanged="Slider_Changed"/>
                            <TextBlock x:Name="WriteSplitValue"
                                       Grid.Column="2"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource Accent}"
                                       FontSize="13"
                                       FontWeight="SemiBold"/>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="86"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="I/O Submission Queues" Foreground="{StaticResource TextSecondary}" FontWeight="SemiBold"/>
                                <TextBlock Text="0 keeps Windows automatic queue allocation. Override it only when you have a clear reason to cap or expand parallelism."
                                           Margin="0,4,0,0"
                                           Foreground="{StaticResource TextDim}"
                                           FontSize="11"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <Slider x:Name="SliderQueueCount"
                                    Grid.Column="1"
                                    Minimum="0"
                                    Maximum="64"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    Style="{StaticResource DarkSlider}"
                                    ValueChanged="Slider_Changed"/>
                            <TextBlock x:Name="QueueCountValue"
                                       Grid.Column="2"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource Accent}"
                                       FontSize="13"
                                       FontWeight="SemiBold"/>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="86"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Idle Power Timeout" Foreground="{StaticResource TextSecondary}" FontWeight="SemiBold"/>
                                <TextBlock Text="0 disables idle power-down. Lower values enter low-power states sooner, while higher values stay performance-biased."
                                           Margin="0,4,0,0"
                                           Foreground="{StaticResource TextDim}"
                                           FontSize="11"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <Slider x:Name="SliderIdlePowerTimeout"
                                    Grid.Column="1"
                                    Minimum="0"
                                    Maximum="500"
                                    TickFrequency="25"
                                    IsSnapToTickEnabled="True"
                                    Style="{StaticResource DarkSlider}"
                                    ValueChanged="Slider_Changed"/>
                            <TextBlock x:Name="IdlePowerValue"
                                       Grid.Column="2"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource Accent}"
                                       FontSize="13"
                                       FontWeight="SemiBold"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="86"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Standby Power Timeout" Foreground="{StaticResource TextSecondary}" FontWeight="SemiBold"/>
                                <TextBlock Text="0 leaves deeper standby disabled. Higher values can save more power, but they may add wake latency on some controllers."
                                           Margin="0,4,0,0"
                                           Foreground="{StaticResource TextDim}"
                                           FontSize="11"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <Slider x:Name="SliderStandbyPowerTimeout"
                                    Grid.Column="1"
                                    Minimum="0"
                                    Maximum="3000"
                                    TickFrequency="100"
                                    IsSnapToTickEnabled="True"
                                    Style="{StaticResource DarkSlider}"
                                    ValueChanged="Slider_Changed"/>
                            <TextBlock x:Name="StandbyPowerValue"
                                       Grid.Column="2"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource Accent}"
                                       FontSize="13"
                                       FontWeight="SemiBold"/>
                        </Grid>
                    </StackPanel>

                    <Border Margin="0,18,0,0"
                            Padding="14,12"
                            Background="{StaticResource YellowBg}"
                            BorderBrush="{StaticResource Border}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <TextBlock Text="Queue count 0 means automatic queue allocation, and timeout values of 0 disable that power-saving path. Benchmark after each reboot so you can tell whether a change actually helped."
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="3" Margin="0,18,0,0">
                <Border Margin="0,0,0,14"
                        Padding="16,14"
                        Style="{StaticResource InsetCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Current Baseline" Style="{StaticResource SectionEyebrow}"/>
                            <TextBlock x:Name="CurrentConfigText"
                                       Margin="0,8,0,0"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontSize="12"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Pending Write" Style="{StaticResource SectionEyebrow}"/>
                            <TextBlock x:Name="PendingConfigText"
                                       Margin="0,8,0,0"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontSize="12"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <StackPanel Orientation="Horizontal">
                    <Button x:Name="BtnApplyTuning"
                            Content="Apply Tuning"
                            Click="ApplyTuning_Click"
                            Style="{StaticResource ActionButton}"
                            Margin="0,0,10,0"/>
                    <Button x:Name="BtnResetTuning"
                            Content="Reset to Defaults"
                            Click="ResetTuning_Click"
                            Style="{StaticResource OutlinedActionButton}"/>
                </StackPanel>

                <Border x:Name="TuningStatusCard"
                        Margin="0,14,0,0"
                        Padding="16,14"
                        Style="{StaticResource InsetCard}">
                    <StackPanel>
                        <TextBlock Text="Registry Write Status" Style="{StaticResource SectionEyebrow}"/>
                        <TextBlock x:Name="TuningStatus"
                                   Margin="0,8,0,0"
                                   Foreground="{StaticResource TextDim}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="Changes take effect after a reboot. Performance favors throughput, Balanced stays closest to Windows defaults, and Power Save is better suited to battery-sensitive systems."
                           Margin="0,12,0,0"
                           Foreground="{StaticResource TextDim}"
                           FontSize="11"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
